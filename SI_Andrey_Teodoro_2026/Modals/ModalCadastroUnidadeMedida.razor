@inject IUnidadeMedidaService UnidadeMedidaService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Straighten" Class="mr-2" />
            @(_readOnly ? "Detalhes da Unidade de Medida" : _dto.IdOriginal == 0 ? "Cadastrar Nova Unidade de Medida" : "Editar Unidade de Medida")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.Sigla"
                                  ValueChanged="@((string v) => _dto.Sigla = v.Replace(" ", "").ToUpper())"
                                  Label="Sigla" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="6" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarSigla(v))" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField Value="@_dto.Descricao"
                                  ValueChanged="@((string v) => _dto.Descricao = Cap(v))"
                                  Label="Descrição" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="50" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => string.IsNullOrWhiteSpace(v) ? "Obrigatório" : v.Trim().Length < 2 ? "Mínimo 2 caracteres" : null)" Disabled="@_readOnly" />
                </MudItem>
            </MudGrid>
        </MudForm>
        @if (_dto.AtualizadoEm.HasValue)
        {
            <MudText Style="font-size:0.75rem;color:#999;text-align:right;display:block;margin-top:8px;">
                Alterado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
                @if (!string.IsNullOrWhiteSpace(_dto.NomeAtualizadoPor))
                {
                    <text> por @_dto.NomeAtualizadoPor</text>
                }
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        @if (_readOnly)
        {
            <MudButton OnClick="Cancelar" Variant="Variant.Text">Fechar</MudButton>
            <MudButton OnClick="@(() => _readOnly = false)" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Edit">
                Editar
            </MudButton>
        }
        else
        {
            <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
            <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                       Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
                @(_salvando ? "Salvando..." : "Salvar")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public UnidadeMedidaDto? DtoEdicao { get; set; }
    [Parameter] public bool SomenteLeitura { get; set; } = false;

    private bool _readOnly;
    private UnidadeMedidaDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido, _salvando;

    protected override Task OnInitializedAsync()
    {
        _readOnly = SomenteLeitura;
        if (DtoEdicao is not null)
            _dto = new UnidadeMedidaDto
            {
                Id = DtoEdicao.Id,
                IdOriginal = DtoEdicao.IdOriginal,
                Sigla = DtoEdicao.Sigla,
                Descricao = DtoEdicao.Descricao,
                Ativo = DtoEdicao.Ativo,
                AtualizadoEm = DtoEdicao.AtualizadoEm,
                NomeAtualizadoPor = DtoEdicao.NomeAtualizadoPor
            };
        return base.OnInitializedAsync();
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await UnidadeMedidaService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }
    private void Cancelar() => MudDialog.Cancel();
    private string? ValidarSigla(string? v) { if (string.IsNullOrWhiteSpace(v)) return "Obrigatório"; if (!System.Text.RegularExpressions.Regex.IsMatch(v.Trim(), @"^[A-Z0-9\²\³\/]+$")) return "Apenas maiúsculas e números"; return null; }
    private static string Cap(string? v) => string.IsNullOrWhiteSpace(v) ? v ?? "" : v.Trim().ToUpper();
    private static readonly HashSet<string> _min = new(StringComparer.OrdinalIgnoreCase) { "da", "de", "do", "das", "dos", "e", "a", "o", "as", "os", "em", "no", "na", "com", "por", "para", "ao", "aos" };
}

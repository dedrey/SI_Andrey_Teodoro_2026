@inject IMetodoPagamentoService MetodoPagamentoService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.CreditCard" Class="mr-2" />
            Cadastrar Novo Método de Pagamento
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">

                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.Codigo"
                                  ValueChanged="@((string v) => _dto.Codigo = FiltrarLetrasUpper(v))"
                                  Label="Código"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="4" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarCodigo(v))" />
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField Value="@_dto.MetodoPagamento"
                                  ValueChanged="@((string v) => _dto.MetodoPagamento = CapPalavras(v))"
                                  Label="Nome do Método"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="25" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarNome(v))" />
                </MudItem>

            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private MetodoPagamentoDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await MetodoPagamentoService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }

    private void Cancelar() => MudDialog.Cancel();

    private string? ValidarCodigo(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        if (v.Length < 1 || v.Length > 4) return "1 a 4 caracteres";
        return null;
    }

    private string? ValidarNome(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        if (v.Trim().Length < 2) return "Mínimo 2 caracteres";
        return null;
    }

    private string FiltrarLetrasUpper(string? v)
        => string.IsNullOrEmpty(v) ? "" : new string(v.Where(char.IsLetterOrDigit).ToArray()).ToUpper();

    private static readonly HashSet<string> _prep = new(StringComparer.OrdinalIgnoreCase)
    { "da", "de", "do", "das", "dos", "e", "a", "o", "as", "os", "em", "no", "na", "of", "and", "the" };

    private string CapPalavras(string? v)
    {
        if (string.IsNullOrEmpty(v)) return v ?? "";
        var palavras = v.Trim().ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        for (int i = 0; i < palavras.Length; i++)
            if (i == 0 || i == palavras.Length - 1 || !_prep.Contains(palavras[i]))
                palavras[i] = char.ToUpper(palavras[i][0]) + palavras[i][1..];
        return string.Join(" ", palavras);
    }
}

@inject IMetodoPagamentoService MetodoPagamentoService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Payment" Class="mr-2" />
            @(_dto.IdOriginal == 0 ? "Cadastrar Novo Método de Pagamento" : "Editar Método de Pagamento")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.Codigo"
                                  ValueChanged="@((string v) => _dto.Codigo = new string(v.Where(char.IsLetterOrDigit).ToArray()).ToUpper())"
                                  Label="Código" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="4" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => !System.Text.RegularExpressions.Regex.IsMatch(v?.Trim() ?? "", @"^[A-Z0-9]{1,4}$") ? "Letras maiúsculas/números (máx 4)" : null)" />
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField Value="@_dto.MetodoPagamento"
                                  ValueChanged="@((string v) => _dto.MetodoPagamento = Cap(v))"
                                  Label="Método de Pagamento" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="25" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => string.IsNullOrWhiteSpace(v) ? "Obrigatório" : v.Trim().Length < 2 ? "Mínimo 2 caracteres" : null)" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public MetodoPagamentoDto? DtoEdicao { get; set; }

    private MetodoPagamentoDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido, _salvando;

    protected override Task OnInitializedAsync()
    {
        if (DtoEdicao is not null)
            _dto = new MetodoPagamentoDto
            {
                Id = DtoEdicao.Id,
                IdOriginal = DtoEdicao.IdOriginal,
                Codigo = DtoEdicao.Codigo,
                MetodoPagamento = DtoEdicao.MetodoPagamento,
                Ativo = DtoEdicao.Ativo
            };
        return base.OnInitializedAsync();
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await MetodoPagamentoService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }
    private void Cancelar() => MudDialog.Cancel();
    private static string Cap(string? v) => string.IsNullOrWhiteSpace(v) ? v ?? "" : v.Trim().ToUpper();
}

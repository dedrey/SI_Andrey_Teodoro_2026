@inject ICidadeService CidadeService
@inject IEstadoService EstadoService
@inject IPaisService PaisService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces


<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.LocationCity" Class="mr-2" />
            Cadastrar Nova Cidade
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="10" sm="5">
                    <MudSelect T="int" Value="_dto.PaisId" ValueChanged="OnPaisAlterado"
                               Label="@(_paisNaoSelecionado ? "País * — Obrigatório!" : "País *")"
                               Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                               Class="@(_paisNaoSelecionado ? "mud-input-error" : "")">
                        <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                        @foreach (var pais in _paises)
                        {
                            <MudSelectItem T="int" Value="@pais.Id">@pais.NomePais</MudSelectItem>
                        }
                    </MudSelect>
                    @if (_paisNaoSelecionado)
                    {
                        <MudText Typo="Typo.caption" Style="color:red;margin-left:14px;">⚠ Selecione um país</MudText>
                    }
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudTooltip Text="Novo País">
                        <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                       Size="Size.Medium" OnClick="AbrirModalPais" />
                    </MudTooltip>
                </MudItem>
                <MudItem xs="10" sm="5">
                    <MudSelect T="int" @bind-Value="_dto.EstadoId"
                               Label="@(_estadoNaoSelecionado ? "Estado * — Obrigatório!" : "Estado *")"
                               Variant="Variant.Outlined" Margin="Margin.Dense"
                               Disabled="@(_dto.PaisId == 0)" FullWidth="true"
                               Class="@(_estadoNaoSelecionado ? "mud-input-error" : "")">
                        <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                        @foreach (var estado in _estados)
                        {
                            <MudSelectItem T="int" Value="@estado.Id">@estado.NomeEstado (@estado.Uf)</MudSelectItem>
                        }
                    </MudSelect>
                    @if (_estadoNaoSelecionado)
                    {
                        <MudText Typo="Typo.caption" Style="color:red;margin-left:14px;">⚠ Selecione um estado</MudText>
                    }
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudTooltip Text="Novo Estado">
                        <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                       Size="Size.Medium" Disabled="@(_dto.PaisId == 0)"
                                       OnClick="AbrirModalEstado" />
                    </MudTooltip>
                </MudItem>
                <MudItem xs="8" sm="9">
                    <MudTextField Value="@_dto.NomeCidade"
                                  ValueChanged="@((string v) => _dto.NomeCidade = Cap(v))"
                                  Label="Cidade"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="50" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarSoLetras(v, "Cidade"))" />
                </MudItem>
                <MudItem xs="4" sm="3">
                    <MudTextField Value="@_dddTexto"
                                  ValueChanged="@((string v) => OnDddAlterado(v))"
                                  Label="DDD"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="3" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarDdd(v))" />
                </MudItem>

            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int PaisIdInicial { get; set; }
    [Parameter] public int EstadoIdInicial { get; set; }

    private CidadeDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;
    private string _dddTexto = "";

    private List<PaisListDto> _paises = new();
    private List<EstadoListDto> _estados = new();
    private bool _paisNaoSelecionado;
    private bool _estadoNaoSelecionado;

    protected override async Task OnInitializedAsync()
    {
        _paises = (await PaisService.ObterTodosAtivosAsync()).ToList();
        if (PaisIdInicial > 0)
        {
            _dto.PaisId = PaisIdInicial;
            _estados = (await EstadoService.ObterPorPaisAsync(PaisIdInicial)).ToList();
        }
        if (EstadoIdInicial > 0)
            _dto.EstadoId = EstadoIdInicial;
    }

    private async Task OnPaisAlterado(int paisId)
    {
        _dto.PaisId = paisId;
        _dto.EstadoId = 0;
        _paisNaoSelecionado = false;
        _estados = (await EstadoService.ObterPorPaisAsync(paisId)).ToList();
    }

    private void OnDddAlterado(string? v)
    {
        if (string.IsNullOrEmpty(v)) { _dddTexto = ""; _dto.Ddd = 0; return; }
        var d = new string(v.Where(char.IsDigit).ToArray());
        _dddTexto = d;
        _dto.Ddd = short.TryParse(d, out short num) ? num : (short)0;
    }

    private async Task AbrirModalPais()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroPais>("Novo País", opts);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            _paises = (await PaisService.ObterTodosAtivosAsync()).ToList();
            if (result.Data is int novoId)
            {
                _dto.PaisId = novoId;
                _paisNaoSelecionado = false;
                _estados = (await EstadoService.ObterPorPaisAsync(novoId)).ToList();
            }
        }
    }

    private async Task AbrirModalEstado()
    {
        var param = new DialogParameters<ModalCadastroEstado>
        {
            { x => x.PaisIdInicial, _dto.PaisId }
        };
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroEstado>("Novo Estado", param, opts);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            _estados = (await EstadoService.ObterPorPaisAsync(_dto.PaisId)).ToList();
            if (result.Data is int novoId)
            {
                _dto.EstadoId = novoId;
                _estadoNaoSelecionado = false;
            }
        }
    }

    private async Task Salvar()
    {
        if (_dto.PaisId == 0)
        {
            _paisNaoSelecionado = true;
            Snackbar.Add("⚠️ Selecione um País.", Severity.Warning);
            return;
        }
        if (_dto.EstadoId == 0)
        {
            _estadoNaoSelecionado = true;
            Snackbar.Add("⚠️ Selecione um Estado.", Severity.Warning);
            return;
        }
        await _form.Validate();
        if (!_formValido) return;

        _salvando = true;
        var (sucesso, mensagem, id) = await CidadeService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }

    private void Cancelar() => MudDialog.Cancel();

    private string? ValidarSoLetras(string? v, string campo)
    {
        if (string.IsNullOrWhiteSpace(v)) return $"{campo} é obrigatório";
        if (!System.Text.RegularExpressions.Regex.IsMatch(v, @"^[a-zA-ZÀ-ÿ\s]+$"))
            return $"{campo} deve conter apenas letras";
        return null;
    }

    private string? ValidarDdd(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        var d = new string(v.Where(char.IsDigit).ToArray());
        if (!short.TryParse(d, out short num) || num < 1 || num > 999)
            return "DDD deve ser entre 1 e 999";
        return null;
    }

    private string Cap(string? v)
    {
        if (string.IsNullOrEmpty(v)) return v ?? "";
        var palavras = v.Trim().ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        for (int i = 0; i < palavras.Length; i++)
        {
            if (i == 0 || i == palavras.Length - 1 || !_min.Contains(palavras[i]))
                palavras[i] = char.ToUpper(palavras[i][0]) + palavras[i][1..];
        }
        return string.Join(" ", palavras);
    }

    private static readonly HashSet<string> _min = new(StringComparer.OrdinalIgnoreCase)
    {
        "da","de","do","das","dos","e","a","o","as","os","em","no","na","com","por","para","ao","aos"
    };
}

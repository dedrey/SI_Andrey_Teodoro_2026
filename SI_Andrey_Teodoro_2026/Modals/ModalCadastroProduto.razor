@inject IProdutoService ProdutoService
@inject ICategoriaService CategoriaService
@inject IMarcaService MarcaService
@inject IUnidadeMedidaService UnidadeMedidaService
@inject ICorService CorService
@inject ITamanhoService TamanhoService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" Color="Color.Primary" Class="mr-2" />
            <MudText Typo="Typo.h6">@(_dto.IdOriginal != 0 ? "Editar Produto" : "Novo Produto")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                @if (_dto.IdOriginal != 0)
                {
                    <MudItem xs="3" sm="2" md="1">
                        <MudTextField @bind-Value="_dto.Id" Label="ID" Variant="Variant.Outlined"
                                      Margin="Margin.Dense" FullWidth="true" ReadOnly="true" />
                    </MudItem>
                }
                <MudItem xs="@(_dto.IdOriginal != 0 ? 9 : 12)" sm="@(_dto.IdOriginal != 0 ? 10 : 12)" md="@(_dto.IdOriginal != 0 ? 11 : 12)">
                    <MudTextField Value="@_dto.Produto" ValueChanged="@((string v) => _dto.Produto = Cap(v))"
                                  Label="Produto" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => string.IsNullOrWhiteSpace(v) ? "Obrigatório" : v.Trim().Length < 2 ? "Mínimo 2 caracteres" : null)" />
                </MudItem>
            </MudGrid>

            <MudGrid Spacing="2" Class="mt-2">
                <MudItem xs="10" sm="4" md="4">
                    <MudAutocomplete T="CategoriaListDto"
                                     Value="@(_categorias.FirstOrDefault(c => c.Id == _dto.CategoriaId))"
                                     ValueChanged="@((CategoriaListDto? c) => _dto.CategoriaId = c?.Id ?? 0)"
                                     SearchFunc="@((s, ct) => Task.FromResult(string.IsNullOrEmpty(s) ? _categorias.AsEnumerable() : _categorias.Where(c => c.NomeCategoria.Contains(s, StringComparison.OrdinalIgnoreCase))))"
                                     ToStringFunc="@(c => c?.NomeCategoria ?? "")"
                                     Label="Categoria" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                                     ResetValueOnEmptyText="true" CoerceText="false" Placeholder="Pesquisar..." />
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Medium" OnClick="AbrirModalCategoria" />
                </MudItem>
                <MudItem xs="10" sm="4" md="3">
                    <MudAutocomplete T="MarcaListDto"
                                     Value="@(_marcas.FirstOrDefault(m => m.Id == _dto.MarcaId))"
                                     ValueChanged="@((MarcaListDto? m) => _dto.MarcaId = m?.Id ?? 0)"
                                     SearchFunc="@((s, ct) => Task.FromResult(string.IsNullOrEmpty(s) ? _marcas.AsEnumerable() : _marcas.Where(m => m.NomeMarca.Contains(s, StringComparison.OrdinalIgnoreCase))))"
                                     ToStringFunc="@(m => m?.NomeMarca ?? "")"
                                     Label="Marca" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                                     ResetValueOnEmptyText="true" CoerceText="false" Placeholder="Pesquisar..." />
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Medium" OnClick="AbrirModalMarca" />
                </MudItem>
                <MudItem xs="10" sm="4" md="2">
                    <MudAutocomplete T="UnidadeMedidaListDto"
                                     Value="@(_unidades.FirstOrDefault(u => u.Id == _dto.UnidadeMedidaId))"
                                     ValueChanged="@((UnidadeMedidaListDto? u) => _dto.UnidadeMedidaId = u?.Id ?? 0)"
                                     SearchFunc="@((s, ct) => Task.FromResult(string.IsNullOrEmpty(s) ? _unidades.AsEnumerable() : _unidades.Where(u => u.Sigla.Contains(s, StringComparison.OrdinalIgnoreCase) || u.Descricao.Contains(s, StringComparison.OrdinalIgnoreCase))))"
                                     ToStringFunc="@(u => u == null ? "" : $"{u.Sigla} — {u.Descricao}")"
                                     Label="Unidade" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                                     ResetValueOnEmptyText="true" CoerceText="false" Placeholder="Pesquisar..." />
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Medium" OnClick="AbrirModalUnidade" />
                </MudItem>
            </MudGrid>

            <MudGrid Spacing="2" Class="mt-2">
                <MudItem xs="12">
                    <MudTextField Value="@_dto.Descricao" ValueChanged="@((string? v) => _dto.Descricao = Cap(v))"
                                  Label="Descrição" Variant="Variant.Outlined"
                                  Margin="Margin.Dense" MaxLength="500" FullWidth="true" Lines="2" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle2" Style="font-weight:600;text-transform:uppercase;letter-spacing:1px;color:#888;margin-bottom:12px;">
                Compra / Custo (vale para o produto inteiro, não muda por cor/tamanho)
            </MudText>
            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField Value="@(_dto.CodigoBarras ?? "")" ValueChanged="@((string v) => _dto.CodigoBarras = v)"
                                  Label="Código de Barras" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="50" FullWidth="true" Immediate="true"
                                  HelperText="Um só código pra este produto (todas as variações)" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField Value="@GetCompraTexto()" ValueChanged="@((string v) => OnCompraAlterado(v))"
                                  Label="Compra (R$)" Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                  FullWidth="true" Adornment="Adornment.Start" AdornmentText="R$" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField Value="@GetFreteTexto()" ValueChanged="@((string v) => OnFreteAlterado(v))"
                                  Label="Frete (R$)" Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                  FullWidth="true" Adornment="Adornment.Start" AdornmentText="R$" />
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudTextField Value="@(_dto.PrecoCusto.ToString("N2"))" ReadOnly="true" Disabled="true"
                                  Label="Custo (R$)" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  FullWidth="true" Adornment="Adornment.Start" AdornmentText="R$"
                                  Style="background-color:#fafafa;" HelperText="Compra + Frete, calculado" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />
            <div class="d-flex align-center justify-space-between mb-3">
                <MudText Typo="Typo.subtitle2" Style="font-weight:600;text-transform:uppercase;letter-spacing:1px;color:#888;">
                    Variações (Cor / Tamanho / Preço de Venda)
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.AddCircleOutline" OnClick="AdicionarVariacao">
                    Nova Variação
                </MudButton>
            </div>

            @if (_dto.Variacoes.Count(v => !v.Removida) > 1)
            {
                <div class="d-flex align-center gap-3 mb-3 pa-2" style="background:#f8f9fa;border-radius:8px;">
                    <MudIcon Icon="@Icons.Material.Filled.Sell" Size="Size.Small" Style="color:#888;" />
                    <MudText Typo="Typo.body2" Style="color:#666;white-space:nowrap;">Replicar valor de venda pra todas as variações:</MudText>
                    <MudTextField Value="@_replicarVendaTexto" ValueChanged="@((string v) => _replicarVendaTexto = v)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                  Adornment="Adornment.Start" AdornmentText="R$" Style="max-width:160px;" />
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.ContentCopy" OnClick="ReplicarValorVenda">
                        Replicar Valor de Venda
                    </MudButton>
                </div>
            }

            <MudExpansionPanels Elevation="0" Class="mb-3" Style="border:1px solid #e0e0e0;border-radius:8px;">
                <MudExpansionPanel Text="Gerar várias combinações de cor × tamanho de uma vez" Icon="@Icons.Material.Filled.GridView">
                    <div class="d-flex flex-wrap align-end gap-3">
                        <MudSelect T="int" @bind-SelectedValues="_coresLote" MultiSelection="true" Label="Cores"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:220px;"
                                   MultiSelectionTextFunc="@((IReadOnlyList<string> l) => $"{l.Count} cor(es) selecionada(s)")">
                            @foreach (var c in _cores)
                            {
                                <MudSelectItem T="int" Value="@c.Id">@c.Nome</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="int" @bind-SelectedValues="_tamanhosLote" MultiSelection="true" Label="Tamanhos"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Style="min-width:220px;"
                                   MultiSelectionTextFunc="@((IReadOnlyList<string> l) => $"{l.Count} tamanho(s) selecionado(s)")">
                            @foreach (var t in _tamanhos)
                            {
                                <MudSelectItem T="int" Value="@t.Id">@t.Nome</MudSelectItem>
                            }
                        </MudSelect>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.GridView"
                                   OnClick="GerarCombinacoes" Style="height:40px;">
                            Gerar combinações
                        </MudButton>
                    </div>
                    <MudText Typo="Typo.caption" Style="color:#888;display:block;margin-top:8px;">
                        Cria uma variação pra cada combinação marcada (pulando as que já existem), já com o preço de venda
                        copiado da última variação preenchida — é só ajustar o que for diferente. Código de barras,
                        compra, frete e custo já valem pra todas (preenchidos ali em cima).
                    </MudText>
                </MudExpansionPanel>
            </MudExpansionPanels>

            @if (_dto.Variacoes.Any(v => !v.Removida))
            {
                <MudTable Items="@_dto.Variacoes.Where(v => !v.Removida)" Dense="true" Hover="false"
                          Elevation="0" Style="border:1px solid #f0f0f0;border-radius:8px;">
                    <HeaderContent>
                        <MudTh Style="font-weight:600;">Cor</MudTh>
                        <MudTh Style="font-weight:600;width:36px;"></MudTh>
                        <MudTh Style="font-weight:600;">Tamanho</MudTh>
                        <MudTh Style="font-weight:600;width:36px;"></MudTh>
                        <MudTh Style="font-weight:600;">Venda (R$)</MudTh>
                        <MudTh Style="font-weight:600;text-align:center;">Estoque</MudTh>
                        <MudTh Style="font-weight:600;text-align:center;">Ação</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        @{
                            bool fastFashion = context.IdOriginal > 0 && _dto.PrecoCusto > 0 && context.PermiteVendaAbaixoCusto;
                            bool abaixoCusto = _dto.PrecoCusto > 0 && context.Preco < _dto.PrecoCusto;
                        }
                        <MudTd>
                            <MudSelect T="int" Value="context.CorId" ValueChanged="@((int id) => { context.CorId = id; context.Cor = _cores.FirstOrDefault(c => c.Id == id)?.Nome ?? ""; })"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                                <MudSelectItem T="int" Value="0" Disabled="true">— Cor —</MudSelectItem>
                                @foreach (var c in _cores)
                                {
                                    <MudSelectItem T="int" Value="@c.Id">@c.Nome</MudSelectItem>
                                }
                            </MudSelect>
                        </MudTd>
                        <MudTd Style="padding:4px;">
                            <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                           Size="Size.Small" OnClick="AbrirModalCor" />
                        </MudTd>
                        <MudTd>
                            <MudSelect T="int" Value="context.TamanhoId" ValueChanged="@((int id) => { context.TamanhoId = id; context.Tamanho = _tamanhos.FirstOrDefault(t => t.Id == id)?.Nome ?? ""; })"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                                <MudSelectItem T="int" Value="0" Disabled="true">— Tam —</MudSelectItem>
                                @foreach (var t in _tamanhos)
                                {
                                    <MudSelectItem T="int" Value="@t.Id">@t.Nome</MudSelectItem>
                                }
                            </MudSelect>
                        </MudTd>
                        <MudTd Style="padding:4px;">
                            <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                           Size="Size.Small" OnClick="AbrirModalTamanho" />
                        </MudTd>
                        <MudTd>
                            <MudTextField Value="@GetPrecoTexto(context)" ValueChanged="@((string v) => OnPrecoAlterado(context, v))"
                                          Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                          FullWidth="true" Adornment="Adornment.Start" AdornmentText="R$"
                                          Style="@(abaixoCusto && !fastFashion ? "border-color:red;" : "")" />
                            @if (abaixoCusto)
                            {
                                <MudText Typo="Typo.caption" Color="@(fastFashion? Color.Warning: Color.Error)">
                                    @(fastFashion ? "⚡ Fast Fashion — abaixo do custo permitido" : "⚠ Abaixo do custo")
                                </MudText>
                            }
                        </MudTd>
                        <MudTd Style="text-align:center;">
                            @if (context.IdOriginal > 0)
                            {
                                <div>
                                    <MudText Typo="Typo.body2" Style="font-weight:600;">@context.QuantidadeEstoque un.</MudText>
                                    @if (context.DataUltimaCompra.HasValue)
                                    {
                                        <MudText Typo="Typo.caption" Style="color:#888;">
                                            Última compra: @context.DataUltimaCompra.Value.ToString("dd/MM/yyyy")
                                        </MudText>
                                    }
                                </div>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Style="color:#bbb;">Salve primeiro</MudText>
                            }
                        </MudTd>
                        <MudTd Style="text-align:center;">
                            @if (context.IdOriginal == 0)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error"
                                               Size="Size.Small" OnClick="@(() => RemoverVariacao(context))" />
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small"
                                         Color="@(context.QuantidadeEstoque > 0 ? Color.Success : Color.Warning)"
                                         Variant="Variant.Outlined">
                                    @(context.QuantidadeEstoque > 0 ? "Em estoque" : "Sem estoque")
                                </MudChip>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <div class="d-flex align-center justify-center pa-4" style="border:1px dashed #ddd;border-radius:8px;color:#bbb;">
                    <MudIcon Icon="@Icons.Material.Filled.AddCircleOutline" Class="mr-2" />
                    <MudText Typo="Typo.body2">Clique em "Nova Variação" para adicionar cor, tamanho e preço.</MudText>
                </div>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Fechar">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar"
                   Disabled="_salvando" Style="height:40px;font-weight:700;min-width:140px;">
            @(_salvando ? "Salvando..." : "SALVAR")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public ProdutoDto? DtoEdicao { get; set; }

    private MudForm? _form;
    private bool _formValido, _salvando;
    private ProdutoDto _dto = new();
    private List<CategoriaListDto> _categorias = new();
    private List<MarcaListDto> _marcas = new();
    private List<UnidadeMedidaListDto> _unidades = new();
    private List<CorListDto> _cores = new();
    private List<TamanhoListDto> _tamanhos = new();
    private readonly Dictionary<ProdutoVariacaoDto, string> _precoTextos = new();
    private string _compraTexto = "";
    private string _freteTexto = "";
    private string _replicarVendaTexto = "";
    private IReadOnlyCollection<int> _coresLote = new List<int>();
    private IReadOnlyCollection<int> _tamanhosLote = new List<int>();

    private static string Cap(string? s) => string.IsNullOrWhiteSpace(s) ? s ?? "" : s.Trim().ToUpper();

    protected override async Task OnInitializedAsync()
    {
        _dto = DtoEdicao ?? new ProdutoDto();
        _compraTexto = _dto.PrecoCompra > 0 ? _dto.PrecoCompra.ToString("N2") : "";
        _freteTexto = _dto.Frete > 0 ? _dto.Frete.ToString("N2") : "";
        _dto.PrecoCusto = _dto.PrecoCompra + _dto.Frete;
        if (DtoEdicao != null)
        {
            foreach (var v in _dto.Variacoes)
                _precoTextos[v] = v.Preco > 0 ? v.Preco.ToString("N2") : "";
        }
        await Task.WhenAll(
            Task.Run(async () => _categorias = (await CategoriaService.ObterTodosAtivosAsync()).ToList()),
            Task.Run(async () => _marcas = (await MarcaService.ObterTodosAtivosAsync()).ToList()),
            Task.Run(async () => _unidades = (await UnidadeMedidaService.ObterTodosAtivosAsync()).ToList()),
            Task.Run(async () => _cores = (await CorService.ObterTodosAtivosAsync()).ToList()),
            Task.Run(async () => _tamanhos = (await TamanhoService.ObterTodosAtivosAsync()).ToList())
        );
    }

    private string GetCompraTexto() => _compraTexto;
    private void OnCompraAlterado(string? texto)
    {
        var f = new string((texto ?? "").Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        _compraTexto = f;
        _dto.PrecoCompra = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any,
                                   System.Globalization.CultureInfo.InvariantCulture, out decimal d) ? d : 0;
        _dto.PrecoCusto = _dto.PrecoCompra + _dto.Frete;
        StateHasChanged();
    }

    private string GetFreteTexto() => _freteTexto;
    private void OnFreteAlterado(string? texto)
    {
        var f = new string((texto ?? "").Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        _freteTexto = f;
        _dto.Frete = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any,
                                   System.Globalization.CultureInfo.InvariantCulture, out decimal d) ? d : 0;
        _dto.PrecoCusto = _dto.PrecoCompra + _dto.Frete;
        StateHasChanged();
    }

    private void AdicionarVariacao()
    {
        var nova = new ProdutoVariacaoDto();
        var ultima = _dto.Variacoes.LastOrDefault(v => !v.Removida);
        if (ultima != null)
            nova.Preco = ultima.Preco;
        _dto.Variacoes.Add(nova);
        _precoTextos[nova] = nova.Preco > 0 ? nova.Preco.ToString("N2") : "";
        StateHasChanged();
    }
    private void RemoverVariacao(ProdutoVariacaoDto v)
    {
        if (v.IdOriginal == 0) { _dto.Variacoes.Remove(v); _precoTextos.Remove(v); }
        else v.Removida = true;
        StateHasChanged();
    }

    private string GetPrecoTexto(ProdutoVariacaoDto v)
    {
        if (!_precoTextos.ContainsKey(v)) _precoTextos[v] = v.Preco > 0 ? v.Preco.ToString("N2") : "";
        return _precoTextos[v];
    }
    private void OnPrecoAlterado(ProdutoVariacaoDto v, string? texto)
    {
        var f = new string((texto ?? "").Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        _precoTextos[v] = f;
        v.Preco = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any,
                                   System.Globalization.CultureInfo.InvariantCulture, out decimal d) ? d : 0;
        StateHasChanged();
    }

    private void ReplicarValorVenda()
    {
        var valor = decimal.TryParse(_replicarVendaTexto.Replace(",", "."), System.Globalization.NumberStyles.Any,
                                     System.Globalization.CultureInfo.InvariantCulture, out decimal d) ? d : 0;
        if (valor <= 0)
        {
            Snackbar.Add("Informe um valor de venda antes de replicar.", Severity.Warning);
            return;
        }

        foreach (var v in _dto.Variacoes.Where(v => !v.Removida))
        {
            v.Preco = valor;
            _precoTextos[v] = valor.ToString("N2");
        }
        Snackbar.Add($"Valor de venda aplicado a todas as {_dto.Variacoes.Count(v => !v.Removida)} variações.", Severity.Success);
        StateHasChanged();
    }

    private void GerarCombinacoes()
    {
        var cores = _coresLote?.ToList() ?? new();
        var tamanhos = _tamanhosLote?.ToList() ?? new();
        if (cores.Count == 0 || tamanhos.Count == 0)
        {
            Snackbar.Add("Selecione ao menos uma cor e um tamanho.", Severity.Warning);
            return;
        }

        var ultima = _dto.Variacoes.LastOrDefault(v => !v.Removida);
        int criadas = 0, existentes = 0;

        foreach (var corId in cores)
        {
            foreach (var tamanhoId in tamanhos)
            {
                bool jaExiste = _dto.Variacoes.Any(v => !v.Removida && v.CorId == corId && v.TamanhoId == tamanhoId);
                if (jaExiste) { existentes++; continue; }

                var cor = _cores.FirstOrDefault(c => c.Id == corId);
                var tamanho = _tamanhos.FirstOrDefault(t => t.Id == tamanhoId);
                var nova = new ProdutoVariacaoDto
                {
                    CorId = corId,
                    Cor = cor?.Nome ?? "",
                    TamanhoId = tamanhoId,
                    Tamanho = tamanho?.Nome ?? "",
                    Preco = ultima?.Preco ?? 0
                };
                _dto.Variacoes.Add(nova);
                _precoTextos[nova] = nova.Preco > 0 ? nova.Preco.ToString("N2") : "";
                criadas++;
            }
        }

        var msg = criadas > 0
            ? $"{criadas} variação(ões) criada(s)." + (existentes > 0 ? $" {existentes} já existia(m) e foram pulada(s)." : "")
            : "Todas as combinações selecionadas já existiam.";
        Snackbar.Add(msg, criadas > 0 ? Severity.Success : Severity.Info);
        StateHasChanged();
    }

    private async Task AbrirModalCor()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, BackdropClick = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroCor>("Nova Cor", opts);
        if ((await dialog.Result) is { Canceled: false })
            _cores = (await CorService.ObterTodosAtivosAsync()).ToList();
    }
    private async Task AbrirModalTamanho()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, BackdropClick = false, MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroTamanho>("Novo Tamanho", opts);
        if ((await dialog.Result) is { Canceled: false })
            _tamanhos = (await TamanhoService.ObterTodosAtivosAsync()).ToList();
    }

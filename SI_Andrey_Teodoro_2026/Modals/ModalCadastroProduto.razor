@inject IProdutoService ProdutoService
@inject ICategoriaService CategoriaService
@inject IMarcaService MarcaService
@inject IUnidadeMedidaService UnidadeMedidaService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" Color="Color.Primary" Class="mr-2" />
            <MudText Typo="Typo.h6">@(_dto.IdOriginal != 0 ? "Editar Produto" : "Novo Produto")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                @if (_dto.IdOriginal != 0)
                {
                    <MudItem xs="3" sm="2" md="1">
                        <MudTextField @bind-Value="_dto.Id" Label="ID" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" ReadOnly="true" />
                    </MudItem>
                }
                <MudItem xs="@(_dto.IdOriginal != 0 ? 9 : 12)" sm="@(_dto.IdOriginal != 0 ? 10 : 12)" md="@(_dto.IdOriginal != 0 ? 11 : 12)">
                    <MudTextField Value="@_dto.Produto" ValueChanged="@((string v) => _dto.Produto = Cap(v))"
                                  Label="Produto *" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => string.IsNullOrWhiteSpace(v) ? "Obrigatório" : v.Trim().Length < 2 ? "Mínimo 2 caracteres" : null)" />
                </MudItem>
            </MudGrid>
            <MudGrid Spacing="2" Class="mt-2">
                <MudItem xs="10" sm="4" md="4">
                    <MudSelect T="int" @bind-Value="_dto.CategoriaId" Label="Categoria *" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                        <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                        @foreach (var c in _categorias)
                        {
                            <MudSelectItem T="int" Value="@c.Id">@c.NomeCategoria</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="2" sm="1" md="1" Class="d-flex align-end pb-1">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Medium" OnClick="AbrirModalCategoria" />
                </MudItem>
                <MudItem xs="10" sm="4" md="3">
                    <MudSelect T="int" @bind-Value="_dto.MarcaId" Label="Marca *" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                        <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                        @foreach (var m in _marcas)
                        {
                            <MudSelectItem T="int" Value="@m.Id">@m.NomeMarca</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="2" sm="1" md="1" Class="d-flex align-end pb-1">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Medium" OnClick="AbrirModalMarca" />
                </MudItem>
                <MudItem xs="10" sm="4" md="2">
                    <MudSelect T="int" @bind-Value="_dto.UnidadeMedidaId" Label="Unidade *" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                        <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                        @foreach (var u in _unidades)
                        {
                            <MudSelectItem T="int" Value="@u.Id">@u.Sigla — @u.Descricao</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="2" sm="1" md="1" Class="d-flex align-end pb-1">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Medium" OnClick="AbrirModalUnidade" />
                </MudItem>
            </MudGrid>
            <MudGrid Spacing="2" Class="mt-2">
                <MudItem xs="12">
                    <MudTextField Value="@_dto.Descricao" ValueChanged="@((string? v) => _dto.Descricao = v)"
                                  Label="Descrição" Placeholder="Opcional" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="500" FullWidth="true" Lines="2" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />
            <div class="d-flex align-center justify-space-between mb-3">
                <MudText Typo="Typo.subtitle2" Style="font-weight:600;text-transform:uppercase;letter-spacing:1px;color:#888;">
                    Variações (Cor / Tamanho / Preço)
                </MudText>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                           StartIcon="@Icons.Material.Filled.AddCircleOutline" OnClick="AdicionarVariacao">
                    Nova Variação
                </MudButton>
            </div>

            @if (_dto.Variacoes.Any(v => !v.Removida))
            {
                <MudTable Items="@_dto.Variacoes.Where(v => !v.Removida)" Dense="true" Hover="false" Elevation="0"
                          Style="border:1px solid #f0f0f0;border-radius:8px;">
                    <HeaderContent>
                        <MudTh Style="font-weight:600;">Cor</MudTh>
                        <MudTh Style="font-weight:600;">Tamanho</MudTh>
                        <MudTh Style="font-weight:600;">Cód. Barras</MudTh>
                        <MudTh Style="font-weight:600;">Preço (R$)</MudTh>
                        <MudTh Style="font-weight:600;text-align:center;">Estoque</MudTh>
                        <MudTh Style="font-weight:600;text-align:center;">Ação</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudTextField Value="@context.Cor" ValueChanged="@((string v) => context.Cor = Cap(v))" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="30" Immediate="true" FullWidth="true" /></MudTd>
                        <MudTd><MudTextField Value="@context.Tamanho" ValueChanged="@((string v) => context.Tamanho = v.Trim().ToUpper())" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="10" Immediate="true" FullWidth="true" /></MudTd>
                        <MudTd><MudTextField @bind-Value="context.CodigoBarras" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="50" FullWidth="true" /></MudTd>
                        <MudTd><MudTextField Value="@GetPrecoTexto(context)" ValueChanged="@((string v) => OnPrecoAlterado(context, v))" Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true" FullWidth="true" Adornment="Adornment.Start" AdornmentText="R$" /></MudTd>
                        <MudTd Style="text-align:center;">
                            @if (context.IdOriginal > 0)
                            {
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@context.QuantidadeEstoque un.</MudText>
                                <MudText Typo="Typo.caption" Style="color:#bbb;">(via Movimentações)</MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.caption" Style="color:#bbb;">Salve primeiro</MudText>
                            }
                        </MudTd>
                        <MudTd Style="text-align:center;">
                            @if (context.IdOriginal == 0)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline" Color="Color.Error" Size="Size.Small" OnClick="@(() => RemoverVariacao(context))" />
                            }
                            else
                            {
                                <MudChip T="string" Size="Size.Small" Color="@(context.QuantidadeEstoque > 0 ? Color.Success : Color.Warning)" Variant="Variant.Outlined">
                                    @(context.QuantidadeEstoque > 0 ? "Em estoque" : "Sem estoque")
                                </MudChip>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
            else
            {
                <div class="d-flex align-center justify-center pa-4" style="border:1px dashed #ddd;border-radius:8px;color:#bbb;">
                    <MudIcon Icon="@Icons.Material.Filled.AddCircleOutline" Class="mr-2" />
                    <MudText Typo="Typo.body2">Clique em "Nova Variação" para adicionar cor, tamanho e preço.</MudText>
                </div>
            }
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Fechar" Style="height:40px;">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar"
                   Disabled="_salvando" Style="height:40px;font-weight:700;min-width:140px;">
            @(_salvando ? "Salvando..." : "SALVAR")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public ProdutoDto? DtoEdicao { get; set; }

    private MudForm? _form;
    private bool _formValido;
    private bool _salvando;
    private ProdutoDto _dto = new();
    private List<CategoriaListDto> _categorias = new();
    private List<MarcaListDto> _marcas = new();
    private List<UnidadeMedidaListDto> _unidades = new();
    private readonly Dictionary<ProdutoVariacaoDto, string> _precoTextos = new();

    private static readonly HashSet<string> _prep = new(StringComparer.OrdinalIgnoreCase)
        { "da", "de", "do", "das", "dos", "e", "a", "o", "as", "os", "em", "no", "na", "com", "por", "para", "ao", "aos" };

    private static string Cap(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return s ?? "";
        return string.Join(" ", s.Trim().Split(' ')
            .Select((w, i) => i > 0 && _prep.Contains(w)
                ? w.ToLower()
                : w.Length == 0 ? w : char.ToUpper(w[0]) + w[1..].ToLower()));
    }

    protected override async Task OnInitializedAsync()
    {
        _dto = DtoEdicao ?? new ProdutoDto();
        if (DtoEdicao != null)
            foreach (var v in _dto.Variacoes)
                _precoTextos[v] = v.Preco > 0 ? v.Preco.ToString("N2") : "";

        var t1 = CategoriaService.ObterTodosAtivosAsync();
        var t2 = MarcaService.ObterTodosAtivosAsync();
        var t3 = UnidadeMedidaService.ObterTodosAtivosAsync();
        await Task.WhenAll(t1, t2, t3);
        _categorias = (await t1).ToList();
        _marcas = (await t2).ToList();
        _unidades = (await t3).ToList();
    }

    private void AdicionarVariacao() { _dto.Variacoes.Add(new ProdutoVariacaoDto()); StateHasChanged(); }
    private void RemoverVariacao(ProdutoVariacaoDto v) { if (v.IdOriginal == 0) { _dto.Variacoes.Remove(v); _precoTextos.Remove(v); } else v.Removida = true; StateHasChanged(); }

    private string GetPrecoTexto(ProdutoVariacaoDto v)
    {
        if (!_precoTextos.ContainsKey(v)) _precoTextos[v] = v.Preco > 0 ? v.Preco.ToString("N2") : "";
        return _precoTextos[v];
    }
    private void OnPrecoAlterado(ProdutoVariacaoDto v, string? texto)
    {
        if (string.IsNullOrEmpty(texto)) { _precoTextos[v] = ""; v.Preco = 0; return; }
        var f = new string(texto.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        _precoTextos[v] = f;
        v.Preco = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal d) ? d : 0;
    }

    private async Task AbrirModalCategoria()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroCategoria>("Nova Categoria", opts);
        if ((await dialog.Result) is { Canceled: false })
            _categorias = (await CategoriaService.ObterTodosAtivosAsync()).ToList();
    }
    private async Task AbrirModalMarca()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroMarca>("Nova Marca", opts);
        if ((await dialog.Result) is { Canceled: false })
            _marcas = (await MarcaService.ObterTodosAtivosAsync()).ToList();
    }
    private async Task AbrirModalUnidade()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroUnidadeMedida>("Nova Unidade", opts);
        if ((await dialog.Result) is { Canceled: false })
            _unidades = (await UnidadeMedidaService.ObterTodosAtivosAsync()).ToList();
    }

    private async Task Salvar()
    {
        await _form!.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, _) = await ProdutoService.SalvarAsync(_dto);
        _salvando = false;
        Snackbar.Add(mensagem, sucesso ? Severity.Success : Severity.Error);
        if (sucesso) MudDialog.Close(DialogResult.Ok(true));
    }
    private void Fechar() => MudDialog.Cancel();
}

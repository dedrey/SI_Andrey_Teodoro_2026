@inject ICategoriaService CategoriaService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Category" Class="mr-2" />
            @(_dto.IdOriginal == 0 ? "Cadastrar Nova Categoria" : "Editar Categoria")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudTextField Value="@_dto.NomeCategoria"
                                  ValueChanged="@((string v) => _dto.NomeCategoria = Cap(v))"
                                  Label="Categoria" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="50" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarNome(v))" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public CategoriaDto? DtoEdicao { get; set; }

    private CategoriaDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido, _salvando;

    protected override Task OnInitializedAsync()
    {
        if (DtoEdicao is not null)
            _dto = new CategoriaDto { Id = DtoEdicao.Id, IdOriginal = DtoEdicao.IdOriginal,
                                      NomeCategoria = DtoEdicao.NomeCategoria, Ativo = DtoEdicao.Ativo };
        return base.OnInitializedAsync();
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await CategoriaService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }
    private void Cancelar() => MudDialog.Cancel();
    private string? ValidarNome(string? v) { if (string.IsNullOrWhiteSpace(v)) return "Obrigatório"; if (v.Trim().Length < 2) return "Mínimo 2 caracteres"; if (!System.Text.RegularExpressions.Regex.IsMatch(v.Trim(), @"^[a-zA-ZÀ-ÿ0-9\s\-\/\.\'\(\)]+$")) return "Caracteres inválidos"; return null; }
    private static string Cap(string? v) => string.IsNullOrWhiteSpace(v) ? v ?? "" : v.Trim().ToUpper();
}

@inject ITransportadoraService TransportadoraService
@inject ICidadeService CidadeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Primary" Class="mr-2" />
            <MudText Typo="Typo.h6">@(_dto.IdOriginal != 0 ? "Editar Transportadora" : "Cadastrar Nova Transportadora")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.RazaoSocial" ValueChanged="@((string v) => _dto.RazaoSocial = Cap(v))" Label="Razão Social" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.NomeFantasia" ValueChanged="@((string? v) => _dto.NomeFantasia = v == null ? null : Cap(v))" Label="Nome Fantasia" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="100" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_cnpjTexto" ValueChanged="@((string v) => { _cnpjTexto = MascaraCnpj(v); _dto.Cnpj = _cnpjTexto; })"
                                  Label="CNPJ" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="18" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => new string((v ?? "").Where(char.IsDigit).ToArray()).Length != 14 ? "CNPJ deve ter 14 dígitos" : null)" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.InscricaoEstadual" ValueChanged="@((string v) => _dto.InscricaoEstadual = Cap(v))" Label="Inscrição Estadual"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="30" FullWidth="true" Immediate="true" />
                </MudItem>
                <MudItem xs="10" sm="5">
                    <MudAutocomplete T="CidadeListDto"
                                     Value="_cidadeSelecionada"
                                     ValueChanged="OnCidadeAlterada"
                                     SearchFunc="PesquisarCidade"
                                     ToStringFunc="@(c => c == null ? "" : $"{c.NomeCidade} — {c.Uf}")"
                                     Label="Cidade*" Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Required="true" RequiredError="Obrigatório"
                                     FullWidth="true" Clearable="true" ResetValueOnEmptyText="true"
                                     CoerceText="false" />
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-center">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                   Size="Size.Medium" OnClick="AbrirModalCidade" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Telefone" ValueChanged="@((string v) => _dto.Telefone = MascaraTel(v))" Label="Telefone"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="15" FullWidth="true" Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Email" ValueChanged="@((string v) => _dto.Email = Cap(v))" Label="E-mail"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarEmail(v))"
                                  InputType="InputType.Email" />
                </MudItem>
                <MudItem xs="12">
                    <MudDivider />
                    <MudText Typo="Typo.caption" Style="color:#888;text-transform:uppercase;letter-spacing:1px;font-weight:600;display:block;margin-top:8px;">
                        Endereço
                    </MudText>
                </MudItem>
                <MudItem xs="12" sm="5">
                    <MudTextField Value="@_dto.Endereco" ValueChanged="@((string v) => _dto.Endereco = Cap(v))" Label="Rua" Immediate="true"
                                  Required="true" RequiredError="Obrigatório"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="100" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudTextField Value="@_dto.Numero" ValueChanged="@((string v) => _dto.Numero = Cap(v))" Label="Número" Immediate="true"
                                  Required="true" RequiredError="Obrigatório"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="10" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="5">
                    <MudTextField Value="@_dto.Bairro" ValueChanged="@((string v) => _dto.Bairro = Cap(v))" Label="Bairro" Immediate="true"
                                  Required="true" RequiredError="Obrigatório"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="60" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Complemento" ValueChanged="@((string v) => _dto.Complemento = Cap(v))" Label="Complemento" Immediate="true"
                                  Required="true" RequiredError="Obrigatório"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="50" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Cep" ValueChanged="@((string v) => _dto.Cep = MascaraCep(v))"
                                  Label="CEP" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Obrigatório"
                                  MaxLength="9" FullWidth="true" Immediate="true" Placeholder="00000-000" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Fechar">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save"
                   Style="font-weight:700;min-width:120px;">
            @(_salvando ? "Salvando..." : "SALVAR")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public TransportadoraDto? DtoEdicao { get; set; }

    private MudForm? _form;
    private bool _formValido, _salvando;
    private string _cnpjTexto = "";
    private TransportadoraDto _dto = new();
    private List<CidadeListDto> _cidades = new();
    private CidadeListDto? _cidadeSelecionada;

    protected override async Task OnInitializedAsync()
    {
        _dto = DtoEdicao ?? new TransportadoraDto();
        _dto.Telefone = MascaraTel(_dto.Telefone);
        _cnpjTexto = _dto.Cnpj ?? "";
        _cidades = (await CidadeService.ObterTodosAtivosSemPaginacaoAsync()).ToList();
        if (_dto.CidadeId.HasValue)
            _cidadeSelecionada = _cidades.FirstOrDefault(c => c.Id == _dto.CidadeId);
    }

    private void OnCidadeAlterada(CidadeListDto? cidade)
    {
        _cidadeSelecionada = cidade;
        _dto.CidadeId = cidade?.Id;
    }

    private Task<IEnumerable<CidadeListDto>> PesquisarCidade(string? busca, CancellationToken ct)
    {
        var r = string.IsNullOrWhiteSpace(busca)
            ? _cidades.Take(50)
            : _cidades.Where(c => c.NomeCidade.Contains(busca, StringComparison.OrdinalIgnoreCase)
                               || c.Uf.Contains(busca, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(r);
    }

    private async Task AbrirModalCidade()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroCidade>("Nova Cidade", opts);
        if ((await dialog.Result) is { Canceled: false })
            _cidades = (await CidadeService.ObterTodosAtivosSemPaginacaoAsync()).ToList();
    }

    private async Task Salvar()
    {
        await _form!.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, _) = await TransportadoraService.SalvarAsync(_dto);
        _salvando = false;
        Snackbar.Add(mensagem, sucesso ? Severity.Success : Severity.Error);
        if (sucesso) MudDialog.Close(DialogResult.Ok(true));
    }

    private void Fechar() => MudDialog.Cancel();

    private string MascaraTel(string? v) { if (string.IsNullOrEmpty(v)) return ""; var d = new string(v.Where(char.IsDigit).ToArray()); if (d.Length > 11) d = d[..11]; return d.Length switch { 0 => "", <= 2 => $"({d}", <= 6 => $"({d[..2]}) {d[2..]}", <= 10 => $"({d[..2]}) {d[2..6]}-{d[6..]}", _ => $"({d[..2]}) {d[2..7]}-{d[7..]}" }; }
    private string MascaraCnpj(string? v) { if (string.IsNullOrEmpty(v)) return ""; var d = new string(v.Where(char.IsDigit).ToArray()); if (d.Length > 14) d = d[..14]; return d.Length switch { 0 => "", <= 2 => d, <= 5 => $"{d[..2]}.{d[2..]}", <= 8 => $"{d[..2]}.{d[2..5]}.{d[5..]}", <= 12 => $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..]}", _ => $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..12]}-{d[12..]}" }; }

    private string MascaraCep(string? v)
    {
        if (string.IsNullOrEmpty(v)) return "";
        var d = new string(v.Where(char.IsDigit).ToArray());
        if (d.Length > 8) d = d[..8];
        return d.Length <= 5 ? d : $"{d[..5]}-{d[5..]}";
    }

    private static string? ValidarEmail(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        return System.Text.RegularExpressions.Regex.IsMatch(v, @"^[^@\s]+@[^@\s]+\.[A-Za-z]{2,}$") ? null : "E-mail inválido";
    }
    private static string Cap(string? s) => string.IsNullOrWhiteSpace(s) ? s ?? "" : s.Trim().ToUpper();
}

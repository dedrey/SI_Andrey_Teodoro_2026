@inject ITransportadoraService TransportadoraService
@inject ICidadeService CidadeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Class="mr-2" />
            Cadastrar Nova Transportadora
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.RazaoSocial"
                                  ValueChanged="@((string v) => _dto.RazaoSocial = Cap(v))"
                                  Label="Razão Social" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="100" FullWidth="true" Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.NomeFantasia"
                                  ValueChanged="@((string v) => _dto.NomeFantasia = Cap(v))"
                                  Label="Nome Fantasia" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="100" FullWidth="true" Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Cnpj"
                                  ValueChanged="@((string v) => _dto.Cnpj = MascaraCnpj(v))"
                                  Label="CNPJ" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="18" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarCnpj(v))" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_dto.InscricaoEstadual"
                                  Label="Inscrição Estadual" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="20" FullWidth="true" />
                </MudItem>
                <MudItem xs="10" sm="5">
                    <MudAutocomplete T="CidadeListDto"
                                     Label="Cidade"
                                     Value="_cidadeSelecionada"
                                     ValueChanged="@((CidadeListDto? c) => { _cidadeSelecionada = c; _dto.CidadeId = c?.Id; })"
                                     SearchFunc="PesquisarCidade"
                                     ToStringFunc="@(c => c == null ? "" : $"{c.NomeCidade} ({c.Uf})")"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     FullWidth="true" Clearable="true"
                                     ResetValueOnEmptyText="true" CoerceText="false" />
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudTooltip Text="Nova Cidade">
                        <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                       Size="Size.Medium" OnClick="AbrirModalCidade" />
                    </MudTooltip>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Telefone"
                                  ValueChanged="@((string v) => _dto.Telefone = MascaraTel(v))"
                                  Label="Telefone" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="15" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarTel(v))" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_dto.Email"
                                  Label="E-mail" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="50" FullWidth="true"
                                  Validation="@((string v) => ValidarEmail(v))"
                                  InputType="InputType.Email" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private TransportadoraDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;

    private List<CidadeListDto> _cidades = new();
    private CidadeListDto? _cidadeSelecionada;

    protected override async Task OnInitializedAsync()
    {
        _cidades = (await CidadeService.ObterTodosAtivosSemPaginacaoAsync())
            .Where(c => c.NomePais.Equals("Brasil", StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private Task<IEnumerable<CidadeListDto>> PesquisarCidade(string? busca, CancellationToken ct)
    {
        var r = string.IsNullOrWhiteSpace(busca)
            ? _cidades.Take(50)
            : _cidades.Where(c => c.NomeCidade.Contains(busca, StringComparison.OrdinalIgnoreCase)
                               || c.Uf.Contains(busca, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(r);
    }

    private async Task AbrirModalCidade()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroCidade>("Nova Cidade", opts);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            _cidades = (await CidadeService.ObterTodosAtivosSemPaginacaoAsync())
                .Where(c => c.NomePais.Equals("Brasil", StringComparison.OrdinalIgnoreCase))
                .ToList();
            if (result.Data is int novoId)
            {
                _cidadeSelecionada = _cidades.FirstOrDefault(c => c.Id == novoId);
                _dto.CidadeId = novoId;
            }
        }
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await TransportadoraService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }

    private void Cancelar() => MudDialog.Cancel();

    private string? ValidarCnpj(string? v) { if (string.IsNullOrWhiteSpace(v)) return "Obrigatório"; var d = new string(v.Where(char.IsDigit).ToArray()); if (d.Length != 14) return "CNPJ deve ter 14 dígitos"; return null; }
    private string? ValidarTel(string? v) { if (string.IsNullOrWhiteSpace(v)) return "Obrigatório"; var d = new string(v.Where(char.IsDigit).ToArray()); return d.Length switch { 10 => null, 11 => null, < 10 => "Incompleto", _ => "Máximo 11 dígitos" }; }
    private string? ValidarEmail(string? v) { if (string.IsNullOrWhiteSpace(v)) return "Obrigatório"; return v.Contains('@') && v.Contains('.') ? null : "E-mail inválido"; }
    private string MascaraCnpj(string? v) { if (string.IsNullOrEmpty(v)) return ""; var d = new string(v.Where(char.IsDigit).ToArray()); if (d.Length > 14) d = d[..14]; return d.Length switch { 0 => "", <= 2 => d, <= 5 => $"{d[..2]}.{d[2..]}", <= 8 => $"{d[..2]}.{d[2..5]}.{d[5..]}", <= 12 => $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..]}", _ => $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..12]}-{d[12..]}" }; }
    private string MascaraTel(string? v) { if (string.IsNullOrEmpty(v)) return ""; var d = new string(v.Where(char.IsDigit).ToArray()); if (d.Length > 11) d = d[..11]; return d.Length switch { 0 => "", <= 2 => $"({d}", <= 6 => $"({d[..2]}) {d[2..]}", <= 10 => $"({d[..2]}) {d[2..6]}-{d[6..]}", _ => $"({d[..2]}) {d[2..7]}-{d[7..]}" }; }
    private string Cap(string? v) { if (string.IsNullOrEmpty(v)) return v ?? ""; var p = v.Trim().ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries); for (int i = 0; i < p.Length; i++) { if (i == 0 || i == p.Length - 1 || !_min.Contains(p[i])) p[i] = char.ToUpper(p[i][0]) + p[i][1..]; } return string.Join(" ", p); }
    private static readonly HashSet<string> _min = new(StringComparer.OrdinalIgnoreCase) { "da", "de", "do", "das", "dos", "e", "a", "o", "as", "os", "em", "no", "na", "com", "por", "para", "ao", "aos" };
}

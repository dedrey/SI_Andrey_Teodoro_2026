@inject ITransportadoraService TransportadoraService
@inject ICidadeService CidadeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Primary" Class="mr-2" />
            <MudText Typo="Typo.h6">@(_dto.IdOriginal != 0 ? "Editar Transportadora" : "Cadastrar Nova Transportadora")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.RazaoSocial" ValueChanged="@((string v) => _dto.RazaoSocial = Cap(v))" Label="Razão Social *" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.NomeFantasia" ValueChanged="@((string? v) => _dto.NomeFantasia = v == null ? null : Cap(v))" Label="Nome Fantasia" Immediate="true"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="100" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_dto.Cnpj" Label="CNPJ *"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="18" FullWidth="true"
                                  Placeholder="00.000.000/0000-00" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_dto.InscricaoEstadual" Label="Inscrição Estadual"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="30" FullWidth="true" />
                </MudItem>
                <MudItem xs="10" sm="5">
                    <MudAutocomplete T="CidadeListDto"
                                     Value="_cidadeSelecionada"
                                     ValueChanged="OnCidadeAlterada"
                                     SearchFunc="PesquisarCidade"
                                     ToStringFunc="@(c => c == null ? "" : $"{c.NomeCidade} — {c.Uf}")"
                                     Label="Cidade" Variant="Variant.Outlined" Margin="Margin.Dense"
                                     FullWidth="true" Clearable="true" ResetValueOnEmptyText="true"
                                     CoerceText="false" Placeholder="Digite para buscar..." />
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-center">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                   Size="Size.Medium" OnClick="AbrirModalCidade" />
                </MudItem>

                <!-- Telefone / E-mail -->
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_dto.Telefone" Label="Telefone *"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="15" FullWidth="true"
                                  Placeholder="(00) 00000-0000" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_dto.Email" Label="E-mail *"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true"
                                  InputType="InputType.Email" />
                </MudItem>

                <!-- Seção Endereço -->
                <MudItem xs="12">
                    <MudDivider />
                    <MudText Typo="Typo.caption" Style="color:#888;text-transform:uppercase;letter-spacing:1px;font-weight:600;display:block;margin-top:8px;">
                        Endereço
                    </MudText>
                </MudItem>
                <MudItem xs="12" sm="7">
                    <MudTextField @bind-Value="_dto.Endereco" Label="Rua / Logradouro"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="100" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="5">
                    <MudTextField @bind-Value="_dto.Bairro" Label="Bairro"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="60" FullWidth="true" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField @bind-Value="_dto.Complemento" Label="Complemento"
                                  Placeholder="Apto, Bloco, Sala..."
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="50" FullWidth="true" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Fechar">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save"
                   Style="font-weight:700;min-width:120px;">
            @(_salvando ? "Salvando..." : "SALVAR")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public TransportadoraDto? DtoEdicao { get; set; }

    private MudForm? _form;
    private bool _formValido, _salvando;
    private TransportadoraDto _dto = new();
    private List<CidadeListDto> _cidades = new();
    private CidadeListDto? _cidadeSelecionada;

    protected override async Task OnInitializedAsync()
    {
        _dto = DtoEdicao ?? new TransportadoraDto();
        _cidades = (await CidadeService.ObterTodosAtivosSemPaginacaoAsync()).ToList();
        if (_dto.CidadeId.HasValue)
            _cidadeSelecionada = _cidades.FirstOrDefault(c => c.Id == _dto.CidadeId);
    }

    private void OnCidadeAlterada(CidadeListDto? cidade)
    {
        _cidadeSelecionada = cidade;
        _dto.CidadeId = cidade?.Id;
    }

    private Task<IEnumerable<CidadeListDto>> PesquisarCidade(string? busca, CancellationToken ct)
    {
        var r = string.IsNullOrWhiteSpace(busca)
            ? _cidades.Take(50)
            : _cidades.Where(c => c.NomeCidade.Contains(busca, StringComparison.OrdinalIgnoreCase)
                               || c.Uf.Contains(busca, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(r);
    }

    private async Task AbrirModalCidade()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroCidade>("Nova Cidade", opts);
        if ((await dialog.Result) is { Canceled: false })
            _cidades = (await CidadeService.ObterTodosAtivosSemPaginacaoAsync()).ToList();
    }

    private async Task Salvar()
    {
        await _form!.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, _) = await TransportadoraService.SalvarAsync(_dto);
        _salvando = false;
        Snackbar.Add(mensagem, sucesso ? Severity.Success : Severity.Error);
        if (sucesso) MudDialog.Close(DialogResult.Ok(true));
    }

    private void Fechar() => MudDialog.Cancel();

    private static readonly HashSet<string> _prep = new(StringComparer.OrdinalIgnoreCase)
        { "da","de","do","das","dos","e","a","o","as","os","em","no","na","com","por","para","ao","aos" };

    private static string Cap(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return s ?? "";
        return string.Join(" ", s.Trim().Split(' ')
            .Select((w, i) => i > 0 && _prep.Contains(w)
                ? w.ToLower()
                : w.Length == 0 ? w : char.ToUpper(w[0]) + w[1..].ToLower()));
    }
}

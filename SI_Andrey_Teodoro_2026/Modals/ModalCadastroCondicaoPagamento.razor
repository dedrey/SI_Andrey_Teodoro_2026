@inject ICondicaoPagamentoService CondicaoPagamentoService
@inject IMetodoPagamentoService MetodoPagamentoService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Class="mr-2" />
            Cadastrar Nova Condição de Pagamento
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">

                <MudItem xs="12" sm="7">
                    <MudTextField Value="@_dto.CondicaoPagamento"
                                  ValueChanged="@((string v) => _dto.CondicaoPagamento = Cap(v))"
                                  Label="Condição de Pagamento"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="50" FullWidth="true" Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudTextField Value="@_parcelasTexto"
                                  ValueChanged="@((string v) => OnParcelasAlterado(v))"
                                  Label="Nº Parcelas"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="3" FullWidth="true" Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudTextField Value="@_entradaTexto"
                                  ValueChanged="@((string v) => { var f = new string(v.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray()); _entradaTexto = f; _dto.EntradaMinimaPercentual = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal d0) ? d0 : 0; })"
                                  Label="Entrada Mín. (%)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="6" FullWidth="true" Immediate="true"
                                  Adornment="Adornment.End" AdornmentText="%" />
                </MudItem>

                <MudItem xs="10" sm="11">
                    <MudSelect T="int" @bind-Value="_dto.MetodoPagamentoId"
                               Label="Método de Pagamento"
                               Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                        <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                        @foreach (var m in _metodos)
                        {
                            <MudSelectItem T="int" Value="@m.Id">[@m.Codigo] @m.MetodoPagamento</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudTooltip Text="Novo Método de Pagamento">
                        <MudIconButton Icon="@Icons.Material.Filled.AddCircle"
                                       Color="Color.Primary" Size="Size.Medium"
                                       OnClick="AbrirModalMetodo" />
                    </MudTooltip>
                </MudItem>

                <MudItem xs="12">
                    <MudDivider Class="my-1" />
                    <MudText Typo="Typo.caption" Style="color:#888;text-transform:uppercase;letter-spacing:1px;font-weight:600;">
                        Taxas e Percentuais
                    </MudText>
                </MudItem>

                <MudItem xs="12" sm="3">
                    <MudTextField Value="@_descontoTexto"
                                  ValueChanged="@((string v) => { var f = new string(v.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray()); _descontoTexto = f; _dto.DescontoPercentual = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal d1) ? d1 : 0; })"
                                  Label="Desconto (%)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="6" FullWidth="true" Immediate="true"
                                  Adornment="Adornment.End" AdornmentText="%" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudTextField Value="@_acrescimoTexto"
                                  ValueChanged="@((string v) => { var f = new string(v.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray()); _acrescimoTexto = f; _dto.AcrescimoPercentual = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal d2) ? d2 : 0; })"
                                  Label="Acréscimo (%)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="6" FullWidth="true" Immediate="true"
                                  Adornment="Adornment.End" AdornmentText="%" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudTextField Value="@_multaTexto"
                                  ValueChanged="@((string v) => { var f = new string(v.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray()); _multaTexto = f; _dto.MultaPercentual = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal d3) ? d3 : 0; })"
                                  Label="Multa (%)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="6" FullWidth="true" Immediate="true"
                                  Adornment="Adornment.End" AdornmentText="%" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudTextField Value="@_jurosTexto"
                                  ValueChanged="@((string v) => { var f = new string(v.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray()); _jurosTexto = f; _dto.TaxaJurosPercentual = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal d4) ? d4 : 0; })"
                                  Label="Taxa de Juros (%)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  MaxLength="6" FullWidth="true" Immediate="true"
                                  Adornment="Adornment.End" AdornmentText="%" />
                </MudItem>

                @if (_dto.DescontoPercentual > 0 || _dto.AcrescimoPercentual > 0 || _dto.TaxaJurosPercentual > 0)
                {
                    <MudItem xs="12">
                        <MudPaper Elevation="0" Class="pa-2 rounded" Style="background:#f5f5f5;">
                            <MudText Typo="Typo.caption" Style="color:#666;">
                                <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-1" Style="vertical-align:middle;" />
                                Exemplo sobre R$ 1.000,00:
                                @if (_dto.DescontoPercentual > 0)
                                {
                                    <span style="color:#2e7d32;margin-left:8px;">
                                        Desconto: - R$ @((1000m * _dto.DescontoPercentual / 100m).ToString("N2"))
                                    </span>
                                }
                                @if (_dto.AcrescimoPercentual > 0)
                                {
                                    <span style="color:#1565c0;margin-left:8px;">
                                        Acréscimo: + R$ @((1000m * _dto.AcrescimoPercentual / 100m).ToString("N2"))
                                    </span>
                                }
                                @if (_dto.TaxaJurosPercentual > 0)
                                {
                                    <span style="color:#e65100;margin-left:8px;">
                                        Juros (@_parcelasTexto@("x")): + R$ @((1000m * _dto.TaxaJurosPercentual / 100m * _dto.NumeroParcelas).ToString("N2"))
                                    </span>
                                }
                            </MudText>
                        </MudPaper>
                    </MudItem>
                }

            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private CondicaoPagamentoDto _dto = new() { NumeroParcelas = 1 };
    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;

    private string _parcelasTexto = "1";
    private string _entradaTexto = "";
    private string _descontoTexto = "";
    private string _acrescimoTexto = "";
    private string _multaTexto = "";
    private string _jurosTexto = "";

    private List<MetodoPagamentoListDto> _metodos = new();

    protected override async Task OnInitializedAsync()
        => _metodos = (await MetodoPagamentoService.ObterTodosAtivosAsync()).ToList();

    private void OnParcelasAlterado(string v)
    {
        var d = new string(v.Where(char.IsDigit).ToArray());
        _parcelasTexto = d;
        _dto.NumeroParcelas = int.TryParse(d, out int n) && n >= 1 ? n : 1;
    }

    private async Task AbrirModalMetodo()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroMetodoPagamento>("Novo Método de Pagamento", opts);
        var result = await dialog.Result;
        _metodos = (await MetodoPagamentoService.ObterTodosAtivosAsync()).ToList();
        if (result is { Canceled: false, Data: int novoId })
            _dto.MetodoPagamentoId = novoId;
    }

    private async Task Salvar()
    {
        if (_dto.MetodoPagamentoId == 0)
        {
            Snackbar.Add("Selecione um método de pagamento.", Severity.Warning);
            return;
        }
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await CondicaoPagamentoService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }

    private void Cancelar() => MudDialog.Cancel();

    private static readonly HashSet<string> _prep = new(StringComparer.OrdinalIgnoreCase)
    { "da", "de", "do", "das", "dos", "e", "a", "o", "as", "os", "em", "no", "na", "ao", "aos", "com", "por", "para" };

    private string Cap(string? v)
    {
        if (string.IsNullOrEmpty(v)) return v ?? "";
        var parts = v.Trim().ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        for (int i = 0; i < parts.Length; i++)
            if (i == 0 || i == parts.Length - 1 || !_prep.Contains(parts[i]))
                parts[i] = char.ToUpper(parts[i][0]) + parts[i][1..];
        return string.Join(" ", parts);
    }
}

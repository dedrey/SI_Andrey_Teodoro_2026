@inject ICondicaoPagamentoService CondicaoPagamentoService
@inject IMetodoPagamentoService MetodoPagamentoService
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@(DtoEdicao == null ? "Nova Condição de Pagamento" : "Editar Condição de Pagamento")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="12" sm="7">
                    <MudTextField @bind-Value="_dto.CondicaoPagamento" Label="Condição de Pagamento"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="50" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="5">
                    <div class="d-flex align-center gap-1">
                        <MudSelect T="int" @bind-Value="_dto.MetodoPagamentoId" Label="Método de Pagamento"
                                   Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" FullWidth="true">
                            @foreach (var m in _metodos)
                            {
                                <MudSelectItem T="int" Value="@m.Id">@m.MetodoPagamento (@m.Codigo)</MudSelectItem>
                            }
                        </MudSelect>
                        <MudTooltip Text="Novo método de pagamento">
                            <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                           Size="Size.Medium" OnClick="AbrirNovoMetodo" />
                        </MudTooltip>
                    </div>
                </MudItem>
            </MudGrid>
            <div style="background:#f8f9fa;border-radius:8px;padding:12px 14px;margin-bottom:12px;">
                <div style="font-size:0.68rem;color:#9e9e9e;text-transform:uppercase;letter-spacing:1px;font-weight:700;margin-bottom:10px;">Taxas e Percentuais</div>
                <MudGrid Spacing="2">
                    <MudItem xs="6" sm="4"><MudNumericField T="decimal" @bind-Value="_dto.DescontoPercentual" HideSpinButtons="true" Label="Desconto (%)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="100" Format="N2" FullWidth="true" /></MudItem>
                    <MudItem xs="6" sm="4"><MudNumericField T="decimal" @bind-Value="_dto.AcrescimoPercentual" HideSpinButtons="true" Label="Acréscimo (%)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="100" Format="N2" FullWidth="true" /></MudItem>
                    <MudItem xs="6" sm="4"><MudNumericField T="decimal" @bind-Value="_dto.TaxaJurosPercentual" HideSpinButtons="true" Label="Juros (%)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="100" Format="N2" FullWidth="true" /></MudItem>
                    <MudItem xs="6" sm="4"><MudNumericField T="decimal" @bind-Value="_dto.MultaPercentual" HideSpinButtons="true" Label="Multa (%)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="100" Format="N2" FullWidth="true" /></MudItem>
                    <MudItem xs="6" sm="4"><MudNumericField T="decimal" @bind-Value="_dto.EntradaMinimaPercentual" HideSpinButtons="true" Label="Entrada mín. (%)" Variant="Variant.Outlined" Margin="Margin.Dense" Min="0" Max="100" Format="N2" FullWidth="true" /></MudItem>
                </MudGrid>
            </div>
            <div style="background:#f8f9fa;border-radius:8px;padding:12px 14px;">
                <div class="d-flex align-center justify-space-between mb-2">
                    <div style="font-size:0.68rem;color:#9e9e9e;text-transform:uppercase;letter-spacing:1px;font-weight:700;">
                        Parcelas (@_dto.Parcelas.Count)
                    </div>
                    <div class="d-flex gap-2 align-center">
                        <MudNumericField T="int" Value="_dto.NumeroParcelas"
                                         ValueChanged="OnNumeroParcelas"
                                         Label="Nº parcelas" Variant="Variant.Outlined"
                                         Margin="Margin.Dense" Min="1" Max="999"
                                         Style="width:110px;" />
                        <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                   OnClick="GerarParcelas" StartIcon="@Icons.Material.Filled.Refresh">
                            Gerar
                        </MudButton>
                    </div>
                </div>

                @if (_dto.Parcelas.Count > 0)
                {
                    <MudTable Items="@_dto.Parcelas" Dense="true" Elevation="0"
                              Style="background:white;border:1px solid #e9ecef;border-radius:6px;">
                        <HeaderContent>
                            <MudTh Style="font-weight:600;font-size:0.78rem;width:80px;">Parcela</MudTh>
                            <MudTh Style="font-weight:600;font-size:0.78rem;">Dias até vencimento</MudTh>
                            <MudTh Style="font-weight:600;font-size:0.78rem;color:#888;">Vencimento (a partir de hoje)</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="font-weight:600;">@context.NumeroParcela</MudTd>
                            <MudTd>
                                <MudNumericField T="int" @bind-Value="context.DiasVencimento"
                                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                                 Min="1" Max="3650" Style="max-width:120px;" />
                            </MudTd>
                            <MudTd Style="color:#888;font-size:0.85rem;">
                                @DateTime.Today.AddDays(context.DiasVencimento).ToString("dd/MM/yyyy")
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Style="color:#bbb;font-size:0.85rem;padding:4px 0;">
                        Defina o número de parcelas e clique em "Gerar" para configurar os prazos.
                    </MudText>
                }
            </div>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Fechar" Disabled="_salvando">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="Salvar" Disabled="_salvando">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public CondicaoPagamentoDto? DtoEdicao { get; set; }

    private CondicaoPagamentoDto _dto = new();
    private List<MetodoPagamentoListDto> _metodos = new();
    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;

    protected override async Task OnInitializedAsync()
    {
        _dto = DtoEdicao != null
            ? new CondicaoPagamentoDto
            {
                Id = DtoEdicao.Id,
                IdOriginal = DtoEdicao.IdOriginal,
                CondicaoPagamento = DtoEdicao.CondicaoPagamento,
                MetodoPagamentoId = DtoEdicao.MetodoPagamentoId,
                NumeroParcelas = DtoEdicao.NumeroParcelas,
                EntradaMinimaPercentual = DtoEdicao.EntradaMinimaPercentual,
                DescontoPercentual = DtoEdicao.DescontoPercentual,
                AcrescimoPercentual = DtoEdicao.AcrescimoPercentual,
                MultaPercentual = DtoEdicao.MultaPercentual,
                TaxaJurosPercentual = DtoEdicao.TaxaJurosPercentual,
                Ativo = DtoEdicao.Ativo,
                Parcelas = DtoEdicao.Parcelas.Select(p => new CondicaoPagamentoParcelaDto
                { Id = p.Id, NumeroParcela = p.NumeroParcela, DiasVencimento = p.DiasVencimento }).ToList()
            }
            : new CondicaoPagamentoDto();

        var metodos = await MetodoPagamentoService.ObterTodosAtivosAsync();
        _metodos = metodos.ToList();
        if (_dto.Parcelas.Count == 0 && _dto.NumeroParcelas > 0)
            GerarParcelas();
    }

    private void OnNumeroParcelas(int valor)
    {
        _dto.NumeroParcelas = valor;
        while (_dto.Parcelas.Count < valor)
        {
            var n = _dto.Parcelas.Count + 1;
            _dto.Parcelas.Add(new CondicaoPagamentoParcelaDto
            { NumeroParcela = n, DiasVencimento = 30 * n });
        }
        while (_dto.Parcelas.Count > valor)
            _dto.Parcelas.RemoveAt(_dto.Parcelas.Count - 1);
    }

    private void GerarParcelas()
    {
        _dto.Parcelas = Enumerable.Range(1, _dto.NumeroParcelas)
            .Select(n => new CondicaoPagamentoParcelaDto
            { NumeroParcela = n, DiasVencimento = 30 * n })
            .ToList();
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        if (_dto.Parcelas.Count != _dto.NumeroParcelas)
        {
            Snackbar.Add("Clique em 'Gerar' para definir os prazos das parcelas.", Severity.Warning);
            return;
        }
        _salvando = true;
        var (sucesso, mensagem, _) = await CondicaoPagamentoService.SalvarAsync(_dto);
        _salvando = false;
        Snackbar.Add(mensagem, sucesso ? Severity.Success : Severity.Error);
        if (sucesso) MudDialog.Close(DialogResult.Ok(true));
    }

    private async Task AbrirNovoMetodo()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroMetodoPagamento>("Novo Método de Pagamento", opts);
        if ((await dialog.Result) is { Canceled: false })
        {
            var metodos = await MetodoPagamentoService.ObterTodosAtivosAsync();
            _metodos = metodos.ToList();
        }
    }

    private void Fechar() => MudDialog.Cancel();
}

@inject ICondicaoPagamentoService CondicaoPagamentoService
@inject IMetodoPagamentoService MetodoPagamentoService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Class="mr-2" />
            @(_dto.IdOriginal == 0 ? "Cadastrar Nova Condição de Pagamento" : "Editar Condição de Pagamento")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.CondicaoPagamento" ValueChanged="@((string v) => _dto.CondicaoPagamento = Cap(v))"
                                  Label="Condição de Pagamento" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="50" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => string.IsNullOrWhiteSpace(v) ? "Obrigatório" : v.Trim().Length < 2 ? "Mínimo 2 caracteres" : null)" />
                </MudItem>
                <MudItem xs="10" sm="5">
                    <MudSelect T="int" @bind-Value="_dto.MetodoPagamentoId"
                               Label="Método de Pagamento *" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                        <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                        @foreach (var m in _metodos)
                        {
                            <MudSelectItem T="int" Value="@m.Id">[@m.Codigo] @m.MetodoPagamento</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudTooltip Text="Novo Método"><MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Medium" OnClick="AbrirModalMetodo" /></MudTooltip>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudTextField Value="@_parcelasTexto" ValueChanged="@((string v) => OnParcelasAlterado(v))"
                                  Label="Nº Parcelas" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="3" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => !int.TryParse(v, out int n) || n < 1 || n > 999 ? "1 a 999" : null)" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-3" />
            <MudText Typo="Typo.caption" Style="color:#888;font-weight:600;text-transform:uppercase;letter-spacing:1px;">Taxas e Percentuais</MudText>
            <MudGrid Spacing="2" Class="mt-2">
                @foreach (var campo in _campos)
                {
                    <MudItem xs="6" sm="4">
                        <MudTextField Value="@campo.Texto" ValueChanged="@((string v) => OnPercentualAlterado(v, campo))"
                                      Label="@campo.Label" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      MaxLength="10" FullWidth="true" Immediate="true"
                                      Adornment="Adornment.End" AdornmentText="%" />
                    </MudItem>
                }
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public CondicaoPagamentoDto? DtoEdicao { get; set; }

    private CondicaoPagamentoDto _dto = new() { NumeroParcelas = 1 };
    private MudForm _form = null!;
    private bool _formValido, _salvando;
    private string _parcelasTexto = "1";
    private List<MetodoPagamentoListDto> _metodos = new();

    private record CampoPercentual(string Label, string Key) { public string Texto { get; set; } = ""; }
    private List<CampoPercentual> _campos = new()
    {
        new("Entrada Mín. (%)", "entrada"), new("Desconto (%)", "desconto"),
        new("Acréscimo (%)", "acrescimo"), new("Multa (%)", "multa"), new("Juros (%)", "juros")
    };

    protected override async Task OnInitializedAsync()
    {
        _metodos = (await MetodoPagamentoService.ObterTodosAtivosAsync()).ToList();
        if (DtoEdicao is not null)
        {
            _dto = new CondicaoPagamentoDto
            {
                Id = DtoEdicao.Id,
                IdOriginal = DtoEdicao.IdOriginal,
                CondicaoPagamento = DtoEdicao.CondicaoPagamento,
                MetodoPagamentoId = DtoEdicao.MetodoPagamentoId,
                NumeroParcelas = DtoEdicao.NumeroParcelas,
                EntradaMinimaPercentual = DtoEdicao.EntradaMinimaPercentual,
                DescontoPercentual = DtoEdicao.DescontoPercentual,
                AcrescimoPercentual = DtoEdicao.AcrescimoPercentual,
                MultaPercentual = DtoEdicao.MultaPercentual,
                TaxaJurosPercentual = DtoEdicao.TaxaJurosPercentual,
                Ativo = DtoEdicao.Ativo
            };
            _parcelasTexto = DtoEdicao.NumeroParcelas.ToString();
            _campos[0].Texto = DtoEdicao.EntradaMinimaPercentual > 0 ? DtoEdicao.EntradaMinimaPercentual.ToString("N2") : "";
            _campos[1].Texto = DtoEdicao.DescontoPercentual > 0 ? DtoEdicao.DescontoPercentual.ToString("N2") : "";
            _campos[2].Texto = DtoEdicao.AcrescimoPercentual > 0 ? DtoEdicao.AcrescimoPercentual.ToString("N2") : "";
            _campos[3].Texto = DtoEdicao.MultaPercentual > 0 ? DtoEdicao.MultaPercentual.ToString("N2") : "";
            _campos[4].Texto = DtoEdicao.TaxaJurosPercentual > 0 ? DtoEdicao.TaxaJurosPercentual.ToString("N2") : "";
        }
    }

    private void OnParcelasAlterado(string? v) { var d = new string((v ?? "").Where(char.IsDigit).ToArray()); _parcelasTexto = d; _dto.NumeroParcelas = int.TryParse(d, out int n) && n >= 1 ? n : 1; }
    private void OnPercentualAlterado(string? v, CampoPercentual campo)
    {
        var f = string.IsNullOrEmpty(v) ? "" : new string(v.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        campo.Texto = f;
        var val = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal d) ? d : 0m;
        switch (campo.Key)
        {
            case "entrada": _dto.EntradaMinimaPercentual = val; break;
            case "desconto": _dto.DescontoPercentual = val; break;
            case "acrescimo": _dto.AcrescimoPercentual = val; break;
            case "multa": _dto.MultaPercentual = val; break;
            case "juros": _dto.TaxaJurosPercentual = val; break;
        }
    }

    private async Task AbrirModalMetodo()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroMetodoPagamento>("Novo Método", opts);
        var result = await dialog.Result;
        if (result is { Canceled: false }) { _metodos = (await MetodoPagamentoService.ObterTodosAtivosAsync()).ToList(); if (result.Data is int id) _dto.MetodoPagamentoId = id; }
    }

    private async Task Salvar()
    {
        if (_dto.MetodoPagamentoId == 0) { Snackbar.Add("Selecione um Método de Pagamento.", Severity.Warning); return; }
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await CondicaoPagamentoService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }
    private void Cancelar() => MudDialog.Cancel();
    private string Cap(string? v) { if (string.IsNullOrEmpty(v)) return v ?? ""; var p = v.Trim().ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries); for (int i = 0; i < p.Length; i++) if (i == 0 || i == p.Length - 1 || !_min.Contains(p[i])) p[i] = char.ToUpper(p[i][0]) + p[i][1..]; return string.Join(" ", p); }
    private static readonly HashSet<string> _min = new(StringComparer.OrdinalIgnoreCase) { "da", "de", "do", "das", "dos", "e", "a", "o", "as", "os", "em", "no", "na", "com", "por", "para", "ao", "aos" };
}

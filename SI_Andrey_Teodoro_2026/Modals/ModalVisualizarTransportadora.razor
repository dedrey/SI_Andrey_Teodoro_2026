@inject ITransportadoraService TransportadoraService

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Info" />
            <MudText Typo="Typo.h6">Detalhes da Transportadora</MudText>
            @if (_dto != null)
            {
                <MudChip T="string" Size="Size.Small" Color="@(_dto.Ativo? Color.Success: Color.Error)">
                    @(_dto.Ativo ? "Ativa" : "Inativa")
                </MudChip>
            }
        </div>
    </TitleContent>
    <DialogContent>
        @if (_carregando)
        {
            <div class="d-flex justify-center pa-8"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /></div>
        }
        else if (_dto == null)
        {
            <MudAlert Severity="Severity.Error">Transportadora não encontrada.</MudAlert>
        }
        else
        {
            <div class="vis-section">
                <div class="vis-section-title">Identificação</div>
                <MudGrid Spacing="3">
                    <MudItem xs="2" sm="1"><div class="vis-field"><span class="vis-label">ID</span><span class="vis-value">@_dto.Id</span></div></MudItem>
                    <MudItem xs="10" sm="5"><div class="vis-field"><span class="vis-label">Razão Social</span><span class="vis-value">@_dto.RazaoSocial</span></div></MudItem>
                    <MudItem xs="12" sm="6"><div class="vis-field"><span class="vis-label">Nome Fantasia</span><span class="vis-value">@(_dto.NomeFantasia ?? "—")</span></div></MudItem>
                    <MudItem xs="12" sm="6"><div class="vis-field"><span class="vis-label">CNPJ</span><span class="vis-value">@FormatCnpj(_dto.Cnpj)</span></div></MudItem>
                    <MudItem xs="12" sm="6"><div class="vis-field"><span class="vis-label">Inscrição Estadual</span><span class="vis-value">@(_dto.InscricaoEstadual ?? "—")</span></div></MudItem>
                </MudGrid>
            </div>

            <div class="vis-section">
                <div class="vis-section-title">Contato</div>
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="4"><div class="vis-field"><span class="vis-label">Telefone</span><span class="vis-value">@(_dto.Telefone ?? "—")</span></div></MudItem>
                    <MudItem xs="12" sm="8"><div class="vis-field"><span class="vis-label">E-mail</span><span class="vis-value">@(_dto.Email ?? "—")</span></div></MudItem>
                </MudGrid>
            </div>

            <div class="vis-section">
                <div class="vis-section-title">Endereço</div>
                <MudGrid Spacing="3">
                    <MudItem xs="12" sm="7"><div class="vis-field"><span class="vis-label">Rua / Logradouro</span><span class="vis-value">@(string.IsNullOrWhiteSpace(_dto.Endereco) ? "—" : _dto.Endereco)</span></div></MudItem>
                    <MudItem xs="12" sm="5"><div class="vis-field"><span class="vis-label">Bairro</span><span class="vis-value">@(string.IsNullOrWhiteSpace(_dto.Bairro) ? "—" : _dto.Bairro)</span></div></MudItem>
                    <MudItem xs="12"><div class="vis-field"><span class="vis-label">Complemento</span><span class="vis-value">@(string.IsNullOrWhiteSpace(_dto.Complemento) ? "—" : _dto.Complemento)</span></div></MudItem>
                </MudGrid>
            </div>

            @if (_dto.AtualizadoEm.HasValue)
            {
                <MudText Style="font-size:0.73rem;color:#bbb;">
                    Atualizado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
                    @if (!string.IsNullOrWhiteSpace(_dto.NomeAtualizadoPor))
                    {
                        <text> por @_dto.NomeAtualizadoPor</text>
                    }
                </MudText>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" OnClick="@(() => MudDialog.Cancel())">Fechar</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .vis-section {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 14px 16px;
        margin-bottom: 12px;
    }

    .vis-section-title {
        font-size: 0.68rem;
        color: #9e9e9e;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .vis-field {
        display: flex;
        flex-direction: column;
    }

    .vis-label {
        font-size: 0.68rem;
        color: #9e9e9e;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 2px;
    }

    .vis-value {
        font-size: 0.92rem;
        font-weight: 500;
        color: #212121;
    }
</style>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int Id { get; set; }

    private TransportadoraDto? _dto;
    private bool _carregando = true;

    protected override async Task OnInitializedAsync()
    {
        _dto = await TransportadoraService.ObterPorIdAsync(Id);
        _carregando = false;
    }

    private static string FormatCnpj(string s)
    {
        var d = new string(s.Where(char.IsDigit).ToArray());
        return d.Length == 14 ? $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..12]}-{d[12..]}" : s;
    }
}

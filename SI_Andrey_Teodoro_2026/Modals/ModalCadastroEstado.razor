@inject IEstadoService EstadoService
@inject IPaisService PaisService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Map" Class="mr-2" />
            Cadastrar Novo Estado
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudSelect T="int" @bind-Value="_dto.PaisId"
                               Label="País" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Required="true" RequiredError="Selecione um país" FullWidth="true">
                        <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                        @foreach (var pais in _paises)
                        {
                            <MudSelectItem T="int" Value="@pais.Id">@pais.NomePais</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="9">
                    <MudTextField Value="@_dto.NomeEstado"
                                  ValueChanged="@((string v) => _dto.NomeEstado = CapPalavras(v))"
                                  Label="Nome do Estado"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="50" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarSoLetras(v, "Estado"))" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudTextField Value="@_dto.Uf"
                                  ValueChanged="@((string v) => _dto.Uf = FiltrarLetrasUpper(v))"
                                  Label="UF"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="2" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarUf(v))" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int PaisIdInicial { get; set; }

    private EstadoDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;
    private List<PaisListDto> _paises = new();

    protected override async Task OnInitializedAsync()
    {
        _paises = (await PaisService.ObterTodosAtivosAsync()).ToList();
        if (PaisIdInicial > 0) _dto.PaisId = PaisIdInicial;
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await EstadoService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }

    private void Cancelar() => MudDialog.Cancel();

    private string? ValidarSoLetras(string? v, string campo)
    {
        if (string.IsNullOrWhiteSpace(v)) return $"{campo} é obrigatório";
        if (!System.Text.RegularExpressions.Regex.IsMatch(v.Trim(), @"^[a-zA-ZÀ-ÿ\s]+$"))
            return $"{campo} deve conter apenas letras";
        return null;
    }

    private string? ValidarUf(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        if (v.Length != 2) return "UF deve ter exatamente 2 letras";
        if (!System.Text.RegularExpressions.Regex.IsMatch(v, @"^[A-Z]{2}$")) return "UF: 2 letras maiúsculas";
        return null;
    }

    private static readonly HashSet<string> _prep = new(StringComparer.OrdinalIgnoreCase)
    { "da","de","do","das","dos","e","a","o","as","os","em","no","na","of","and","the" };

    private string CapPalavras(string? v)
    {
        if (string.IsNullOrEmpty(v)) return v ?? "";
        var palavras = v.Trim().ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        for (int i = 0; i < palavras.Length; i++)
            if (i == 0 || i == palavras.Length - 1 || !_prep.Contains(palavras[i]))
                palavras[i] = char.ToUpper(palavras[i][0]) + palavras[i][1..];
        return string.Join(" ", palavras);
    }

    private string FiltrarLetrasUpper(string? v)
        => string.IsNullOrEmpty(v) ? "" : new string(v.Where(char.IsLetter).ToArray()).ToUpper();
}

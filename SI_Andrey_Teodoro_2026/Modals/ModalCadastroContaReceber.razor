@inject IContaReceberService ContaReceberService
@inject IClienteService ClienteService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Color="Color.Primary" Class="mr-2" />
            <MudText Typo="Typo.h6">@(_dto.IdOriginal != 0 ? "Editar Conta a Receber" : "Nova Conta a Receber")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_dto.VendaId.HasValue)
        {
            <div style="background:#e3f2fd;border:1px solid #90caf9;border-radius:8px;padding:10px 14px;margin-bottom:14px;">
                <div class="d-flex align-center gap-2">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Info" Size="Size.Small" />
                    <MudText Typo="Typo.body2" Style="color:#1565c0;">
                        Gerada automaticamente pela Venda #@_dto.VendaId
                    </MudText>
                </div>
            </div>
        }

        @if (_dto.IdOriginal != 0 && _contasDaVenda.Count > 1)
        {
            <!-- Venda parcelada: mostra TODAS as parcelas/entrada da mesma venda -->
            <div style="background:#f8f9fa;border-radius:8px;padding:12px 14px;margin-bottom:14px;">
                <div style="font-size:0.68rem;color:#9e9e9e;text-transform:uppercase;letter-spacing:0.5px;font-weight:700;margin-bottom:8px;">
                    Histórico de Pagamentos da Venda
                </div>
                @foreach (var conta in _contasDaVenda)
                {
                    <div class="d-flex align-center justify-space-between" style="padding:6px 0;border-bottom:1px solid #eee;">
                        <div style="flex:1;">
                            <span style="font-size:0.85rem;font-weight:@(conta.Id == _dto.IdOriginal ? "700" : "500");color:@(conta.Id == _dto.IdOriginal ? "#1565c0" : "#555");">
                                @conta.Descricao
                            </span>
                            <div style="font-size:0.72rem;color:#aaa;">Venc. @conta.DataVencimento.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div style="text-align:right;">
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(conta.Status == "RECEBIDA" ? Color.Success : conta.Status == "CANCELADA" ? Color.Default : Color.Warning)">
                                @(conta.Status == "RECEBIDA" ? "Recebida" : conta.Status == "CANCELADA" ? "Cancelada" : "Aberta")
                            </MudChip>
                            <div style="font-size:0.8rem;font-weight:600;margin-top:2px;">
                                R$ @conta.ValorOriginal.ToString("N2")
                                @if (conta.ValorRecebido > 0)
                                {
                                    <span style="color:#2e7d32;font-size:0.72rem;"> (recebido R$ @conta.ValorRecebido.ToString("N2"))</span>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (_dto.IdOriginal != 0 && _dto.Baixas.Any())
        {
            <!-- Conta isolada (manual ou sem parcelamento): mostra só o histórico dela -->
            <div style="background:#f8f9fa;border-radius:8px;padding:12px 14px;margin-bottom:14px;">
                <div style="font-size:0.68rem;color:#9e9e9e;text-transform:uppercase;letter-spacing:0.5px;font-weight:700;margin-bottom:8px;">
                    Histórico de Recebimentos
                </div>
                @foreach (var baixa in _dto.Baixas)
                {
                    <div class="d-flex align-center justify-space-between" style="padding:4px 0;border-bottom:1px solid #eee;">
                        <span style="font-size:0.85rem;color:#555;">@baixa.DataRecebimento.ToString("dd/MM/yyyy")</span>
                        <span style="font-size:0.85rem;font-weight:600;color:#2e7d32;">R$ @baixa.ValorRecebido.ToString("N2")</span>
                        @if (!string.IsNullOrWhiteSpace(baixa.ComprovanteArquivo))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.AttachFile" Color="Color.Info" Size="Size.Small"
                                           Href="@baixa.ComprovanteArquivo" Target="_blank" />
                        }
                    </div>
                }
            </div>
        }

        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12">
                    <MudTextField Value="@_dto.Descricao" ValueChanged="@((string v) => _dto.Descricao = Cap(v))" Label="Descrição *"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" Immediate="true"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true"
                                  ReadOnly="@_somenteLeitura"
                                  Placeholder="Ex: Venda à vista, Acerto de dívida..." />
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudAutocomplete T="ClienteListDto"
                                     Value="@(_clientes.FirstOrDefault(c => c.Id == _dto.ClienteId))"
                                     ValueChanged="@((ClienteListDto? c) => _dto.ClienteId = c?.Id ?? 0)"
                                     SearchFunc="@((s, ct) => Task.FromResult(string.IsNullOrEmpty(s) ? _clientes.Take(50) : _clientes.Where(c => c.NomeRazaoSocial.Contains(s, StringComparison.OrdinalIgnoreCase))))"
                                     ToStringFunc="@(c => c?.NomeRazaoSocial ?? "")"
                                     Label="Cliente *"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                                     Required="true" RequiredError="Selecione um cliente"
                                     ResetValueOnEmptyText="true" CoerceText="false"
                                     Disabled="@(_somenteLeitura || _dto.VendaId.HasValue)" />
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudTooltip Text="Novo cliente">
                        <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                       Size="Size.Medium" OnClick="AbrirModalCliente" Disabled="@_somenteLeitura" />
                    </MudTooltip>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudDatePicker @bind-Date="_dataVencimento" @bind-PickerMonth="_mesExibido" Label="Vencimento *"
                                   Variant="Variant.Outlined" Margin="Margin.Dense"
                                   Required="true" RequiredError="Obrigatório" Editable="true"
                                   DateFormat="dd/MM/yyyy" ReadOnly="@_somenteLeitura" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_valorTexto" ValueChanged="@((string v) => OnValorAlterado(v))"
                                  Label="Valor Original *" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" FullWidth="true" Immediate="true"
                                  Adornment="Adornment.Start" AdornmentText="R$"
                                  ReadOnly="@(_somenteLeitura || (_dto.IdOriginal != 0 && _dto.ValorRecebido > 0))"
                                  HelperText="@(_dto.IdOriginal != 0 && _dto.ValorRecebido > 0 ? "Não editável após recebimentos" : null)" />
                </MudItem>

                @if (_dto.IdOriginal != 0)
                {
                    <MudItem xs="12" sm="4">
                        <MudTextField Value="@FormatarStatus(_dto.Status)" Label="Status"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" ReadOnly="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField Value="@($"R$ {_dto.ValorRecebido:N2}")" Label="Já Recebido"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" ReadOnly="true"
                                      Style="@(_dto.ValorRecebido > 0 ? "color:#2e7d32;" : "")" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudTextField Value="@($"R$ {_dto.ValorSaldo:N2}")" Label="Saldo Devido"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" ReadOnly="true"
                                      Style="@(_dto.ValorSaldo > 0 ? "color:#e65100;font-weight:600;" : "")" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudText Typo="Typo.caption" Style="color:#aaa;display:block;text-align:center;">
                            Valor Original (R$ @_dto.ValorOriginal.ToString("N2")) = Já Recebido + Saldo Devido
                        </MudText>
                    </MudItem>
                }
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="Fechar">@(_somenteLeitura ? "Fechar" : "Cancelar")</MudButton>
        @if (!_somenteLeitura)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar"
                       Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save" Style="font-weight:700;min-width:120px;">
                @(_salvando ? "Salvando..." : "SALVAR")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public ContaReceberDto? DtoEdicao { get; set; }

    private MudForm? _form;
    private bool _formValido, _salvando;
    private ContaReceberDto _dto = new();
    private DateTime? _dataVencimento;
    private DateTime? _mesExibido = DateTime.Today;
    private string _valorTexto = "";
    private List<ClienteListDto> _clientes = new();
    private List<ContaReceberResumoVendaDto> _contasDaVenda = new();

    private bool _somenteLeitura => DtoEdicao != null && DtoEdicao.Status != "ABERTA";

    protected override async Task OnInitializedAsync()
    {
        _clientes = (await ClienteService.ObterTodosAtivosAsync()).ToList();

        if (DtoEdicao is not null)
        {
            _dto = new ContaReceberDto
            {
                Id = DtoEdicao.Id,
                IdOriginal = DtoEdicao.IdOriginal,
                ClienteId = DtoEdicao.ClienteId,
                NomeCliente = DtoEdicao.NomeCliente,
                VendaId = DtoEdicao.VendaId,
                Descricao = DtoEdicao.Descricao,
                DataVencimento = DtoEdicao.DataVencimento,
                ValorOriginal = DtoEdicao.ValorOriginal,
                ValorSaldo = DtoEdicao.ValorSaldo,
                Status = DtoEdicao.Status,
                Baixas = DtoEdicao.Baixas
            };
            _dataVencimento = DtoEdicao.DataVencimento;
            _mesExibido = DtoEdicao.DataVencimento;
            _valorTexto = DtoEdicao.ValorOriginal.ToString("N2");

            // Se a conta vem de uma venda, carrega todas as parcelas/entrada dessa mesma venda
            if (DtoEdicao.VendaId.HasValue)
                _contasDaVenda = await ContaReceberService.ObterContasDaVendaAsync(DtoEdicao.VendaId.Value);
        }
    }

    private void OnValorAlterado(string? texto)
    {
        if (string.IsNullOrEmpty(texto)) { _valorTexto = ""; _dto.ValorOriginal = 0; return; }
        var f = new string(texto.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        _valorTexto = f;
        _dto.ValorOriginal = decimal.TryParse(f.Replace(",", "."), System.Globalization.NumberStyles.Any,
                                              System.Globalization.CultureInfo.InvariantCulture, out decimal d) ? d : 0;
    }

    private static string FormatarStatus(string status) => status switch
    {
        "RECEBIDA" => "Recebida",
        "CANCELADA" => "Cancelada",
        _ => "Aberta"
    };

    private async Task AbrirModalCliente()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroCliente>("Novo Cliente", opts);
        var result = await dialog.Result;
        if (result is { Canceled: false })
        {
            _clientes = (await ClienteService.ObterTodosAtivosAsync()).ToList();
            if (result.Data is int novoId)
                _dto.ClienteId = novoId;
        }
    }

    private async Task Salvar()
    {
        await _form!.Validate();
        if (!_formValido) return;
        if (_dto.ClienteId <= 0) { Snackbar.Add("Selecione um cliente.", Severity.Warning); return; }
        if (_dto.ValorOriginal <= 0) { Snackbar.Add("Informe um valor maior que zero.", Severity.Warning); return; }
        if (!_dataVencimento.HasValue) { Snackbar.Add("Informe a data de vencimento.", Severity.Warning); return; }

        _dto.DataVencimento = _dataVencimento.Value;
        _salvando = true;
        var (sucesso, mensagem, _) = await ContaReceberService.SalvarAsync(_dto);
        _salvando = false;
        Snackbar.Add(mensagem, sucesso ? Severity.Success : Severity.Error);
        if (sucesso) MudDialog.Close(DialogResult.Ok(true));
    }

    private void Fechar() => MudDialog.Cancel();

    private static string Cap(string? s) => string.IsNullOrWhiteSpace(s) ? s ?? "" : s.Trim().ToUpper();
}

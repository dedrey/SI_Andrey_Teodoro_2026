@inject ISnackbar Snackbar
@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color:#c62828;">
            <MudIcon Icon="@Icons.Material.Filled.Cancel" Class="mr-2" />
            Cancelar Venda #@VendaId
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3" Style="color:#666;">
            @if (EraFinalizada)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                    Esta venda já foi <strong>finalizada</strong>. O estoque será estornado automaticamente.
                </MudAlert>
            }
            Informe o motivo do cancelamento. Este registro ficará salvo para auditoria.
        </MudText>
        <MudTextField @bind-Value="Motivo"
                      Label="Motivo do cancelamento"
                      Variant="Variant.Outlined"
                      Lines="3"
                      MaxLength="255"
                      FullWidth="true"
                      Counter="255"
                      Immediate="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text">Voltar</MudButton>
        <MudButton OnClick="Confirmar" Color="Color.Error" Variant="Variant.Filled"
                   Disabled="@(string.IsNullOrWhiteSpace(Motivo))"
                   StartIcon="@Icons.Material.Filled.Cancel">
            Confirmar Cancelamento
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int VendaId { get; set; }
    [Parameter] public bool EraFinalizada { get; set; }

    public string Motivo { get; set; } = "";

    private void Confirmar()
    {
        if (string.IsNullOrWhiteSpace(Motivo))
        {
            Snackbar.Add("Informe o motivo do cancelamento.", Severity.Warning);
            return;
        }
        MudDialog.Close(DialogResult.Ok(Motivo.Trim()));
    }

    private void Cancelar() => MudDialog.Cancel();
}

@inject IPaisService PaisService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Public" Class="mr-2" />
            Cadastrar Novo País
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="8">
                    <MudTextField Value="@_dto.NomePais"
                                  ValueChanged="@((string v) => _dto.NomePais = CapitalizarPrimeira(v))"
                                  Label="Nome do País"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="60" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarNome(v, "País"))" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.Sigla"
                                  ValueChanged="@((string v) => _dto.Sigla = FiltrarLetrasUpper(v))"
                                  Label="Sigla"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="3" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarSigla(v))" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.Ddi"
                                  ValueChanged="@((string v) => _dto.Ddi = FiltrarNumeros(v))"
                                  Label="DDI"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="3" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarDdi(v))" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.Moeda"
                                  ValueChanged="@((string v) => _dto.Moeda = CapitalizarPrimeira(v))"
                                  Label="Moeda"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="30" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarNome(v, "Moeda"))" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.SimboleMoeda"
                                  ValueChanged="@((string v) => _dto.SimboleMoeda = v.ToUpper())"
                                  Label="Símbolo"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="5" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarSimbolo(v))" />
                </MudItem>

            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private PaisDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await PaisService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }

    private void Cancelar() => MudDialog.Cancel();
    private string? ValidarNome(string? v, string campo)
    {
        if (string.IsNullOrWhiteSpace(v)) return $"{campo} é obrigatório";
        if (!System.Text.RegularExpressions.Regex.IsMatch(v.Trim(), @"^[a-zA-ZÀ-ÿ\s]+$"))
            return $"{campo} deve conter apenas letras";
        if (!char.IsUpper(v.TrimStart()[0]))
            return $"{campo} deve começar com letra maiúscula";
        return null;
    }

    private string? ValidarSigla(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        if (!System.Text.RegularExpressions.Regex.IsMatch(v, @"^[A-Z]{1,3}$"))
            return "Sigla: 1 a 3 letras maiúsculas";
        return null;
    }

    private string? ValidarDdi(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        if (!int.TryParse(v, out int n) || n < 1 || n > 999)
            return "DDI: número entre 1 e 999";
        return null;
    }

    private string? ValidarSimbolo(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        if (v.Length < 1) return "Símbolo é obrigatório";
        return null;
    }
    private string CapitalizarPrimeira(string? v)
    {
        if (string.IsNullOrEmpty(v)) return v ?? "";
        return char.ToUpper(v[0]) + v[1..];
    }
    private string FiltrarLetrasUpper(string? v)
        => string.IsNullOrEmpty(v) ? "" : new string(v.Where(char.IsLetter).ToArray()).ToUpper();
    private string FiltrarNumeros(string? v)
        => string.IsNullOrEmpty(v) ? "" : new string(v.Where(char.IsDigit).ToArray());
}

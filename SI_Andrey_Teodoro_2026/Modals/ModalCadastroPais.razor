@inject IPaisService PaisService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Public" Class="mr-2" />
            @(_dto.IdOriginal == 0 ? "Cadastrar Novo País" : "Editar País")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="8">
                    <MudTextField Value="@_dto.NomePais" ValueChanged="@((string v) => _dto.NomePais = CapPalavras(v))"
                                  Label="Nome do País" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="60" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarNome(v, "País"))" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.Sigla" ValueChanged="@((string v) => _dto.Sigla = new string(v.Where(char.IsLetter).ToArray()).ToUpper())"
                                  Label="Sigla" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="3" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => !System.Text.RegularExpressions.Regex.IsMatch(v ?? "", @"^[A-Z]{1,3}$") ? "1-3 letras maiúsculas" : null)" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.Ddi" ValueChanged="@((string v) => _dto.Ddi = new string(v.Where(char.IsDigit).ToArray()))"
                                  Label="DDI" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="3" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => !int.TryParse(v, out int n) || n < 1 || n > 999 ? "DDI: 1 a 999" : null)" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.Moeda" ValueChanged="@((string v) => _dto.Moeda = CapPalavras(v))"
                                  Label="Moeda" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="30" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarNome(v, "Moeda"))" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.SimboleMoeda" ValueChanged="@((string v) => _dto.SimboleMoeda = v.ToUpper())"
                                  Label="Símbolo" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="5" FullWidth="true" Immediate="true" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                   Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public PaisDto? DtoEdicao { get; set; }

    private PaisDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido, _salvando;

    protected override Task OnInitializedAsync()
    {
        if (DtoEdicao is not null)
            _dto = new PaisDto
            {
                Id = DtoEdicao.Id,
                IdOriginal = DtoEdicao.IdOriginal,
                Ddi = DtoEdicao.Ddi,
                Sigla = DtoEdicao.Sigla,
                Moeda = DtoEdicao.Moeda,
                SimboleMoeda = DtoEdicao.SimboleMoeda,
                NomePais = DtoEdicao.NomePais,
                Ativo = DtoEdicao.Ativo
            };
        return base.OnInitializedAsync();
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await PaisService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }
    private void Cancelar() => MudDialog.Cancel();
    private string? ValidarNome(string? v, string campo) { if (string.IsNullOrWhiteSpace(v)) return $"{campo} obrigatório"; if (!System.Text.RegularExpressions.Regex.IsMatch(v.Trim(), @"^[a-zA-ZÀ-ÿ\s]+$")) return "Apenas letras"; return null; }
    private string CapPalavras(string? v) { if (string.IsNullOrEmpty(v)) return v ?? ""; var p = v.Trim().ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries); for (int i = 0; i < p.Length; i++) if (i == 0 || i == p.Length - 1 || !_prep.Contains(p[i])) p[i] = char.ToUpper(p[i][0]) + p[i][1..]; return string.Join(" ", p); }
    private static readonly HashSet<string> _prep = new(StringComparer.OrdinalIgnoreCase) { "da", "de", "do", "das", "dos", "e", "a", "o", "as", "os", "em", "no", "na", "of", "and", "the" };
}

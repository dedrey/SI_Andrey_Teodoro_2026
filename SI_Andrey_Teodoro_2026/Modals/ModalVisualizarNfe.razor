@inject INfeService NfeService
@inject IContaReceberService ContaReceberService
@inject NavigationManager Nav

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Info" />
            <MudText Typo="Typo.h6">Nota Fiscal @(_nfe != null ? $"Nº {_nfe.Numero:D6}" : "")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_carregando)
        {
            <div class="d-flex justify-center pa-8"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /></div>
        }
        else if (_nfe == null)
        {
            <MudAlert Severity="Severity.Error">Nota Fiscal não encontrada.</MudAlert>
        }
        else
        {
            <NfeInvoiceView Nfe="_nfe" Parcelas="_parcelas" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Outlined" OnClick="@(() => MudDialog.Cancel())">Fechar</MudButton>
        @if (_nfe != null)
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Print"
                       OnClick="AbrirPaginaImpressao" Style="font-weight:700;">
                Imprimir
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int Id { get; set; }

    private NfeDto? _nfe;
    private List<ContaReceberResumoVendaDto> _parcelas = new();
    private bool _carregando = true;

    protected override async Task OnInitializedAsync()
    {
        _nfe = await NfeService.ObterPorIdAsync(Id);
        if (_nfe?.VendaId != null)
            _parcelas = await ContaReceberService.ObterContasDaVendaAsync(_nfe.VendaId.Value);
        _carregando = false;
    }
    private void AbrirPaginaImpressao()
    {
        Nav.NavigateTo($"/notas-fiscais/imprimir/{Id}", forceLoad: true);
    }
}

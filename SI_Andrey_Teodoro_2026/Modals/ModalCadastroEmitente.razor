@inject IEmitenteService EmitenteService
@inject ICidadeService CidadeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-2" />
            @(_readOnly ? "Detalhes do Emitente" : _dto.IdOriginal == 0 ? "Cadastrar Novo Emitente" : "Editar Emitente")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.NomeRazaoSocial" ValueChanged="@((string v) => _dto.NomeRazaoSocial = Cap(v))"
                                  Label="Razão Social" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.ApelidoNomeFantasia" ValueChanged="@((string v) => _dto.ApelidoNomeFantasia = Cap(v))"
                                  Label="Nome Fantasia" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="5">
                    <MudTextField Value="@_dto.Cnpj" ValueChanged="@((string v) => _dto.Cnpj = MascaraCnpj(v))"
                                  Label="CNPJ" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="18" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => new string(v?.Where(char.IsDigit).ToArray() ?? Array.Empty<char>()).Length != 14 ? "14 dígitos" : null)" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.InscricaoEstadual" ValueChanged="@((string v) => _dto.InscricaoEstadual = Cap(v))" Label="Inscrição Estadual"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="20" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="string" @bind-Value="_dto.RegimeTributario" Label="Regime Tributário"
                               Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Disabled="@_readOnly">
                        <MudSelectItem T="string" Value="@("SIMPLES")">Simples Nacional</MudSelectItem>
                        <MudSelectItem T="string" Value="@("PRESUMIDO")">Lucro Presumido</MudSelectItem>
                        <MudSelectItem T="string" Value="@("REAL")">Lucro Real</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="10" sm="5">
                    <MudAutocomplete T="CidadeListDto" Label="Cidade"
                                     Value="_cidadeSelecionada"
                                     ValueChanged="@((CidadeListDto? c) => { _cidadeSelecionada = c; _dto.CidadeId = c?.Id; })"
                                     SearchFunc="PesquisarCidade"
                                     ToStringFunc="@(c => c == null ? "" : $"{c.NomeCidade} ({c.Uf})")"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                                     Required="true" RequiredError="Obrigatório"
                                     Clearable="true" ResetValueOnEmptyText="true" CoerceText="false" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Medium" OnClick="AbrirModalCidade" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField Value="@_dto.Endereco" ValueChanged="@((string v) => _dto.Endereco = Cap(v))"
                                  Label="Endereço" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="50" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudTextField Value="@_dto.Numero" ValueChanged="@((string v) => _dto.Numero = Cap(v))"
                                  Label="Número" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="10" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudTextField Value="@_dto.Bairro" ValueChanged="@((string v) => _dto.Bairro = Cap(v))"
                                  Label="Bairro" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="50" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudTextField Value="@_dto.Complemento" ValueChanged="@((string? v) => _dto.Complemento = Cap(v))"
                                  Label="Complemento" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="50" FullWidth="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Telefone" ValueChanged="@((string v) => _dto.Telefone = MascaraTel(v))"
                                  Label="Telefone" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="15" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => { var d = new string(v?.Where(char.IsDigit).ToArray() ?? Array.Empty<char>()); return d.Length switch { 10 => null, 11 => null, < 10 => "Incompleto", _ => "Máx 11" }; })" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Email" ValueChanged="@((string v) => _dto.Email = Cap(v))" Label="E-mail"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="50" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarEmail(v))"
                                  InputType="InputType.Email" Disabled="@_readOnly" />
                </MudItem>
            </MudGrid>
        </MudForm>
        @if (_dto.AtualizadoEm.HasValue)
        {
            <MudText Style="font-size:0.75rem;color:#999;text-align:right;display:block;margin-top:8px;">
                Alterado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
                @if (!string.IsNullOrWhiteSpace(_dto.NomeAtualizadoPor))
                {
                    <text> por @_dto.NomeAtualizadoPor</text>
                }
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        @if (_readOnly)
        {
            <MudButton OnClick="Cancelar" Variant="Variant.Text">Fechar</MudButton>
            <MudButton OnClick="@(() => _readOnly = false)" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Edit">
                Editar
            </MudButton>
        }
        else
        {
            <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
            <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                       Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
                @(_salvando ? "Salvando..." : "Salvar")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public EmitenteDto? DtoEdicao { get; set; }
    [Parameter] public bool SomenteLeitura { get; set; } = false;

    private bool _readOnly;
    private EmitenteDto _dto = new() { RegimeTributario = "SIMPLES" };
    private MudForm _form = null!;
    private bool _formValido, _salvando;
    private List<CidadeListDto> _cidades = new();
    private CidadeListDto? _cidadeSelecionada;

    protected override async Task OnInitializedAsync()
    {
        _readOnly = SomenteLeitura;
        _cidades = (await CidadeService.ObterTodosAtivosSemPaginacaoAsync())
            .Where(c => c.NomePais.Equals("Brasil", StringComparison.OrdinalIgnoreCase)).ToList();
        if (DtoEdicao is not null)
        {
            _dto = new EmitenteDto
            {
                Id = DtoEdicao.Id,
                IdOriginal = DtoEdicao.IdOriginal,
                NomeRazaoSocial = DtoEdicao.NomeRazaoSocial,
                ApelidoNomeFantasia = DtoEdicao.ApelidoNomeFantasia,
                Cnpj = DtoEdicao.Cnpj,
                InscricaoEstadual = DtoEdicao.InscricaoEstadual,
                RegimeTributario = DtoEdicao.RegimeTributario,
                CidadeId = DtoEdicao.CidadeId,
                Endereco = DtoEdicao.Endereco ?? "",
                Numero = DtoEdicao.Numero ?? "",
                Complemento = DtoEdicao.Complemento,
                Bairro = DtoEdicao.Bairro ?? "",
                Telefone = MascaraTel(DtoEdicao.Telefone ?? ""),
                Email = DtoEdicao.Email ?? "",
                Ativo = DtoEdicao.Ativo,
                AtualizadoEm = DtoEdicao.AtualizadoEm,
                NomeAtualizadoPor = DtoEdicao.NomeAtualizadoPor
            };
            if (_dto.CidadeId.HasValue) _cidadeSelecionada = _cidades.FirstOrDefault(c => c.Id == _dto.CidadeId);
        }
    }

    private Task<IEnumerable<CidadeListDto>> PesquisarCidade(string? busca, CancellationToken ct)
    {
        var r = string.IsNullOrWhiteSpace(busca) ? _cidades.Take(50)
            : _cidades.Where(c => c.NomeCidade.Contains(busca, StringComparison.OrdinalIgnoreCase) || c.Uf.Contains(busca, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(r);
    }
    private async Task AbrirModalCidade()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroCidade>("Nova Cidade", opts);
        var result = await dialog.Result;
        if (result is { Canceled: false }) { _cidades = (await CidadeService.ObterTodosAtivosSemPaginacaoAsync()).Where(c => c.NomePais.Equals("Brasil", StringComparison.OrdinalIgnoreCase)).ToList(); if (result.Data is int id) { _cidadeSelecionada = _cidades.FirstOrDefault(c => c.Id == id); _dto.CidadeId = id; } }
    }
    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await EmitenteService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }
    private void Cancelar() => MudDialog.Cancel();
    private string MascaraCnpj(string? v) { if (string.IsNullOrEmpty(v)) return ""; var d = new string(v.Where(char.IsDigit).ToArray()); if (d.Length > 14) d = d[..14]; return d.Length switch { 0 => "", <= 2 => d, <= 5 => $"{d[..2]}.{d[2..]}", <= 8 => $"{d[..2]}.{d[2..5]}.{d[5..]}", <= 12 => $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..]}", _ => $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..12]}-{d[12..]}" }; }
    private string MascaraTel(string? v) { if (string.IsNullOrEmpty(v)) return ""; var d = new string(v.Where(char.IsDigit).ToArray()); if (d.Length > 11) d = d[..11]; return d.Length switch { 0 => "", <= 2 => $"({d}", <= 6 => $"({d[..2]}) {d[2..]}", <= 10 => $"({d[..2]}) {d[2..6]}-{d[6..]}", _ => $"({d[..2]}) {d[2..7]}-{d[7..]}" }; }
    private static string? ValidarEmail(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        return System.Text.RegularExpressions.Regex.IsMatch(v, @"^[^@\s]+@[^@\s]+\.[A-Za-z]{2,}$") ? null : "E-mail inválido";
    }
    private static string Cap(string? v) => string.IsNullOrWhiteSpace(v) ? v ?? "" : v.Trim().ToUpper();
}

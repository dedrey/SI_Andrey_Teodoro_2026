@inject IFornecedorService FornecedorService

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Info" />
            <MudText Typo="Typo.h6">Detalhes do Fornecedor</MudText>
            @if (_dto != null)
            {
                <MudChip T="string" Size="Size.Small" Color="@(_dto.Ativo? Color.Success: Color.Error)">
                    @(_dto.Ativo ? "Ativo" : "Inativo")
                </MudChip>
            }
        </div>
    </TitleContent>
    <DialogContent>
        @if (_carregando)
        {
            <div class="d-flex justify-center pa-8"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /></div>
        }
        else if (_dto == null)
        {
            <MudAlert Severity="Severity.Error">Fornecedor não encontrado.</MudAlert>
        }
        else
        {
            <div class="vis-section">
                <div class="vis-section-title">Identificação</div>
                <MudGrid Spacing="3" Justify="Justify.Center">
                    <MudItem xs="2" sm="1"><div class="vis-field"><span class="vis-label">ID</span><span class="vis-value">@_dto.Id</span></div></MudItem>
                    <MudItem xs="10" sm="6"><div class="vis-field"><span class="vis-label">@(_dto.TipoPessoa == "PJ" ? "Razão Social" : "Nome")</span><span class="vis-value" style="font-size:1.05rem;font-weight:700;">@_dto.RazaoSocial</span></div></MudItem>
                    @if (_dto.TipoPessoa == "PJ")
                    {
                        <MudItem xs="12" sm="5"><div class="vis-field"><span class="vis-label">Nome Fantasia</span><span class="vis-value">@(_dto.NomeFantasia ?? "—")</span></div></MudItem>
                    }

                    <MudItem xs="12" sm="3"><div class="vis-field"><span class="vis-label">Tipo</span><span class="vis-value">@(_dto.TipoPessoa == "PF" ? "Pessoa Física" : "Pessoa Jurídica")</span></div></MudItem>
                    <MudItem xs="12" sm="6"><div class="vis-field"><span class="vis-label">@(_dto.TipoPessoa == "PF" ? "CPF" : "CNPJ")</span><span class="vis-value">@_dto.CpfCnpj</span></div></MudItem>
                </MudGrid>
            </div>

            <div class="vis-section">
                <div class="vis-section-title">Contato</div>
                <div class="vis-row">
                    <div class="vis-field"><span class="vis-label">Telefone</span><span class="vis-value">@(_dto.Telefone ?? "—")</span></div>
                    <div class="vis-field"><span class="vis-label">E-mail</span><span class="vis-value">@(_dto.Email ?? "—")</span></div>
                </div>
            </div>

            <div class="vis-section">
                <div class="vis-section-title">Endereço</div>
                <div class="vis-row">
                    <div class="vis-field">
                        <span class="vis-label">Rua / Logradouro</span>
                        <span class="vis-value">@(string.IsNullOrWhiteSpace(_dto.Endereco) ? "—" : _dto.Endereco)</span>
                    </div>
                    <div class="vis-field">
                        <span class="vis-label">Número</span>
                        <span class="vis-value">@(string.IsNullOrWhiteSpace(_dto.Numero) ? "—" : _dto.Numero)</span>
                    </div>
                    <div class="vis-field">
                        <span class="vis-label">Bairro</span>
                        <span class="vis-value">@(string.IsNullOrWhiteSpace(_dto.Bairro) ? "—" : _dto.Bairro)</span>
                    </div>
                    <div class="vis-field">
                        <span class="vis-label">CEP</span>
                        <span class="vis-value">@(string.IsNullOrWhiteSpace(_dto.Cep) ? "—" : _dto.Cep)</span>
                    </div>
                    <div class="vis-field">
                        <span class="vis-label">Cidade</span>
                        <span class="vis-value">@(_dto.NomeCidade ?? "—")</span>
                    </div>
                    <div class="vis-field">
                        <span class="vis-label">Complemento</span>
                        <span class="vis-value">@(string.IsNullOrWhiteSpace(_dto.Complemento) ? "—" : _dto.Complemento)</span>
                    </div>
                </div>
            </div>

            @if (_dto.AtualizadoEm.HasValue)
            {
                <MudText Style="font-size:0.73rem;color:#bbb;text-align:center;display:block;">
                    Atualizado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
                    @if (!string.IsNullOrWhiteSpace(_dto.NomeAtualizadoPor))
                    {
                        <text> por @_dto.NomeAtualizadoPor</text>
                    }
                </MudText>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" OnClick="@(() => MudDialog.Cancel())">Fechar</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .vis-section {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 14px 16px;
        margin-bottom: 12px;
    }

    .vis-section-title {
        font-size: 0.68rem;
        color: #9e9e9e;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        font-weight: 700;
        margin-bottom: 10px;
        text-align: center;
    }

    .vis-field {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        width: 100%;
    }

    .vis-row {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 8px 32px;
    }

        .vis-row .vis-field {
            width: auto;
            min-width: 80px;
            flex: 1 1 auto;
            max-width: 240px;
        }

    .vis-label {
        font-size: 0.68rem;
        color: #9e9e9e;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 2px;
    }

    .vis-value {
        font-size: 0.92rem;
        font-weight: 500;
        color: #212121;
    }
</style>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int Id { get; set; }

    private FornecedorDto? _dto;
    private bool _carregando = true;

    protected override async Task OnInitializedAsync()
    {
        _dto = await FornecedorService.ObterPorIdAsync(Id);
        _carregando = false;
    }

    private static string FormatCnpj(string s)
    {
        var d = new string(s.Where(char.IsDigit).ToArray());
        return d.Length == 14 ? $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..12]}-{d[12..]}" : s;
    }
}

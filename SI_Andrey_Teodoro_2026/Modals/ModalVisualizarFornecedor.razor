@inject IFornecedorService FornecedorService

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Info" Class="mr-2" />
            <MudText Typo="Typo.h6">Detalhes do Fornecedor</MudText>
            @if (_dto != null)
            {
                <MudChip T="string" Size="Size.Small" Color="@(_dto.Ativo? Color.Success: Color.Error)" Class="ml-3">
                    @(_dto.Ativo ? "Ativo" : "Inativo")
                </MudChip>
            }
        </div>
    </TitleContent>
    <DialogContent>
        @if (_carregando)
        {
            <div class="d-flex justify-center pa-6"><MudProgressCircular Indeterminate="true" Color="Color.Primary" /></div>
        }
        else if (_dto == null)
        {
            <MudAlert Severity="Severity.Error">Fornecedor não encontrado.</MudAlert>
        }
        else
        {
            <MudGrid Spacing="2">
                <MudItem xs="12"><MudText Typo="Typo.caption" Class="section-label">Identificação</MudText><MudDivider Class="mb-3 mt-1" /></MudItem>
                <MudItem xs="3" sm="1"><div class="info-field"><span class="info-label">ID</span><span class="info-value">@_dto.Id</span></div></MudItem>
                <MudItem xs="9" sm="5"><div class="info-field"><span class="info-label">Razão Social</span><span class="info-value">@_dto.RazaoSocial</span></div></MudItem>
                <MudItem xs="12" sm="6"><div class="info-field"><span class="info-label">Nome Fantasia</span><span class="info-value">@(_dto.NomeFantasia ?? "—")</span></div></MudItem>
                <MudItem xs="12" sm="6"><div class="info-field"><span class="info-label">CNPJ</span><span class="info-value">@FormatCnpj(_dto.Cnpj)</span></div></MudItem>

                <MudItem xs="12" Class="mt-2"><MudText Typo="Typo.caption" Class="section-label">Contato</MudText><MudDivider Class="mb-3 mt-1" /></MudItem>
                <MudItem xs="12" sm="4"><div class="info-field"><span class="info-label">Telefone</span><span class="info-value">@(_dto.Telefone ?? "—")</span></div></MudItem>
                <MudItem xs="12" sm="8"><div class="info-field"><span class="info-label">E-mail</span><span class="info-value">@(_dto.Email ?? "—")</span></div></MudItem>

                <MudItem xs="12" Class="mt-2"><MudText Typo="Typo.caption" Class="section-label">Endereço</MudText><MudDivider Class="mb-3 mt-1" /></MudItem>
                <MudItem xs="12" sm="7"><div class="info-field"><span class="info-label">Rua / Logradouro</span><span class="info-value">@(string.IsNullOrWhiteSpace(_dto.Endereco) ? "—" : _dto.Endereco)</span></div></MudItem>
                <MudItem xs="12" sm="5"><div class="info-field"><span class="info-label">Bairro</span><span class="info-value">@(string.IsNullOrWhiteSpace(_dto.Bairro) ? "—" : _dto.Bairro)</span></div></MudItem>
                <MudItem xs="12" sm="7"><div class="info-field"><span class="info-label">Complemento</span><span class="info-value">@(string.IsNullOrWhiteSpace(_dto.Complemento) ? "—" : _dto.Complemento)</span></div></MudItem>

                @if (_dto.AtualizadoEm.HasValue)
                {
                    <MudItem xs="12" Class="mt-1">
                        <MudText Style="font-size:0.75rem;color:#bbb;">
                            Atualizado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
                            @if (!string.IsNullOrWhiteSpace(_dto.NomeAtualizadoPor))
                            {
                                <text> por @_dto.NomeAtualizadoPor</text>
                            }
                        </MudText>
                    </MudItem>
                }
            </MudGrid>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Default" OnClick="@(() => MudDialog.Cancel())">Fechar</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .section-label {
        color: #9e9e9e;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-weight: 600;
        font-size: 0.7rem;
    }

    .info-field {
        display: flex;
        flex-direction: column;
        margin-bottom: 4px;
    }

    .info-label {
        font-size: 0.7rem;
        color: #9e9e9e;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 2px;
    }

    .info-value {
        font-size: 0.92rem;
        font-weight: 500;
        color: #212121;
    }
</style>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int Id { get; set; }

    private FornecedorDto? _dto;
    private bool _carregando = true;

    protected override async Task OnInitializedAsync()
    {
        _dto = await FornecedorService.ObterPorIdAsync(Id);
        _carregando = false;
    }

    private static string FormatCnpj(string s)
    {
        var d = new string(s.Where(char.IsDigit).ToArray());
        return d.Length == 14 ? $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..12]}-{d[12..]}" : s;
    }
}

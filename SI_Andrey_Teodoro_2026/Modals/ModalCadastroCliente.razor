@inject IClienteService ClienteService
@inject ICidadeService CidadeService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-2" />
            @(_readOnly ? "Detalhes do Cliente" : _dto.IdOriginal == 0 ? "Cadastrar Novo Cliente" : "Editar Cliente")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid Spacing="2">
                <MudItem xs="6" sm="3">
                    <MudSelect T="string" Value="@_dto.TipoPessoa" ValueChanged="OnTipoPessoaAlterado"
                               Label="Tipo" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Disabled="@_readOnly">
                        <MudSelectItem T="string" Value="@("PF")">Pessoa Física</MudSelectItem>
                        <MudSelectItem T="string" Value="@("PJ")">Pessoa Jurídica</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudSelect T="string" @bind-Value="_dto.Sexo" Label="Sexo"
                               Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" Disabled="@_readOnly">
                        <MudSelectItem T="string" Value="@("MASCULINO")">Masculino</MudSelectItem>
                        <MudSelectItem T="string" Value="@("FEMININO")">Feminino</MudSelectItem>
                        <MudSelectItem T="string" Value="@("OUTRO")">Outro</MudSelectItem>
                        <MudSelectItem T="string" Value="@("NAO_INFORMAR")">Não informar</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6" Class="d-flex align-center">
                    <MudCheckBox T="bool" Value="@_dto.Estrangeiro" ValueChanged="OnEstrangeiroAlterado"
                                 Color="Color.Primary" Label="Estrangeiro" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField Value="@_dto.NomeRazaoSocial" ValueChanged="@((string v) => _dto.NomeRazaoSocial = Cap(v))"
                                  Label="@(_dto.TipoPessoa == "PJ" ? "Razão Social" : "Cliente")"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    @if (_dto.Estrangeiro)
                    {
                        <MudTextField Value="@(_dto.DocumentoEstrangeiro ?? "")"
                                      ValueChanged="@((string v) => _dto.DocumentoEstrangeiro = v.Trim())"
                                      Label="Documento Estrangeiro" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      MaxLength="30" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                    }
                    else
                    {
                        <MudTextField Value="@_docTexto" ValueChanged="@((string v) => OnDocAlterado(v))"
                                      Label="@(_dto.TipoPessoa == "PF" ? "CPF*" : "CNPJ*")"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      MaxLength="@(_dto.TipoPessoa == "PF" ? 14 : 18)" FullWidth="true" Immediate="true"
                                      Validation="@((string v) => ValidarDocumento(v))" Disabled="@_readOnly" />
                    }
                </MudItem>

                @if (_dto.TipoPessoa == "PJ")
                {
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@_dto.ApelidoNomeFantasia" ValueChanged="@((string v) => _dto.ApelidoNomeFantasia = Cap(v))"
                                      Label="Nome Fantasia" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      MaxLength="100" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@_dto.InscricaoEstadual" ValueChanged="@((string v) => _dto.InscricaoEstadual = Cap(v))" Label="Inscrição Estadual/Municipal"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="20" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                    </MudItem>
                }

                <MudItem xs="10" sm="5">
                    <MudAutocomplete T="CidadeListDto" Label="Cidade"
                                     Value="_cidadeSelecionada"
                                     ValueChanged="@((CidadeListDto? c) => { _cidadeSelecionada = c; _dto.CidadeId = c?.Id; })"
                                     SearchFunc="PesquisarCidade"
                                     ToStringFunc="@(c => c == null ? "" : $"{c.NomeCidade} ({c.Uf})")"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                                     Required="true" RequiredError="Obrigatório"
                                     Clearable="true" ResetValueOnEmptyText="true" CoerceText="false" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary" Size="Size.Medium" OnClick="AbrirModalCidade" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Telefone" ValueChanged="@((string v) => _dto.Telefone = MascaraTel(v))"
                                  Label="@(_dto.TipoPessoa == "PJ" ? "Telefone" : "Celular")" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="15" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarTel(v))" Disabled="@_readOnly" />
                </MudItem>
                @if (_dto.TipoPessoa == "PJ")
                {
                    <MudItem xs="12" sm="6">
                        <MudTextField Value="@(_dto.Celular ?? "")" ValueChanged="@((string v) => _dto.Celular = MascaraTel(v))"
                                      Label="Celular" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Required="true" RequiredError="Obrigatório" MaxLength="15" FullWidth="true" Immediate="true"
                                      Validation="@((string v) => ValidarTel(v))" Disabled="@_readOnly" />
                    </MudItem>
                }
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Email" ValueChanged="@((string v) => _dto.Email = Cap(v))" Label="E-mail"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarEmail(v))"
                                  InputType="InputType.Email" Disabled="@_readOnly" />
                </MudItem>

                <MudItem xs="12"><MudDivider /><MudText Typo="Typo.caption" Style="color:#888;text-transform:uppercase;letter-spacing:1px;font-weight:600;">Endereço</MudText></MudItem>

                <MudItem xs="12" sm="5">
                    <MudTextField Value="@_dto.Endereco" ValueChanged="@((string v) => _dto.Endereco = Cap(v))"
                                  Label="Rua" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Obrigatório"
                                  MaxLength="100" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudTextField Value="@_dto.Numero" ValueChanged="@((string v) => _dto.Numero = Cap(v))"
                                  Label="Número" Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="10" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="5">
                    <MudTextField Value="@_dto.Bairro" ValueChanged="@((string v) => _dto.Bairro = Cap(v))"
                                  Label="Bairro" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Obrigatório"
                                  MaxLength="60" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Complemento" ValueChanged="@((string v) => _dto.Complemento = Cap(v))"
                                  Label="Complemento" Required="true" RequiredError="Obrigatório"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="50" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Value="@_dto.Cep" ValueChanged="@((string v) => _dto.Cep = MascaraCep(v))"
                                  Label="CEP" Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Obrigatório"
                                  MaxLength="9" FullWidth="true" Immediate="true" Disabled="@_readOnly" />
                </MudItem>

                <MudItem xs="12"><MudDivider /><MudText Typo="Typo.caption" Style="color:#888;text-transform:uppercase;letter-spacing:1px;font-weight:600;">Financeiro</MudText></MudItem>

                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_dto.LimiteCredito" Label="Limite de Crédito"
                                     Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                                     Format="N2" Culture="@_culturaBr" Min="0" Adornment="Adornment.Start" AdornmentText="R$" Disabled="@_readOnly" />
                </MudItem>


            </MudGrid>
        </MudForm>
        @if (_dto.AtualizadoEm.HasValue)
        {
            <MudText Style="font-size:0.75rem;color:#999;text-align:right;display:block;margin-top:8px;">
                Alterado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
                @if (!string.IsNullOrWhiteSpace(_dto.NomeAtualizadoPor))
                {
                    <text> por @_dto.NomeAtualizadoPor</text>
                }
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        @if (_readOnly)
        {
            <MudButton OnClick="Cancelar" Variant="Variant.Text">Fechar</MudButton>
            <MudButton OnClick="@(() => _readOnly = false)" Color="Color.Primary" Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Edit">
                Editar
            </MudButton>
        }
        else
        {
            <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
            <MudButton OnClick="Salvar" Color="Color.Primary" Variant="Variant.Filled"
                       Disabled="_salvando" StartIcon="@Icons.Material.Filled.Save">
                @(_salvando ? "Salvando..." : "Salvar")
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public ClienteDto? DtoEdicao { get; set; }
    [Parameter] public bool SomenteLeitura { get; set; } = false;

    private bool _readOnly;
    private ClienteDto _dto = new() { TipoPessoa = "PF", Sexo = "NAO_INFORMAR" };
    private MudForm _form = null!;
    private bool _formValido, _salvando;
    private string _docTexto = "";
    private List<CidadeListDto> _cidades = new();
    private CidadeListDto? _cidadeSelecionada;
    private readonly System.Globalization.CultureInfo _culturaBr = new("pt-BR");

    protected override async Task OnInitializedAsync()
    {
        _readOnly = SomenteLeitura;
        _cidades = (await CidadeService.ObterTodosAtivosSemPaginacaoAsync()).ToList();
        if (DtoEdicao is not null)
        {
            _dto = new ClienteDto
            {
                Id = DtoEdicao.Id,
                IdOriginal = DtoEdicao.IdOriginal,
                TipoPessoa = DtoEdicao.TipoPessoa,
                Sexo = string.IsNullOrWhiteSpace(DtoEdicao.Sexo) ? "NAO_INFORMAR" : DtoEdicao.Sexo,
                Estrangeiro = DtoEdicao.Estrangeiro,
                NomeRazaoSocial = DtoEdicao.NomeRazaoSocial,
                ApelidoNomeFantasia = DtoEdicao.ApelidoNomeFantasia,
                CpfCnpj = DtoEdicao.CpfCnpj,
                DocumentoEstrangeiro = DtoEdicao.DocumentoEstrangeiro,
                CidadeId = DtoEdicao.CidadeId,
                Endereco = DtoEdicao.Endereco,
                Numero = DtoEdicao.Numero,
                Complemento = DtoEdicao.Complemento,
                Bairro = DtoEdicao.Bairro,
                Cep = DtoEdicao.Cep,
                Telefone = MascaraTel(DtoEdicao.Telefone ?? ""),
                Celular = string.IsNullOrWhiteSpace(DtoEdicao.Celular) ? null : MascaraTel(DtoEdicao.Celular),
                Email = DtoEdicao.Email ?? "",
                InscricaoEstadual = DtoEdicao.InscricaoEstadual,
                InscricaoMunicipal = DtoEdicao.InscricaoMunicipal,
                LimiteCredito = DtoEdicao.LimiteCredito,
                Ativo = DtoEdicao.Ativo,
                AtualizadoEm = DtoEdicao.AtualizadoEm,
                NomeAtualizadoPor = DtoEdicao.NomeAtualizadoPor
            };
            _docTexto = DtoEdicao.CpfCnpj ?? "";

            if (_dto.CidadeId.HasValue) _cidadeSelecionada = _cidades.FirstOrDefault(c => c.Id == _dto.CidadeId);
        }
    }

    private void OnTipoPessoaAlterado(string tipo) { _dto.TipoPessoa = tipo; _docTexto = ""; _dto.CpfCnpj = ""; if (tipo == "PF") _dto.Celular = null; }
    private void OnEstrangeiroAlterado(bool v) { _dto.Estrangeiro = v; _dto.CidadeId = null; _dto.DocumentoEstrangeiro = null; _docTexto = ""; _dto.CpfCnpj = null; }
    private void OnDocAlterado(string? v) { if (string.IsNullOrEmpty(v)) { _docTexto = ""; _dto.CpfCnpj = ""; return; } var limpo = new string(v.Where(char.IsDigit).ToArray()); _docTexto = _dto.TipoPessoa == "PF" ? FormatarCpf(limpo) : FormatarCnpj(limpo); _dto.CpfCnpj = limpo; }


    private Task<IEnumerable<CidadeListDto>> PesquisarCidade(string? busca, CancellationToken ct)
    {
        var fonte = _dto.Estrangeiro ? _cidades : _cidades.Where(c => c.NomePais.Equals("Brasil", StringComparison.OrdinalIgnoreCase));
        var r = string.IsNullOrWhiteSpace(busca) ? fonte.Take(50) : fonte.Where(c => c.NomeCidade.Contains(busca, StringComparison.OrdinalIgnoreCase) || c.Uf.Contains(busca, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(r);
    }

    private async Task AbrirModalCidade()
    {
        var opts = new DialogOptions { CloseOnEscapeKey = true, BackdropClick = false, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ModalCadastroCidade>("Nova Cidade", opts);
        var result = await dialog.Result;
        if (result is { Canceled: false }) { _cidades = (await CidadeService.ObterTodosAtivosSemPaginacaoAsync()).ToList(); if (result.Data is int id) { _cidadeSelecionada = _cidades.FirstOrDefault(c => c.Id == id); _dto.CidadeId = id; } }
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;
        _salvando = true;
        var (sucesso, mensagem, id) = await ClienteService.SalvarAsync(_dto);
        _salvando = false;
        if (sucesso) { Snackbar.Add(mensagem, Severity.Success); MudDialog.Close(DialogResult.Ok(id)); }
        else Snackbar.Add(mensagem, Severity.Error);
    }
    private void Cancelar() => MudDialog.Cancel();

    private string? ValidarDocumento(string? v) { if (string.IsNullOrWhiteSpace(v)) return "Obrigatório"; var d = new string(v.Where(char.IsDigit).ToArray()); if (_dto.TipoPessoa == "PF" && d.Length != 11) return "CPF deve ter 11 dígitos"; if (_dto.TipoPessoa == "PJ" && d.Length != 14) return "CNPJ deve ter 14 dígitos"; return null; }
    private string? ValidarTel(string? v) { if (string.IsNullOrWhiteSpace(v)) return "Obrigatório"; var d = new string(v.Where(char.IsDigit).ToArray()); return d.Length switch { 10 => null, 11 => null, < 10 => "Incompleto", _ => "Máx 11 dígitos" }; }
    private static string FormatarCpf(string d) { if (d.Length >= 11) d = d[..11]; return d.Length == 11 ? $"{d[..3]}.{d[3..6]}.{d[6..9]}-{d[9..]}" : d; }
    private static string FormatarCnpj(string d) { if (d.Length >= 14) d = d[..14]; return d.Length == 14 ? $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..12]}-{d[12..]}" : d; }
    private string MascaraTel(string? v) { if (string.IsNullOrEmpty(v)) return ""; var d = new string(v.Where(char.IsDigit).ToArray()); if (d.Length > 11) d = d[..11]; return d.Length switch { 0 => "", <= 2 => $"({d}", <= 6 => $"({d[..2]}) {d[2..]}", <= 10 => $"({d[..2]}) {d[2..6]}-{d[6..]}", _ => $"({d[..2]}) {d[2..7]}-{d[7..]}" }; }
    private string MascaraCep(string? v)
    {
        if (string.IsNullOrEmpty(v)) return "";
        var d = new string(v.Where(char.IsDigit).ToArray());
        if (d.Length > 8) d = d[..8];
        return d.Length <= 5 ? d : $"{d[..5]}-{d[5..]}";
    }
    private static string? ValidarEmail(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        return System.Text.RegularExpressions.Regex.IsMatch(v, @"^[^@\s]+@[^@\s]+\.[A-Za-z]{2,}$") ? null : "E-mail inválido";
    }
    private static string Cap(string? v) => string.IsNullOrWhiteSpace(v) ? v ?? "" : v.Trim().ToUpper();

}

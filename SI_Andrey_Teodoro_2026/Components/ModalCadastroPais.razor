@inject IPaisService PaisService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Public" Class="mr-2" />
            Cadastrar Novo País
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid>
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="_dto.NomePais"
                                  Label="Nome do País *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Nome é obrigatório"
                                  MaxLength="100"
                                  FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_dto.Sigla"
                                  Label="Sigla *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  MaxLength="10"
                                  FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_dto.Ddi"
                                  Label="DDI *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  MaxLength="10"
                                  FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_dto.Moeda"
                                  Label="Moeda *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  MaxLength="50"
                                  FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_dto.SimboleMoeda"
                                  Label="Símbolo *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  MaxLength="10"
                                  FullWidth="true" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">
            Cancelar
        </MudButton>
        <MudButton OnClick="Salvar"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="_salvando"
                   StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private PaisDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;

        _salvando = true;
        var (sucesso, mensagem, id) = await PaisService.SalvarAsync(_dto);
        _salvando = false;

        if (sucesso)
        {
            Snackbar.Add(mensagem, Severity.Success);
            MudDialog.Close(DialogResult.Ok(id));
        }
        else
        {
            Snackbar.Add(mensagem, Severity.Error);
        }
    }

    private void Cancelar() => MudDialog.Cancel();
}
@inject IEstadoService EstadoService
@inject IPaisService PaisService
@inject ISnackbar Snackbar
@using SI_Andrey_Teodoro_2026.DTOs
@using SI_Andrey_Teodoro_2026.Services.Interfaces

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Map" Class="mr-2" />
            Cadastrar Novo Estado
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="_formValido">
            <MudGrid>
                <MudItem xs="12">
                    <MudSelect T="int" @bind-Value="_dto.PaisId"
                               Label="País *"
                               Variant="Variant.Outlined"
                               Required="true"
                               RequiredError="País é obrigatório"
                               FullWidth="true">
                        @foreach (var pais in _paises)
                        {
                            <MudSelectItem T="int" Value="@pais.Id">@pais.NomePais</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="9">
                    <MudTextField @bind-Value="_dto.NomeEstado"
                                  Label="Nome do Estado *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  MaxLength="100"
                                  FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudTextField @bind-Value="_dto.Uf"
                                  Label="UF *"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  MaxLength="2"
                                  FullWidth="true" />
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" Variant="Variant.Text" Disabled="_salvando">Cancelar</MudButton>
        <MudButton OnClick="Salvar"
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="_salvando"
                   StartIcon="@Icons.Material.Filled.Save">
            @(_salvando ? "Salvando..." : "Salvar")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int PaisIdInicial { get; set; }

    private EstadoDto _dto = new();
    private MudForm _form = null!;
    private bool _formValido;
    private bool _salvando;
    private List<PaisListDto> _paises = new();

    protected override async Task OnInitializedAsync()
    {
        _paises = (await PaisService.ObterTodosAtivosAsync()).ToList();
        if (PaisIdInicial > 0) _dto.PaisId = PaisIdInicial;
    }

    private async Task Salvar()
    {
        await _form.Validate();
        if (!_formValido) return;

        _salvando = true;
        var (sucesso, mensagem, id) = await EstadoService.SalvarAsync(_dto);
        _salvando = false;

        if (sucesso)
        {
            Snackbar.Add(mensagem, Severity.Success);
            MudDialog.Close(DialogResult.Ok(new { id, paisId = _dto.PaisId }));
        }
        else
        {
            Snackbar.Add(mensagem, Severity.Error);
        }
    }

    private void Cancelar() => MudDialog.Cancel();
}
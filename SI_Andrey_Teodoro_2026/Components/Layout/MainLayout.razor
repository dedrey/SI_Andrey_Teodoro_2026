@inherits LayoutComponentBase


<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Primary" Dense="false">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudText Typo="Typo.h6" Class="ml-2" Style="font-weight:700;letter-spacing:0.5px;">Sistema</MudText>
        <MudSpacer />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="1"
               Variant="@DrawerVariant.Responsive" ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader>
            <MudText Typo="Typo.subtitle2" Style="font-weight:600;color:#555;">Menu</MudText>
        </MudDrawerHeader>

        <MudNavMenu Rounded="true" Margin="Margin.Dense" Color="Color.Primary" Class="pa-2">

            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">Início</MudNavLink>

            <MudNavGroup Title="Localização" Icon="@Icons.Material.Filled.LocationOn" Expanded="false">
                <MudNavLink Href="/paises" Icon="@Icons.Material.Filled.Flag">Países</MudNavLink>
                <MudNavLink Href="/estados" Icon="@Icons.Material.Filled.Map">Estados</MudNavLink>
                <MudNavLink Href="/cidades" Icon="@Icons.Material.Filled.LocationCity">Cidades</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Pessoas" Icon="@Icons.Material.Filled.PeopleAlt" Expanded="false">
                <MudNavLink Href="/clientes" Icon="@Icons.Material.Filled.Person">Clientes</MudNavLink>
                <MudNavLink Href="/emitentes" Icon="@Icons.Material.Filled.Business">Emitentes</MudNavLink> 
                <MudNavLink Href="/fornecedores" Icon="@Icons.Material.Filled.LocalShipping">Fornecedores</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Transportes" Icon="@Icons.Material.Filled.FireTruck" Expanded="false">
                <MudNavLink Href="/transportadoras" Icon="@Icons.Material.Filled.LocalShipping">Transportadoras</MudNavLink>
                <MudNavLink Href="/veiculos" Icon="@Icons.Material.Filled.DirectionsCar">Veículos</MudNavLink>
            </MudNavGroup>

            @*<MudNavLink Href="/usuarios" Icon="@Icons.Material.Filled.ManageAccounts">Usuários</MudNavLink>*@

            <MudNavGroup Title="Cadastros Base" Icon="@Icons.Material.Filled.Tune" Expanded="false">
                <MudNavLink Href="/categorias" Icon="@Icons.Material.Filled.Category">Categorias</MudNavLink>
                <MudNavLink Href="/marcas" Icon="@Icons.Material.Filled.Style">Marcas</MudNavLink>
                <MudNavLink Href="/unidades-medida" Icon="@Icons.Material.Filled.Straighten">Unidades de Medida</MudNavLink>
            </MudNavGroup>

            <MudNavGroup Title="Financeiro" Icon="@Icons.Material.Filled.AccountBalance" Expanded="false">
                <MudNavLink Href="/metodos-pagamento" Icon="@Icons.Material.Filled.Payment">Métodos de Pagamento</MudNavLink>
                <MudNavLink Href="/condicoes-pagamento" Icon="@Icons.Material.Filled.RequestQuote">Condições de Pagamento</MudNavLink>
                <MudNavLink Href="/contas-pagar" Icon="@Icons.Material.Filled.Payments">Contas a Pagar</MudNavLink>
                <MudNavLink Href="/contas-receber" Icon="@Icons.Material.Filled.RequestQuote">Contas a Receber</MudNavLink>
            </MudNavGroup>
            <MudNavGroup Title="Estoque" Icon="@Icons.Material.Filled.Inventory" Expanded="false">
                <MudNavLink Href="/produtos" Icon="@Icons.Material.Filled.Inventory2">Produtos</MudNavLink>
                <MudNavLink Href="/movimentacoes-estoque" Icon="@Icons.Material.Filled.SwapVert">Movimentações</MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="/vendas" Icon="@Icons.Material.Filled.ShoppingCart">Vendas</MudNavLink>
            <MudNavLink Href="/notas-fiscais" Icon="@Icons.Material.Filled.Description">Notas Fiscais</MudNavLink>

        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4">@Body</MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private MudTheme _theme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#5C6BC0",
            Secondary = "#7E57C2",
            AppbarBackground = "#5C6BC0",
            Background = "#F5F6FA",
            Surface = "#FFFFFF",
            DrawerBackground = "#FFFFFF",
            DrawerText = "#424242",
            TextPrimary = "#212121",
        }
    };
}

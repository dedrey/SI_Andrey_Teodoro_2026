@page "/fornecedores"
@rendermode InteractiveServer

<PageTitle>Fornecedores</PageTitle>

<LoadingSpinner Visivel="_carregando" />

<div class="d-flex align-center mb-4">
    <MudIcon Icon="@Icons.Material.Filled.LocalShipping" Color="Color.Primary" Class="mr-2" Style="font-size:1.8rem;" />
    <MudText Typo="Typo.h5" Style="font-weight:700;">Fornecedores</MudText>
</div>

<!-- FORMULÁRIO -->
<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:8px;">

    <div class="d-flex align-center justify-space-between mb-3">
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
            @(_dto.IdOriginal == 0 ? "Novo Fornecedor" : "Editar Fornecedor")
        </MudText>
        @if (_dto.IdOriginal != 0 && _dto.AtualizadoEm.HasValue)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                     Icon="@Icons.Material.Filled.Edit">
                Atualizado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
            </MudChip>
        }
    </div>

    <MudForm @ref="_form" @bind-IsValid="_formValido">
        <MudGrid Spacing="2">

            @if (_dto.IdOriginal != 0)
            {
                <MudItem xs="4" sm="2" md="1">
                    <MudTextField @bind-Value="_dto.Id" Label="ID"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  FullWidth="true" />
                </MudItem>
            }

            <MudItem xs="12" sm="6" md="@(_dto.IdOriginal != 0 ? 4 : 5)">
                <MudTextField Value="@_dto.RazaoSocial"
                              ValueChanged="@((string v) => _dto.RazaoSocial = CapitalizarPrimeira(v))"
                              Label="Razão Social *"
                              Placeholder="Ex: Têxtil Brasil Ltda"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório"
                              MaxLength="255" FullWidth="true" Immediate="true" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudTextField Value="@_dto.NomeFantasia"
                              ValueChanged="@((string v) => _dto.NomeFantasia = CapitalizarPrimeira(v))"
                              Label="Nome Fantasia"
                              Placeholder="Ex: Têxtil Brasil"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="255" FullWidth="true" Immediate="true" />
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudTextField Value="@_dto.Cnpj"
                              ValueChanged="@((string v) => _dto.Cnpj = AplicarMascaraCnpj(v))"
                              Label="CNPJ *"
                              Placeholder="00.000.000/0001-00"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório"
                              MaxLength="18" FullWidth="true" Immediate="true"
                              Validation="@((string v) => ValidarCnpjCampo(v))" />
            </MudItem>

        </MudGrid>
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.caption" Class="mb-2"
                 Style="color:#888;font-weight:600;text-transform:uppercase;letter-spacing:1px;">
            Contato e Localização (opcional)
        </MudText>

        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4" md="2">
                <MudSelect T="int?"
                           Value="@_dto.PaisId"
                           ValueChanged="OnPaisAlterado"
                           Label="País"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           FullWidth="true" Clearable="true">
                    <MudSelectItem T="int?" Value="@((int?)null)">— Selecione —</MudSelectItem>
                    @foreach (var p in _paises)
                    {
                        <MudSelectItem T="int?" Value="@((int?)p.Id)">@p.NomePais</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="4" md="2">
                <MudSelect T="int?"
                           Value="@_dto.EstadoId"
                           ValueChanged="OnEstadoAlterado"
                           Label="Estado"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           FullWidth="true" Clearable="true"
                           Disabled="@(_dto.PaisId == null)">
                    <MudSelectItem T="int?" Value="@((int?)null)">— Selecione —</MudSelectItem>
                    @foreach (var e in _estados)
                    {
                        <MudSelectItem T="int?" Value="@((int?)e.Id)">@e.NomeEstado (@e.Uf)</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="4" md="2">
                <MudSelect T="int?" @bind-Value="_dto.CidadeId"
                           Label="Cidade"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           FullWidth="true" Clearable="true"
                           Disabled="@(_dto.EstadoId == null)">
                    <MudSelectItem T="int?" Value="@((int?)null)">— Selecione —</MudSelectItem>
                    @foreach (var c in _cidadesFiltradas)
                    {
                        <MudSelectItem T="int?" Value="@((int?)c.Id)">@c.NomeCidade</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudTextField @bind-Value="_dto.Endereco"
                              Label="Endereço"
                              Placeholder="Ex: Rua das Flores, 123"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="255" FullWidth="true" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudTextField @bind-Value="_dto.Bairro"
                              Label="Bairro"
                              Placeholder="Ex: Centro"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="120" FullWidth="true" />
            </MudItem>

        </MudGrid>

        <MudGrid Spacing="2" Class="mt-1">

            <MudItem xs="12" sm="6" md="3">
                <MudTextField Value="@_dto.Telefone"
                              ValueChanged="@((string v) => _dto.Telefone = AplicarMascaraTelefone(v))"
                              Label="Telefone"
                              Placeholder="(45) 99999-0000"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="45" FullWidth="true" Immediate="true" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <MudTextField @bind-Value="_dto.Email"
                              Label="E-mail"
                              Placeholder="contato@empresa.com.br"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="320" FullWidth="true"
                              Validation="@((string? v) => ValidarEmail(v))"
                              InputType="InputType.Email" />
            </MudItem>

            <MudItem xs="12" sm="12" md="6" Class="d-flex justify-end align-end gap-2">
                @if (_dto.IdOriginal != 0)
                {
                    <MudButton Variant="Variant.Outlined" OnClick="LimparFormulario" Style="height:40px;">
                        <MudIcon Icon="@Icons.Material.Filled.Clear" Size="Size.Small" Class="mr-1" />
                        Cancelar
                    </MudButton>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="Salvar" Disabled="_salvando"
                           Style="height:40px;font-weight:700;min-width:120px;">
                    @(_salvando ? "Salvando..." : "SALVAR")
                </MudButton>
            </MudItem>

        </MudGrid>

    </MudForm>
</MudPaper>
<MudPaper Elevation="1" Class="pa-3 mb-3" Style="border-radius:8px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="5" md="5">
            <MudTextField @bind-Value="_filtro.Busca" Label="Pesquisar..."
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          OnKeyUp="@(async e => { if (e.Key == "Enter") await Pesquisar(); })"
                          FullWidth="true" />
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.StatusFiltro"
                       Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("ativos")">Ativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("inativos")">Inativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("todos")">Todos</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.OrdenarPor"
                       Label="Ordenar por" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("nome")">Nome</MudSelectItem>
                <MudSelectItem T="string" Value="@("id")">ID</MudSelectItem>
                <MudSelectItem T="string" Value="@("data")">Data</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="12" md="3" Class="d-flex align-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="Pesquisar" FullWidth="true" Style="height:40px;">Pesquisar</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="LimparFiltros"
                       Style="height:40px;min-width:40px;" title="Limpar filtros">
                <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" />
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>
<MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;">
    <MudTable Items="@(_resultado?.Itens ?? new())" Dense="true" Hover="true" Striped="false"
              Loading="_carregando" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh Style="font-weight:600;">ID</MudTh>
            <MudTh Style="font-weight:600;">Razão Social</MudTh>
            <MudTh Style="font-weight:600;">Nome Fantasia</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">CNPJ</MudTh>
            <MudTh Style="font-weight:600;">Endereço</MudTh>
            <MudTh Style="font-weight:600;">Telefone</MudTh>
            <MudTh Style="font-weight:600;">E-mail</MudTh>
            <MudTh Style="font-weight:600;">Status</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="ID" Style="color:#888;font-size:0.85rem;">@context.Id</MudTd>
            <MudTd DataLabel="Razão Social"><strong>@context.RazaoSocial</strong></MudTd>
            <MudTd DataLabel="Nome Fantasia">
                @(string.IsNullOrWhiteSpace(context.NomeFantasia) ? "—" : context.NomeFantasia)
            </MudTd>
            <MudTd DataLabel="CNPJ" Style="text-align:center;">
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                    @FormatarCnpjExibicao(context.Cnpj)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Endereço">
                @(string.IsNullOrWhiteSpace(context.Endereco) ? "—" : context.Endereco)
            </MudTd>
            <MudTd DataLabel="Telefone">@(string.IsNullOrWhiteSpace(context.Telefone) ? "—" : context.Telefone)</MudTd>
            <MudTd DataLabel="E-mail">@(string.IsNullOrWhiteSpace(context.Email) ? "—" : context.Email)</MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Ativo ? Color.Success : Color.Error)">
                    @(context.Ativo ? "Ativo" : "Inativo")
                </MudChip>
            </MudTd>
            <MudTd Style="text-align:center;">
                <MudTooltip Text="Editar">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => Editar(context.Id))" />
                </MudTooltip>
                <MudTooltip Text="@(context.Ativo ? "Desativar" : "Ativar")">
                    <MudIconButton Icon="@(context.Ativo? Icons.Material.Filled.ToggleOff : Icons.Material.Filled.ToggleOn)"
                                   Color="@(context.Ativo ? Color.Error : Color.Success)" Size="Size.Small"
                                   OnClick="@(() => AlterarStatus(context.Id, context.RazaoSocial, context.Ativo))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="d-flex flex-column align-center pa-6" style="color:#bbb;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:2.5rem;margin-bottom:8px;" />
                <MudText Typo="Typo.body1">Nenhum registro encontrado.</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>
    @if (_resultado != null)
    {
        <div class="pa-2" style="border-top:1px solid #f0f0f0;">
            <PaginacaoComponent PaginaAtual="@_filtro.Pagina"
                                TotalPaginas="@_resultado.TotalPaginas"
                                TotalItens="@_resultado.TotalItens"
                                OnPaginaMudou="MudarPagina" />
        </div>
    }
</MudPaper>

@code {
    private string? ValidarCnpjCampo(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        var digits = new string(v.Where(char.IsDigit).ToArray());
        if (digits.Length != 14) return "CNPJ deve ter 14 dígitos";
        return null;
    }

    private string? ValidarEmail(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return null;
        return v.Contains('@') && v.Contains('.') ? null : "E-mail inválido";
    }
    private string CapitalizarPrimeira(string? v)
    {
        if (string.IsNullOrEmpty(v)) return v ?? "";
        return char.ToUpper(v[0]) + v[1..];
    }
    private string AplicarMascaraCnpj(string? v)
    {
        if (string.IsNullOrEmpty(v)) return "";
        var d = new string(v.Where(char.IsDigit).ToArray());
        if (d.Length > 14) d = d[..14];
        return d.Length switch
        {
            0 => "",
            <= 2 => d,
            <= 5 => $"{d[..2]}.{d[2..]}",
            <= 8 => $"{d[..2]}.{d[2..5]}.{d[5..]}",
            <= 12 => $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..]}",
            _ => $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..12]}-{d[12..]}"
        };
    }

    private string AplicarMascaraTelefone(string? v)
    {
        if (string.IsNullOrEmpty(v)) return "";
        var d = new string(v.Where(char.IsDigit).ToArray());
        if (d.Length > 11) d = d[..11];
        return d.Length switch
        {
            0 => "",
            <= 2 => $"({d}",
            <= 6 => $"({d[..2]}) {d[2..]}",
            <= 10 => $"({d[..2]}) {d[2..6]}-{d[6..]}",
            _ => $"({d[..2]}) {d[2..7]}-{d[7..]}"
        };
    }

    private static string FormatarCnpjExibicao(string cnpj)
    {
        var d = new string(cnpj.Where(char.IsDigit).ToArray());
        return d.Length == 14
            ? $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..12]}-{d[12..]}"
            : cnpj;
    }
}

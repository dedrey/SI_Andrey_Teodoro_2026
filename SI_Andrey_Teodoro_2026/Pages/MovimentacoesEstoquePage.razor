@page "/movimentacoes-estoque"
@rendermode InteractiveServer
@inherits BasePage<MovimentacaoEstoqueListDto, MovimentacaoEstoqueDto>

<PageTitle>Movimentações de Estoque</PageTitle>
<LoadingSpinner Visivel="_carregando" />

<div class="d-flex align-center justify-space-between mb-4">
    <div class="d-flex align-center">
        <MudIcon Icon="@Icons.Material.Filled.SwapVert" Color="Color.Primary" Class="mr-2" Style="font-size:1.8rem;" />
        <MudText Typo="Typo.h5" Style="font-weight:700;">Movimentações de Estoque</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="AbrirModalCadastro" Style="font-weight:700;">
        Registrar
    </MudButton>
</div>

<MudPaper Elevation="1" Class="pa-3 mb-3" Style="border-radius:8px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="5" md="5"><MudTextField @bind-Value="_filtro.Busca" Label="Pesquisar..." Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" OnKeyUp="@(async e => { if (e.Key == "Enter") await Pesquisar(); })" FullWidth="true" /></MudItem>
        <MudItem xs="6" sm="3" md="2"><MudSelect T="string" @bind-Value="_filtro.StatusFiltro" Label="Tipo" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"><MudSelectItem T="string" Value="@("todos")">Todos</MudSelectItem><MudSelectItem T="string" Value="@("ENTRADA")">Entrada</MudSelectItem><MudSelectItem T="string" Value="@("SAIDA")">Saída</MudSelectItem><MudSelectItem T="string" Value="@("AJUSTE")">Ajuste</MudSelectItem></MudSelect></MudItem>
        <MudItem xs="6" sm="3" md="2"><MudSelect T="string" @bind-Value="_filtro.OrdenarPor" Label="Ordenar por" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"><MudSelectItem T="string" Value="@("data")">Data (recente)</MudSelectItem><MudSelectItem T="string" Value="@("id")">ID</MudSelectItem></MudSelect></MudItem>
        <MudItem xs="12" sm="12" md="3" Class="d-flex align-end gap-2"><MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Pesquisar" FullWidth="true" Style="height:40px;">Pesquisar</MudButton><MudButton Variant="Variant.Outlined" OnClick="LimparFiltros" Style="height:40px;min-width:40px;"><MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" /></MudButton></MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;" Class="mb-4">
    <MudTable T="MovimentacaoEstoqueListDto" Items="@(_resultado?.Itens ?? new())" Dense="true" Hover="true" Loading="_carregando" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh Style="width:36px;"></MudTh>
            <MudTh Style="font-weight:600;">ID</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Tipo</MudTh>
            <MudTh Style="font-weight:600;">Data</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Itens</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Qtd. Total</MudTh>
            <MudTh Style="font-weight:600;text-align:right;">Valor Total</MudTh>
            <MudTh Style="font-weight:600;">Observação</MudTh>
        </HeaderContent>
        <RowTemplate Context="mov">
            <MudTd Style="padding:4px 8px;"><MudIconButton Icon="@(_expandidos.Contains(mov.Id)?Icons.Material.Filled.KeyboardArrowDown:Icons.Material.Filled.KeyboardArrowRight)" Size="Size.Small" OnClick="@(async ()=>await ToggleDetalhe(mov.Id))"/></MudTd>
            <MudTd Style="color:#888;font-size:0.85rem;">@mov.Id</MudTd>
            <MudTd Style="text-align:center;"><MudChip T="string" Size="Size.Small" Color="@(mov.TipoMovimentacao=="ENTRADA"?Color.Success:mov.TipoMovimentacao=="SAIDA"?Color.Error:Color.Warning)">@(mov.TipoMovimentacao=="ENTRADA"?"↓ Entrada":mov.TipoMovimentacao=="SAIDA"?"↑ Saída":"⇅ Ajuste")</MudChip></MudTd>
            <MudTd>@mov.CriadoEm.ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd Style="text-align:center;"><MudChip T="string" Size="Size.Small" Color="Color.Info">@mov.TotalItens @(mov.TotalItens==1?"item":"itens")</MudChip></MudTd>
            <MudTd Style="text-align:center;font-weight:600;">@mov.TotalQuantidade un.</MudTd>
            <MudTd Style="text-align:right;font-weight:600;">@if(mov.ValorTotal>0){<span>R$ @mov.ValorTotal.ToString("N2")</span>}else{<span style="color:#bbb;">—</span>}</MudTd>
            <MudTd Style="color:#888;font-size:0.85rem;">@if(!string.IsNullOrWhiteSpace(mov.Observacao)){@(mov.Observacao.Length>50?mov.Observacao[..50]+"…":mov.Observacao)}else{<span style="color:#ccc;">—</span>}</MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (_expandidos.Contains(context.Id))
            {
                <MudTd ColSpan="8" Style="padding:0;background:var(--mud-palette-background-grey);">
                    @if (_detalhesCache.TryGetValue(context.Id, out var itens) && itens != null)
                    {
                        <div style="padding:10px 20px 14px 48px;">
                            <MudTable Items="@itens" Dense="true" Hover="true" Elevation="0" Style="border:0.5px solid #e0e0e0;border-radius:6px;background:white;">
                                <HeaderContent><MudTh Style="font-weight:600;font-size:0.8rem;">Produto</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:center;">Cor</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:center;">Tamanho</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:center;">Quantidade</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:right;">Valor Unit.</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:right;">Total</MudTh></HeaderContent>
                                <RowTemplate Context="item"><MudTd Style="font-weight:600;font-size:0.85rem;">@item.NomeProduto</MudTd><MudTd Style="text-align:center;">@item.Cor</MudTd><MudTd Style="text-align:center;"><MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@item.Tamanho</MudChip></MudTd><MudTd Style="text-align:center;font-weight:600;">@item.Quantidade un.</MudTd><MudTd Style="text-align:right;">@if(item.ValorUnitario>0){<span>R$ @item.ValorUnitario.ToString("N2")</span>}else{<span style="color:#bbb;">—</span>}</MudTd><MudTd Style="text-align:right;font-weight:600;">@if(item.ValorTotal>0){<span>R$ @item.ValorTotal.ToString("N2")</span>}else{<span style="color:#bbb;">—</span>}</MudTd></RowTemplate>
                                <NoRecordsContent><MudTd ColSpan="6" Style="text-align:center;color:#bbb;padding:12px;">Nenhum item.</MudTd></NoRecordsContent>
                            </MudTable>
                        </div>
                    }
                    else
                    {
                        <div style="padding:12px 48px;color:#bbb;font-size:0.85rem;">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>Carregando itens...
                        </div>
                    }
                </MudTd>
            }
        </ChildRowContent>
        <NoRecordsContent><div class="d-flex flex-column align-center pa-6" style="color:#bbb;"><MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:2.5rem;margin-bottom:8px;"/><MudText Typo="Typo.body1">Nenhuma movimentação encontrada.</MudText></div></NoRecordsContent>
    </MudTable>
    @if (_resultado != null) { <div class="pa-2" style="border-top:1px solid #f0f0f0;"><PaginacaoComponent PaginaAtual="@_filtro.Pagina" TotalPaginas="@_resultado.TotalPaginas" TotalItens="@_resultado.TotalItens" OnPaginaMudou="MudarPagina" /></div> }
</MudPaper>

@code { }

@page "/clientes"
@rendermode InteractiveServer

<PageTitle>Clientes</PageTitle>
<LoadingSpinner Visivel="_carregando" />

<div class="d-flex align-center mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Person" Color="Color.Primary" Class="mr-2" Style="font-size:1.8rem;" />
    <MudText Typo="Typo.h5" Style="font-weight:700;">Clientes</MudText>
</div>

<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:8px;">
    <div class="d-flex align-center justify-space-between mb-3">
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
            @(_dto.IdOriginal == 0 ? "Novo Cliente" : "Editar Cliente")
        </MudText>
        @if (_dto.IdOriginal != 0 && _dto.AtualizadoEm.HasValue)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Edit">
                Atualizado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
            </MudChip>
        }
    </div>

    <MudForm @ref="_form" @bind-IsValid="_formValido">
        <MudGrid Spacing="2">
            @if (_dto.IdOriginal != 0)
            {
                <MudItem xs="4" sm="2" md="1">
                    <MudTextField @bind-Value="_dto.Id" Label="ID" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                </MudItem>
            }
            <MudItem xs="6" sm="4" md="2">
                <MudSelect T="string" Value="@_dto.TipoPessoa" ValueChanged="OnTipoPessoaAlterado"
                           Label="Tipo" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                    <MudSelectItem T="string" Value="@("PF")"><MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-1" Size="Size.Small" /> Pessoa Física</MudSelectItem>
                    <MudSelectItem T="string" Value="@("PJ")"><MudIcon Icon="@Icons.Material.Filled.Business" Class="mr-1" Size="Size.Small" /> Pessoa Jurídica</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="4" md="2" Class="d-flex align-center">
                <MudCheckBox T="bool" Value="@_dto.Estrangeiro" ValueChanged="OnEstrangeiroAlterado"
                             Color="Color.Primary" Label="Cliente estrangeiro" />
            </MudItem>
            <MudItem xs="12" sm="@(_dto.IdOriginal != 0 ? 6 : 8)" md="@(_dto.IdOriginal != 0 ? 5 : 8)">
                <MudTextField Value="@_dto.NomeRazaoSocial" ValueChanged="@((string v) => _dto.NomeRazaoSocial = Cap(v))"
                              Label="@(_dto.TipoPessoa == "PJ" ? "Razão Social" : "Nome Completo")"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true" />
            </MudItem>
        </MudGrid>
        <MudGrid Spacing="2" Class="mt-1">
            @if (!_dto.Estrangeiro)
            {
                <MudItem xs="12" sm="4" md="3">
                    <MudTextField Value="@_docTexto" ValueChanged="@((string v) => { OnDocAlterado(v); })"
                                  Label="@(_dto.TipoPessoa == "PF" ? "CPF" : "CNPJ")"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório"
                                  MaxLength="@(_dto.TipoPessoa == "PF" ? 14 : 18)"
                                  FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarDocumento(v))" />
                </MudItem>
                @if (_dto.TipoPessoa == "PJ")
                {
                    <MudItem xs="12" sm="4" md="3">
                        <MudTextField Value="@_dto.ApelidoNomeFantasia" ValueChanged="@((string v) => _dto.ApelidoNomeFantasia = Cap(v))"
                                      Label="Nome Fantasia" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudTextField @bind-Value="_dto.InscricaoEstadual" Label="Inscrição Estadual" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="20" FullWidth="true" />
                    </MudItem>
                    <MudItem xs="12" sm="4" md="3">
                        <MudTextField @bind-Value="_dto.InscricaoMunicipal" Label="Inscrição Municipal" Variant="Variant.Outlined" Margin="Margin.Dense" MaxLength="20" FullWidth="true" />
                    </MudItem>
                }
            }
            else
            {
                <MudItem xs="12" sm="4" md="3">
                    <MudTextField Value="@_docTexto" ValueChanged="@((string v) => { OnDocAlterado(v); })"
                                  Label="Documento Estrangeiro"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Required="true" RequiredError="Obrigatório" MaxLength="30" FullWidth="true" Immediate="true"
                                  Validation="@((string v) => ValidarDocEstrangeiro(v))" />
                </MudItem>
                <MudItem xs="12" sm="4" md="3">
                    <MudAutocomplete T="PaisListDto"
                                     Label="País de Origem"
                                     Value="_paisEstrangeiro"
                                     ValueChanged="@((PaisListDto? p) => { _paisEstrangeiro = p; _dto.Nacionalidade = p?.NomePais; _dto.CidadeId = null; })"
                                     SearchFunc="PesquisarPais"
                                     ToStringFunc="@(p => p == null ? "" : p.NomePais)"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     FullWidth="true" Clearable="true"
                                     ResetValueOnEmptyText="true"
                                     CoerceText="false"
                                     Required="true" RequiredError="Obrigatório"
                                     Validation="@((PaisListDto? p) => p == null ? "Obrigatório" : null)" />
                </MudItem>

                @if (_dto.TipoPessoa == "PJ")
                {
                    <MudItem xs="12" sm="4" md="3">
                        <MudTextField Value="@_dto.ApelidoNomeFantasia" ValueChanged="@((string v) => _dto.ApelidoNomeFantasia = Cap(v))"
                                      Label="Nome Fantasia" Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true" />
                    </MudItem>
                }
            }
        </MudGrid>
        <MudDivider Class="my-3" />
        <MudText Typo="Typo.caption" Class="mb-2" Style="color:#888;font-weight:600;text-transform:uppercase;letter-spacing:1px;">
            Contato e Localização
        </MudText>

        <MudGrid Spacing="2">
            <MudItem xs="12" sm="4" md="3">
                <MudAutocomplete T="CidadeListDto"
                                 Label="Cidade"
                                 Value="_cidadeSelecionada"
                                 ValueChanged="@((CidadeListDto? c) => { _cidadeSelecionada = c; _dto.CidadeId = c?.Id; })"
                                 SearchFunc="PesquisarCidade"
                                 ToStringFunc="@(c => c == null ? "" : $"{c.NomeCidade} ({c.Uf})")"
                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                 FullWidth="true" Clearable="true"
                                 ResetValueOnEmptyText="true"
                                 CoerceText="false" />
            </MudItem>
            <MudItem xs="12" sm="4" md="3">
                <MudTextField Value="@_dto.Endereco" ValueChanged="@((string v) => _dto.Endereco = Cap(v))"
                              Label="Endereço"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true" Immediate="true" />
            </MudItem>
            <MudItem xs="12" sm="4" md="2">
                <MudTextField Value="@_dto.Bairro" ValueChanged="@((string v) => _dto.Bairro = Cap(v))"
                              Label="Bairro"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório" MaxLength="60" FullWidth="true" Immediate="true" />
            </MudItem>
            <MudItem xs="12" sm="4" md="2">
                <MudTextField Value="@_dto.Telefone" ValueChanged="@((string v) => _dto.Telefone = MascaraTel(v))"
                              Label="Telefone"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório" MaxLength="15" FullWidth="true" Immediate="true"
                              Validation="@((string v) => ValidarTel(v))" />
            </MudItem>
            <MudItem xs="12" sm="4" md="2">
                <MudTextField @bind-Value="_dto.Email" Label="E-mail"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório" MaxLength="100" FullWidth="true"
                              Validation="@((string v) => ValidarEmail(v))" InputType="InputType.Email" />
            </MudItem>
        </MudGrid>
        <MudGrid Spacing="2" Class="mt-1">
            <MudItem xs="12" sm="4" md="2">
                <MudTextField Value="@_limiteCreditoTexto"
                              ValueChanged="@((string v) => { OnLimiteCreditoAlterado(v); })"
                              Label="Limite de Crédito (R$)"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="15" FullWidth="true" Immediate="true"
                              Adornment="Adornment.Start" AdornmentText="R$" />
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="2" Class="mt-2">
            <MudItem xs="12" Class="d-flex justify-end align-end gap-2">
                @if (_dto.IdOriginal != 0)
                {
                    <MudButton Variant="Variant.Outlined" OnClick="LimparFormulario" Style="height:40px;min-width:40px;">
                        <MudIcon Icon="@Icons.Material.Filled.Clear" Size="Size.Small" />
                    </MudButton>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar"
                           Disabled="_salvando" Style="height:40px;font-weight:700;min-width:130px;">
                    @(_salvando ? "Salvando..." : "SALVAR")
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudForm>
</MudPaper>
<MudPaper Elevation="1" Class="pa-3 mb-3" Style="border-radius:8px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="5" md="5">
            <MudTextField @bind-Value="_filtro.Busca" Label="Pesquisar..." Variant="Variant.Outlined" Margin="Margin.Dense"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true"
                          OnKeyUp="@(async e => { if (e.Key == "Enter") await Pesquisar(); })" FullWidth="true" />
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.StatusFiltro" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("ativos")">Ativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("inativos")">Inativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("todos")">Todos</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.OrdenarPor" Label="Ordenar por" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("nome")">Nome</MudSelectItem>
                <MudSelectItem T="string" Value="@("id")">ID</MudSelectItem>
                <MudSelectItem T="string" Value="@("data")">Data</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="12" md="3" Class="d-flex align-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Pesquisar" FullWidth="true" Style="height:40px;">Pesquisar</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="LimparFiltros" Style="height:40px;min-width:40px;">
                <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" />
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>
<MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;">
    <MudTable Items="@(_resultado?.Itens ?? new())" Dense="true" Hover="true" Loading="_carregando" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh Style="font-weight:600;">ID</MudTh>
            <MudTh Style="font-weight:600;">Nome / Razão Social</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Tipo</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Documento</MudTh>
            <MudTh Style="font-weight:600;">Telefone</MudTh>
            <MudTh Style="font-weight:600;">E-mail</MudTh>
            <MudTh Style="font-weight:600;text-align:right;">Limite</MudTh>
            <MudTh Style="font-weight:600;">Status</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Style="color:#888;font-size:0.85rem;">@context.Id</MudTd>
            <MudTd>
                <strong>@context.NomeRazaoSocial</strong>
                @if (!string.IsNullOrWhiteSpace(context.ApelidoNomeFantasia))
                {
                    <br />
                    <span style="color:#888;font-size:0.8rem;">@context.ApelidoNomeFantasia</span>
 }
            </MudTd>
            <MudTd Style="text-align:center;">
                @if (context.Estrangeiro)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning">🌍 Estrangeiro</MudChip>
                }
                else
                {

                    <MudChip T="string" Size="Size.Small" Color="@(context.TipoPessoa == "PF" ? Color.Info : Color.Secondary)">@context.TipoPessoa</MudChip>
                }
            </MudTd>
            <MudTd Style="text-align:center;">
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                    @(context.Estrangeiro
                                        ? (context.DocumentoEstrangeiro ?? "—")
                                        : FormatDoc(context.CpfCnpj, context.TipoPessoa))
                </MudChip>
                @if (context.Estrangeiro && !string.IsNullOrWhiteSpace(context.Nacionalidade))
                {
                    <br />
                    <span style="color:#888;font-size:0.75rem;">@context.Nacionalidade</span>
 }
            </MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.Telefone) ? "—" : context.Telefone)</MudTd>
            <MudTd>@(string.IsNullOrWhiteSpace(context.Email) ? "—" : context.Email)</MudTd>
            <MudTd Style="text-align:right;">
                @if (context.LimiteCredito > 0)
                {
                    <MudText Style="font-size:0.85rem;">R$ @context.LimiteCredito.ToString("N2")</MudText>
                }
                else
                {

                    <span style="color:#bbb;">—</span>
                }
            </MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.Ativo? Color.Success: Color.Error)">@(context.Ativo ? "Ativo" : "Inativo")</MudChip></MudTd>
            <MudTd Style="text-align:center;">
                <MudTooltip Text="Editar"><MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => Editar(context.Id))" /></MudTooltip>
                <MudTooltip Text="@(context.Ativo ? "Desativar" : "Ativar")">
                    <MudIconButton Icon="@(context.Ativo? Icons.Material.Filled.ToggleOff : Icons.Material.Filled.ToggleOn)"
                                   Color="@(context.Ativo ? Color.Error : Color.Success)" Size="Size.Small"
                                   OnClick="@(() => AlterarStatus(context.Id, context.NomeRazaoSocial, context.Ativo))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="d-flex flex-column align-center pa-6" style="color:#bbb;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:2.5rem;margin-bottom:8px;" />
                <MudText Typo="Typo.body1">Nenhum registro encontrado.</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>
    @if (_resultado != null)
    {
        <div class="pa-2" style="border-top:1px solid #f0f0f0;">
            <PaginacaoComponent PaginaAtual="@_filtro.Pagina" TotalPaginas="@_resultado.TotalPaginas" TotalItens="@_resultado.TotalItens" OnPaginaMudou="MudarPagina" />
        </div>
    }
</MudPaper>

@code {
    private string _limiteCreditoTexto = "";
    private CidadeListDto? _cidadeSelecionada
    {
        get => _cidades.FirstOrDefault(c => c.Id == _dto.CidadeId);
        set => _dto.CidadeId = value?.Id;
    }
    private PaisListDto? _paisEstrangeiro
    {
        get => _paises.FirstOrDefault(p => p.NomePais == _dto.Nacionalidade);
        set => _dto.Nacionalidade = value?.NomePais;
    }

    private Task<IEnumerable<CidadeListDto>> PesquisarCidade(string? busca, CancellationToken ct)
    {
        var fonte = (_dto.Estrangeiro && _paisEstrangeiro != null)
            ? _cidades.Where(c => c.PaisId == _paisEstrangeiro.Id)
            : _cidades;

        var r = string.IsNullOrWhiteSpace(busca)
            ? fonte.Take(50)
            : fonte.Where(c => c.NomeCidade.Contains(busca, StringComparison.OrdinalIgnoreCase)
                            || c.Uf.Contains(busca, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(r);
    }

    private Task<IEnumerable<PaisListDto>> PesquisarPais(string? busca, CancellationToken ct)
    {
        var r = string.IsNullOrWhiteSpace(busca)
            ? _paises.Take(50)
            : _paises.Where(p => p.NomePais.Contains(busca, StringComparison.OrdinalIgnoreCase));
        return Task.FromResult(r);
    }

    private void OnLimiteCreditoAlterado(string? v)
    {
        if (string.IsNullOrEmpty(v)) { _limiteCreditoTexto = ""; _dto.LimiteCredito = 0; return; }
        var filtrado = new string(v.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        _limiteCreditoTexto = filtrado;
        _dto.LimiteCredito = decimal.TryParse(filtrado.Replace(",", "."),
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out decimal val) ? val : 0;
    }

    private string? ValidarDocumento(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        var d = new string(v.Where(char.IsDigit).ToArray());
        if (_dto.TipoPessoa == "PF" && d.Length != 11) return "CPF deve ter 11 dígitos";
        if (_dto.TipoPessoa == "PJ" && d.Length != 14) return "CNPJ deve ter 14 dígitos";
        return null;
    }
    private string? ValidarDocEstrangeiro(string? v) { if (string.IsNullOrWhiteSpace(v)) return "Obrigatório"; if (v.Trim().Length < 4) return "Mínimo 4 caracteres"; return null; }
    private string? ValidarTel(string? v) { if (string.IsNullOrWhiteSpace(v)) return "Obrigatório"; var d = new string(v.Where(char.IsDigit).ToArray()); return d.Length switch { 10 => null, 11 => null, < 10 => "Incompleto", _ => "Máximo 11 dígitos" }; }
    private string? ValidarEmail(string? v) { if (string.IsNullOrWhiteSpace(v)) return "Obrigatório"; return v.Contains('@') && v.Contains('.') ? null : "E-mail inválido"; }
    private string Cap(string? v) { if (string.IsNullOrEmpty(v)) return v ?? ""; return char.ToUpper(v[0]) + v[1..]; }
    private string MascaraTel(string? v)
    {
        if (string.IsNullOrEmpty(v)) return "";
        var d = new string(v.Where(char.IsDigit).ToArray()); if (d.Length > 11) d = d[..11];
        return d.Length switch { 0 => "", <= 2 => $"({d}", <= 6 => $"({d[..2]}) {d[2..]}", <= 10 => $"({d[..2]}) {d[2..6]}-{d[6..]}", _ => $"({d[..2]}) {d[2..7]}-{d[7..]}" };
    }
    private static string FormatDoc(string? doc, string tipo)
    {
        if (string.IsNullOrWhiteSpace(doc)) return "—";
        var d = new string(doc.Where(char.IsDigit).ToArray());
        if (tipo == "PF" && d.Length == 11) return $"{d[..3]}.{d[3..6]}.{d[6..9]}-{d[9..]}";
        if (tipo == "PJ" && d.Length == 14) return $"{d[..2]}.{d[2..5]}.{d[5..8]}/{d[8..12]}-{d[12..]}";
        return doc;
    }
}

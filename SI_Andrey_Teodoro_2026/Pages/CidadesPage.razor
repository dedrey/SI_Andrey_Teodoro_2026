@page "/cidades"
@rendermode InteractiveServer

<PageTitle>Cidades</PageTitle>
<LoadingSpinner Visivel="_carregando" />

<div class="d-flex align-center mb-4">
    <MudIcon Icon="@Icons.Material.Filled.LocationCity" Color="Color.Primary" Class="mr-2" Style="font-size:1.8rem;" />
    <MudText Typo="Typo.h5" Style="font-weight:700;">Cidades</MudText>
</div>

<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:8px;">

    <div class="d-flex align-center justify-space-between mb-3">
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
            @(_dto.IdOriginal == 0 ? "Nova Cidade" : "Editar Cidade")
        </MudText>
        @if (_dto.IdOriginal != 0 && _dto.AtualizadoEm.HasValue)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                     Icon="@Icons.Material.Filled.Edit">
                Atualizado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
            </MudChip>
        }
    </div>

    <MudForm @ref="_form" @bind-IsValid="_formValido">
        <MudGrid Spacing="2">
            @if (_dto.IdOriginal != 0)
            {
                <MudItem xs="4" sm="2" md="1">
                    <MudTextField @bind-Value="_dto.Id" Label="ID"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                </MudItem>
            }
            <MudItem xs="10" sm="5" md="3">
                <MudSelect T="int" Value="_dto.PaisId" ValueChanged="OnPaisAlterado"
                           Label="@(_paisNaoSelecionado ? "País * — Obrigatório!" : "País *")"
                           Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                           Class="@(_paisNaoSelecionado ? "mud-input-error" : "")">
                    <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                    @foreach (var pais in _paises)
                    {
                        <MudSelectItem T="int" Value="@pais.Id">@pais.NomePais</MudSelectItem>
                    }
                </MudSelect>
                @if (_paisNaoSelecionado)
                {
                    <MudText Typo="Typo.caption" Style="color:red;margin-left:14px;">
                        ⚠ Selecione um país antes de salvar
                    </MudText>
                }
            </MudItem>
            <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                <MudTooltip Text="Novo País">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                   Size="Size.Medium" OnClick="AbrirModalPais" />
                </MudTooltip>
            </MudItem>
            <MudItem xs="10" sm="5" md="3">
                <MudSelect T="int" @bind-Value="_dto.EstadoId"
                           Label="@(_estadoNaoSelecionado ? "Estado * — Obrigatório!" : "Estado *")"
                           Variant="Variant.Outlined" Margin="Margin.Dense"
                           Disabled="@(_dto.PaisId == 0)" FullWidth="true"
                           Class="@(_estadoNaoSelecionado ? "mud-input-error" : "")">
                    <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                    @foreach (var estado in _estados)
                    {
                        <MudSelectItem T="int" Value="@estado.Id">@estado.NomeEstado (@estado.Uf)</MudSelectItem>
                    }
                </MudSelect>
                @if (_estadoNaoSelecionado)
                {
                    <MudText Typo="Typo.caption" Style="color:red;margin-left:14px;">
                        ⚠ Selecione um estado antes de salvar
                    </MudText>
                }
            </MudItem>
            <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                <MudTooltip Text="Novo Estado">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                   Size="Size.Medium" Disabled="@(_dto.PaisId == 0)"
                                   OnClick="AbrirModalEstado" />
                </MudTooltip>
            </MudItem>
            <MudItem xs="12" sm="6" md="3">
                <MudTextField Value="@_dto.NomeCidade"
                              ValueChanged="@((string v) => _dto.NomeCidade = CapitalizarPrimeira(v))"
                              Label="Nome da Cidade *" Placeholder="Ex: Campinas"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório" MaxLength="50" FullWidth="true"
                              Immediate="true" Validation="@((string v) => ValidarSoLetras(v, "Cidade"))" />
            </MudItem>
            <MudItem xs="4" sm="2" md="1">
                <MudNumericField T="short" @bind-Value="_dto.Ddd"
                                 Label="DDD *" Placeholder="Ex: 45 ou 407"
                                 Variant="Variant.Outlined" Margin="Margin.Dense"
                                 Required="true" Min="1" Max="999" FullWidth="true" />
            </MudItem>
            <MudItem xs="12" sm="12" md="@(_dto.IdOriginal != 0 ? 1 : 2)" Class="d-flex align-end gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar"
                           Disabled="_salvando" FullWidth="true" Style="height:40px;font-weight:700;">
                    @(_salvando ? "Salvando..." : "SALVAR")
                </MudButton>
                @if (_dto.IdOriginal != 0)
                {
                    <MudButton Variant="Variant.Outlined" OnClick="LimparFormulario"
                               Style="height:40px;min-width:40px;">
                        <MudIcon Icon="@Icons.Material.Filled.Clear" Size="Size.Small" />
                    </MudButton>
                }
            </MudItem>
        </MudGrid>
    </MudForm>
</MudPaper>

<MudPaper Elevation="1" Class="pa-3 mb-3" Style="border-radius:8px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="5" md="5">
            <MudTextField @bind-Value="_filtro.Busca" Label="Pesquisar..."
                          Variant="Variant.Outlined" Margin="Margin.Dense"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          OnKeyUp="@(async e => { if (e.Key == "Enter") await Pesquisar(); })" FullWidth="true" />
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.StatusFiltro" Label="Status"
                       Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("ativos")">Ativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("inativos")">Inativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("todos")">Todos</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.OrdenarPor" Label="Ordenar por"
                       Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("nome")">Nome</MudSelectItem>
                <MudSelectItem T="string" Value="@("id")">ID</MudSelectItem>
                <MudSelectItem T="string" Value="@("data")">Data</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="12" md="3" Class="d-flex align-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Pesquisar"
                       FullWidth="true" Style="height:40px;">Pesquisar</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="LimparFiltros"
                       Style="height:40px;min-width:40px;">
                <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" />
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;">
    <MudTable Items="@(_resultado?.Itens ?? new())" Dense="true" Hover="true"
              Loading="_carregando" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh Style="font-weight:600;">ID</MudTh>
            <MudTh Style="font-weight:600;">Cidade</MudTh>
            <MudTh Style="font-weight:600;">DDD</MudTh>
            <MudTh Style="font-weight:600;">Estado</MudTh>
            <MudTh Style="font-weight:600;">UF</MudTh>
            <MudTh Style="font-weight:600;">País</MudTh>
            <MudTh Style="font-weight:600;">DDI</MudTh>
            <MudTh Style="font-weight:600;">Status</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Style="color:#888;font-size:0.85rem;">@context.Id</MudTd>
            <MudTd><strong>@context.NomeCidade</strong></MudTd>
            <MudTd>(@context.Ddd)</MudTd>
            <MudTd>@context.NomeEstado</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Info">@context.Uf</MudChip></MudTd>
            <MudTd>@context.NomePais</MudTd>
            <MudTd>+@context.Ddi</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@(context.Ativo? Color.Success: Color.Error)">
                    @(context.Ativo ? "Ativa" : "Inativa")
                </MudChip>
            </MudTd>
            <MudTd Style="text-align:center;">
                <MudTooltip Text="Editar">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => Editar(context.Id))" />
                </MudTooltip>
                <MudTooltip Text="@(context.Ativo ? "Desativar" : "Ativar")">
                    <MudIconButton Icon="@(context.Ativo? Icons.Material.Filled.ToggleOff : Icons.Material.Filled.ToggleOn)"
                                   Color="@(context.Ativo ? Color.Error : Color.Success)" Size="Size.Small"
                                   OnClick="@(() => AlterarStatus(context.Id, context.NomeCidade, context.Ativo))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="d-flex flex-column align-center pa-6" style="color:#bbb;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:2.5rem;margin-bottom:8px;" />
                <MudText Typo="Typo.body1">Nenhum registro encontrado.</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>
    @if (_resultado != null)
    {
        <div class="pa-2" style="border-top:1px solid #f0f0f0;">
            <PaginacaoComponent PaginaAtual="@_filtro.Pagina" TotalPaginas="@_resultado.TotalPaginas"
                                TotalItens="@_resultado.TotalItens" OnPaginaMudou="MudarPagina" />
        </div>
    }
</MudPaper>

@code {
    private string? ValidarSoLetras(string? v, string campo)
    {
        if (string.IsNullOrWhiteSpace(v)) return $"{campo} é obrigatório";
        if (!System.Text.RegularExpressions.Regex.IsMatch(v, @"^[a-zA-ZÀ-ÿ\s]+$"))
            return $"{campo} deve conter apenas letras";
        return null;
    }
    private string CapitalizarPrimeira(string? v)
    {
        if (string.IsNullOrEmpty(v)) return v ?? "";
        return char.ToUpper(v[0]) + v[1..];
    }
}

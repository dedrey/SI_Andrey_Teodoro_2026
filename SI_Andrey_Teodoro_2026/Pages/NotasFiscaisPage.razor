@page "/notas-fiscais"
@rendermode InteractiveServer

<PageTitle>Notas Fiscais</PageTitle>
<LoadingSpinner Visivel="_carregando" />

<div class="d-flex align-center justify-space-between mb-4">
    <div class="d-flex align-center">
        <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" Class="mr-2" Style="font-size:1.8rem;" />
        <MudText Typo="Typo.h5" Style="font-weight:700;">Notas Fiscais</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="AbrirModalGeracao" Style="font-weight:700;">
        Gerar Nova
    </MudButton>
</div>

<MudPaper Elevation="1" Class="pa-3 mb-3" Style="border-radius:8px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="5" md="5">
            <MudTextField @bind-Value="_filtro.Busca" Label="Pesquisar..." Variant="Variant.Outlined" Margin="Margin.Dense"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true"
                          OnKeyUp="@(async e => { if (e.Key == "Enter") await Pesquisar(); })" FullWidth="true" />
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.StatusFiltro" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("todos")">Todas</MudSelectItem>
                <MudSelectItem T="string" Value="@("emitida")">Emitidas</MudSelectItem>
                <MudSelectItem T="string" Value="@("cancelada")">Canceladas</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.OrdenarPor" Label="Ordenar por" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("data")">Emissão (recente)</MudSelectItem>
                <MudSelectItem T="string" Value="@("numero")">Número</MudSelectItem>
                <MudSelectItem T="string" Value="@("id")">ID</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="12" md="3" Class="d-flex align-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Pesquisar" FullWidth="true" Style="height:40px;">Pesquisar</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="LimparFiltros" Style="height:40px;min-width:40px;"><MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" /></MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;">
    <MudTable Items="@(_resultado?.Itens ?? new())" Dense="true" Hover="true" Loading="_carregando" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh Style="font-weight:600;text-align:center;">Nº/Série</MudTh>
            <MudTh Style="font-weight:600;">Emissão</MudTh>
            <MudTh Style="font-weight:600;">Cliente</MudTh>
            <MudTh Style="font-weight:600;">Emitente</MudTh>
            <MudTh Style="font-weight:600;">Transportadora</MudTh>
            <MudTh Style="font-weight:600;">Origem</MudTh>
            <MudTh Style="font-weight:600;text-align:right;">Valor Total</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Status</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Style="text-align:center;font-family:monospace;">@context.Numero.ToString("D6")/@context.Serie</MudTd>
            <MudTd>@context.DataEmissao.ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd>@context.NomeCliente</MudTd>
            <MudTd>@context.NomeEmitente</MudTd>
            <MudTd>@(context.NomeTransportadora ?? "—")</MudTd>
            <MudTd>
                @if (context.VendaId.HasValue)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.ShoppingCart">
                        Venda #@context.VendaId
                    </MudChip>
                }
            </MudTd>
            <MudTd Style="text-align:right;font-weight:600;">R$ @context.ValorTotal.ToString("N2")</MudTd>
            <MudTd Style="text-align:center;">
                <MudChip T="string" Size="Size.Small" Color="@(context.StatusNfe == "EMITIDA" ? Color.Success : Color.Default)">
                    @(context.StatusNfe == "EMITIDA" ? "Emitida" : "Cancelada")
                </MudChip>
            </MudTd>
            <MudTd Style="text-align:center;">
                <MudTooltip Text="Visualizar / Imprimir">
                    <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Info" Size="Size.Small"
                                   OnClick="@(() => Visualizar(context.Id))" />
                </MudTooltip>

                @if (context.StatusNfe == "EMITIDA")
                {
                    <MudTooltip Text="Cancelar">
                        <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" OnClick="@(() => Cancelar(context.Id))" />
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="d-flex flex-column align-center pa-6" style="color:#bbb;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:2.5rem;margin-bottom:8px;" />
                <MudText Typo="Typo.body1">Nenhuma Nota Fiscal encontrada.</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>
    @if (_resultado != null)
    {
        <div class="pa-2" style="border-top:1px solid #f0f0f0;">
            <PaginacaoComponent PaginaAtual="@_filtro.Pagina" TotalPaginas="@_resultado.TotalPaginas" TotalItens="@_resultado.TotalItens" OnPaginaMudou="MudarPagina" />
        </div>
    }
</MudPaper>
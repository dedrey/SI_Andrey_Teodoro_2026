@page "/produtos"
@rendermode InteractiveServer
@inherits BasePage<ProdutoListDto, ProdutoDto>

<PageTitle>Produtos</PageTitle>
<LoadingSpinner Visivel="_carregando" />

<div class="d-flex align-center justify-space-between mb-4">
    <div class="d-flex align-center">
        <MudIcon Icon="@Icons.Material.Filled.ShoppingBag" Color="Color.Primary" Class="mr-2" Style="font-size:1.8rem;" />
        <MudText Typo="Typo.h5" Style="font-weight:700;">Produtos</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AbrirModalCadastro" Style="font-weight:700;">Cadastrar</MudButton>
</div>

<MudPaper Elevation="1" Class="pa-3 mb-3" Style="border-radius:8px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="5" md="5"><MudTextField @bind-Value="_filtro.Busca" Label="Pesquisar..." Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" OnKeyUp="@(async e => { if (e.Key == "Enter") await Pesquisar(); })" FullWidth="true" /></MudItem>
        <MudItem xs="6" sm="3" md="2"><MudSelect T="string" @bind-Value="_filtro.StatusFiltro" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"><MudSelectItem T="string" Value="@("ativos")">Ativos</MudSelectItem><MudSelectItem T="string" Value="@("inativos")">Inativos</MudSelectItem><MudSelectItem T="string" Value="@("todos")">Todos</MudSelectItem></MudSelect></MudItem>
        <MudItem xs="6" sm="3" md="2"><MudSelect T="string" @bind-Value="_filtro.OrdenarPor" Label="Ordenar por" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"><MudSelectItem T="string" Value="@("id")">ID</MudSelectItem><MudSelectItem T="string" Value="@("nome")">Nome</MudSelectItem></MudSelect></MudItem>
        <MudItem xs="12" sm="12" md="3" Class="d-flex align-end gap-2"><MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Pesquisar" FullWidth="true" Style="height:40px;">Pesquisar</MudButton><MudButton Variant="Variant.Outlined" OnClick="LimparFiltros" Style="height:40px;min-width:40px;"><MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" /></MudButton></MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;" Class="mb-4">
    <MudTable T="ProdutoListDto" Items="@(_resultado?.Itens ?? new())" Dense="true" Hover="true" Loading="_carregando" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh Style="width:36px;"></MudTh>
            <MudTh Style="font-weight:600;">ID</MudTh>
            <MudTh Style="font-weight:600;">Produto</MudTh>
            <MudTh Style="font-weight:600;">Categoria</MudTh>
            <MudTh Style="font-weight:600;">Marca</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Un.</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Variações</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Estoque</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Status</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate Context="produto">
            <MudTd Style="padding:4px 8px;"><MudIconButton Icon="@(_expandidos.Contains(produto.Id)?Icons.Material.Filled.KeyboardArrowDown:Icons.Material.Filled.KeyboardArrowRight)" Size="Size.Small" OnClick="@(async ()=>await ToggleExpansao(produto.Id))"/></MudTd>
            <MudTd Style="color:#888;font-size:0.85rem;">@produto.Id</MudTd>
            <MudTd Style="font-weight:600;">@produto.Produto</MudTd>
            <MudTd>@produto.NomeCategoria</MudTd>
            <MudTd>@produto.NomeMarca</MudTd>
            <MudTd Style="text-align:center;"><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">@produto.SiglaUnidade</MudChip></MudTd>
            <MudTd Style="text-align:center;"><MudChip T="string" Size="Size.Small" Color="Color.Info">@produto.TotalVariacoes @(produto.TotalVariacoes == 1 ? "variação" : "variações")</MudChip></MudTd>
            <MudTd Style="text-align:center;"><MudChip T="string" Size="Size.Small" Color="@(produto.TotalEstoque > 0 ? Color.Success : Color.Warning)">@produto.TotalEstoque un.</MudChip></MudTd>
            <MudTd Style="text-align:center;"><MudChip T="string" Size="Size.Small" Color="@(produto.Ativo ? Color.Success : Color.Error)">@(produto.Ativo ? "Ativo" : "Inativo")</MudChip></MudTd>
            <MudTd Style="text-align:center;">
                <MudTooltip Text="Visualizar"><MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(async ()=>await Visualizar(produto.Id))"/></MudTooltip>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(async ()=>await Editar(produto.Id))"/>
                <MudIconButton Icon="@(produto.Ativo ? Icons.Material.Filled.ToggleOn : Icons.Material.Filled.ToggleOff)" Color="@(produto.Ativo ? Color.Success : Color.Error)" Size="Size.Small" OnClick="@(async ()=>await AlterarStatus(produto.Id, produto.Produto, produto.Ativo))"/>
            </MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (_expandidos.Contains(context.Id))
            {
                <MudTd ColSpan="10" Style="padding:0;background:var(--mud-palette-background-grey);">
                    @if (_variacoesCache.TryGetValue(context.Id, out var variacoes) && variacoes != null)
                    {
                        <div style="padding:10px 20px 14px 48px;">
                            <MudTable Items="@variacoes" Dense="true" Hover="true" Elevation="0" Style="border:0.5px solid #e0e0e0;border-radius:6px;background:white;">
                                <HeaderContent><MudTh Style="font-weight:600;font-size:0.8rem;">Cor</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;">Tamanho</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;">Cód. Barras</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:right;">Preço</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:center;">Estoque</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:center;">Status</MudTh></HeaderContent>
                                <RowTemplate Context="v">
                                    <MudTd>@v.Cor</MudTd><MudTd><MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@v.Tamanho</MudChip></MudTd><MudTd Style="color:#888;font-size:0.82rem;">@(string.IsNullOrEmpty(v.CodigoBarras) ? "—" : v.CodigoBarras)</MudTd><MudTd Style="text-align:right;font-weight:600;">R$ @v.Preco.ToString("N2")</MudTd>
                                    <MudTd Style="text-align:center;font-weight:600;">@v.QuantidadeEstoque un.</MudTd>
                                    <MudTd Style="text-align:center;"><MudChip T="string" Size="Size.Small" Color="@(v.Ativo ? Color.Success : Color.Error)" Variant="Variant.Outlined">@(v.Ativo?"Ativo":"Inativo")</MudChip></MudTd>
                                </RowTemplate>
                            </MudTable>
                        </div>
                    }
                    else
                    {
                        <div style="padding:12px 48px;color:#bbb;font-size:0.85rem;"><MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>Carregando variações...</div>
                    }
                </MudTd>
            }
        </ChildRowContent>
        <NoRecordsContent><div class="d-flex flex-column align-center pa-6" style="color:#bbb;"><MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:2.5rem;margin-bottom:8px;"/><MudText Typo="Typo.body1">Nenhum produto encontrado.</MudText></div></NoRecordsContent>
    </MudTable>
    @if (_resultado != null) { <div class="pa-2" style="border-top:1px solid #f0f0f0;"><PaginacaoComponent PaginaAtual="@_filtro.Pagina" TotalPaginas="@_resultado.TotalPaginas" TotalItens="@_resultado.TotalItens" OnPaginaMudou="MudarPagina" /></div> }
</MudPaper>

@code { }

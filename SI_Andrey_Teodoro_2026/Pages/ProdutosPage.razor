@page "/produtos"
@rendermode InteractiveServer
@inherits BasePage<ProdutoListDto, ProdutoDto>

<PageTitle>Produtos</PageTitle>
<LoadingSpinner Visivel="_carregando" />

<div class="d-flex align-center mb-4">
    <MudIcon Icon="@Icons.Material.Filled.Inventory2" Color="Color.Primary" Class="mr-2" Style="font-size:1.8rem;" />
    <MudText Typo="Typo.h5" Style="font-weight:700;">Produtos</MudText>
</div>

<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:8px;">
    <div class="d-flex align-center justify-space-between mb-3">
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
            @(_dto.IdOriginal == 0 ? "Novo Produto" : "Editar Produto")
        </MudText>
        @if (_dto.IdOriginal != 0 && _dto.AtualizadoEm.HasValue)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Edit">
                Atualizado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
            </MudChip>
        }
    </div>
    <MudForm @ref="_form" @bind-IsValid="_formValido">
        <MudGrid Spacing="2">
            @if (_dto.IdOriginal != 0)
            {
                <MudItem xs="3" sm="2" md="1">
                    <MudTextField @bind-Value="_dto.Id" Label="ID"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                </MudItem>
            }
            <MudItem xs="@(_dto.IdOriginal != 0 ? 9 : 12)" sm="@(_dto.IdOriginal != 0 ? 10 : 12)" md="@(_dto.IdOriginal != 0 ? 11 : 12)">
                <MudTextField Value="@_dto.Produto"
                              ValueChanged="@((string v) => _dto.Produto = Cap(v))"
                              Label="Produto"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório"
                              MaxLength="100" FullWidth="true" Immediate="true"
                              Validation="@((string v) => ValidarNome(v))" />
            </MudItem>
        </MudGrid>
        <MudGrid Spacing="2" Class="mt-2">
            <MudItem xs="10" sm="4" md="4">
                <MudSelect T="int" @bind-Value="_dto.CategoriaId"
                           Label="Categoria *" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                    <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                    @foreach (var c in _categorias)
                    {
                        <MudSelectItem T="int" Value="@c.Id">@c.NomeCategoria</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="2" sm="1" md="1" Class="d-flex align-end pb-1">
                <MudTooltip Text="Nova Categoria">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                   Size="Size.Medium" OnClick="AbrirModalCategoria" />
                </MudTooltip>
            </MudItem>
            <MudItem xs="10" sm="4" md="3">
                <MudSelect T="int" @bind-Value="_dto.MarcaId"
                           Label="Marca *" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                    <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                    @foreach (var m in _marcas)
                    {
                        <MudSelectItem T="int" Value="@m.Id">@m.NomeMarca</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="2" sm="1" md="1" Class="d-flex align-end pb-1">
                <MudTooltip Text="Nova Marca">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                   Size="Size.Medium" OnClick="AbrirModalMarca" />
                </MudTooltip>
            </MudItem>
            <MudItem xs="10" sm="4" md="2">
                <MudSelect T="int" @bind-Value="_dto.UnidadeMedidaId"
                           Label="Unidade *" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                    <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                    @foreach (var u in _unidades)
                    {
                        <MudSelectItem T="int" Value="@u.Id">@u.Sigla — @u.Descricao</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="2" sm="1" md="1" Class="d-flex align-end pb-1">
                <MudTooltip Text="Nova Unidade de Medida">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                   Size="Size.Medium" OnClick="AbrirModalUnidade" />
                </MudTooltip>
            </MudItem>
        </MudGrid>
        <MudGrid Spacing="2" Class="mt-2">
            <MudItem xs="12">
                <MudTextField Value="@_dto.Descricao"
                              ValueChanged="@((string? v) => _dto.Descricao = v)"
                              Label="Descrição"
                              Placeholder="Descrição detalhada do produto (opcional)"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="500" FullWidth="true" Lines="2" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-4" />
        <div class="d-flex align-center justify-space-between mb-3">
            <MudText Typo="Typo.subtitle2" Style="font-weight:600;text-transform:uppercase;letter-spacing:1px;color:#888;">
                <MudIcon Icon="@Icons.Material.Filled.Palette" Size="Size.Small" Class="mr-1" />
                Variações (Cor / Tamanho / Preço)
            </MudText>
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.AddCircleOutline"
                       OnClick="AdicionarVariacao">
                Nova Variação
            </MudButton>
        </div>

        @if (_dto.Variacoes.Any(v => !v.Removida))
        {
            <MudTable Items="@_dto.Variacoes.Where(v => !v.Removida)" Dense="true" Hover="false"
                      Elevation="0" Style="border:1px solid #f0f0f0;border-radius:8px;">
                <HeaderContent>
                    <MudTh Style="font-weight:600;">Cor</MudTh>
                    <MudTh Style="font-weight:600;">Tamanho</MudTh>
                    <MudTh Style="font-weight:600;">Cód. de Barras</MudTh>
                    <MudTh Style="font-weight:600;">Preço (R$)</MudTh>
                    <MudTh Style="font-weight:600;text-align:center;">Estoque</MudTh>
                    <MudTh Style="font-weight:600;text-align:center;">Status / Ação</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudTextField Value="@context.Cor"
                                      ValueChanged="@((string v) => context.Cor = Cap(v))"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      MaxLength="30" Immediate="true" FullWidth="true" />
                    </MudTd>
                    <MudTd>
                        <MudTextField Value="@context.Tamanho"
                                      ValueChanged="@((string v) => context.Tamanho = FiltrarTamanho(v))"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      MaxLength="10" Immediate="true" FullWidth="true" />
                    </MudTd>
                    <MudTd>
                        <MudTextField @bind-Value="context.CodigoBarras"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      MaxLength="50" FullWidth="true" />
                    </MudTd>
                    <MudTd>
                        <MudTextField Value="@GetPrecoTexto(context)"
                                      ValueChanged="@((string v) => OnPrecoAlterado(context, v))"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      Immediate="true" FullWidth="true"
                                      Adornment="Adornment.Start" AdornmentText="R$" />
                    </MudTd>
                    <MudTd Style="text-align:center;">
                        @if (context.IdOriginal > 0)
                        {
                            <div class="d-flex align-center justify-center gap-1">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove" Size="Size.Small"
                                               Disabled="@(context.QuantidadeEstoque <= 0)"
                                               OnClick="@(() => AlterarEstoqueInline(context, -1))" />
                                <MudText Typo="Typo.body2" Style="min-width:32px;text-align:center;font-weight:600;">
                                    @context.QuantidadeEstoque
                                </MudText>
                                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                                               OnClick="@(() => AlterarEstoqueInline(context, +1))" />
                            </div>
                        }
                        else
                        {
                            <MudText Typo="Typo.caption" Style="color:#bbb;">Salve primeiro</MudText>
                        }
                    </MudTd>
                    <MudTd Style="text-align:center;">
                        @if (context.IdOriginal == 0)
                        {
                            <MudTooltip Text="Remover variação">
                                <MudIconButton Icon="@Icons.Material.Filled.DeleteOutline"
                                               Color="Color.Error" Size="Size.Small"
                                               OnClick="@(() => RemoverVariacao(context))" />
                            </MudTooltip>
                        }
                        else
                        {
                            <MudChip T="string" Size="Size.Small"
                                     Color="@(context.QuantidadeEstoque > 0 ? Color.Success : Color.Warning)"
                                     Variant="Variant.Outlined">
                                @(context.QuantidadeEstoque > 0 ? "Em estoque" : "Sem estoque")
                            </MudChip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
        else
        {
            <div class="d-flex align-center justify-center pa-4"
                 style="border:1px dashed #ddd;border-radius:8px;color:#bbb;">
                <MudIcon Icon="@Icons.Material.Filled.AddCircleOutline" Class="mr-2" />
                <MudText Typo="Typo.body2">Clique em "Nova Variação" para adicionar cor, tamanho e preço.</MudText>
            </div>
        }

        <MudGrid Spacing="2" Class="mt-3">
            <MudItem xs="12" Class="d-flex justify-end align-end gap-2">
                @if (_dto.IdOriginal != 0)
                {
                    <MudButton Variant="Variant.Outlined" OnClick="LimparFormulario"
                               Style="height:40px;min-width:40px;" title="Cancelar edição">
                        <MudIcon Icon="@Icons.Material.Filled.Clear" Size="Size.Small" />
                    </MudButton>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar"
                           Disabled="_salvando" Style="height:40px;font-weight:700;min-width:130px;">
                    @(_salvando ? "Salvando..." : "SALVAR")
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudForm>
</MudPaper>

<MudPaper Elevation="1" Class="pa-3 mb-3" Style="border-radius:8px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="5" md="5">
            <MudTextField @bind-Value="_filtro.Busca" Label="Pesquisar..." Variant="Variant.Outlined" Margin="Margin.Dense"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true"
                          OnKeyUp="@(async e => { if (e.Key == "Enter") await Pesquisar(); })" FullWidth="true" />
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.StatusFiltro" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("ativos")">Ativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("inativos")">Inativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("todos")">Todos</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.OrdenarPor" Label="Ordenar por" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("nome")">Nome</MudSelectItem>
                <MudSelectItem T="string" Value="@("id")">ID</MudSelectItem>
                <MudSelectItem T="string" Value="@("data")">Data</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="12" md="3" Class="d-flex align-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Pesquisar" FullWidth="true" Style="height:40px;">Pesquisar</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="LimparFiltros" Style="height:40px;min-width:40px;">
                <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" />
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;">
    <MudTable T="ProdutoListDto"
              Items="@(_resultado?.Itens ?? new())"
              Dense="true" Hover="true"
              Loading="_carregando" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh Style="width:36px;"></MudTh>
            <MudTh Style="font-weight:600;">ID</MudTh>
            <MudTh Style="font-weight:600;">Produto</MudTh>
            <MudTh Style="font-weight:600;">Categoria</MudTh>
            <MudTh Style="font-weight:600;">Marca</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Un.</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Variações</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Estoque</MudTh>
            <MudTh Style="font-weight:600;">Status</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate Context="produto">
            <MudTd Style="padding:4px 8px;">
                <MudIconButton Icon="@(_expandidos.Contains(produto.Id) ? Icons.Material.Filled.KeyboardArrowDown : Icons.Material.Filled.KeyboardArrowRight)"
                               Size="Size.Small" Color="Color.Default"
                               OnClick="@(() => ToggleExpansao(produto.Id))" />
            </MudTd>
            <MudTd Style="color:#888;font-size:0.85rem;">@produto.Id</MudTd>
            <MudTd>
                <strong>@produto.Produto</strong>
                @if (!string.IsNullOrWhiteSpace(produto.Descricao))
                {
                    <br />
                    <span style="color:#888;font-size:0.78rem;">
                        @(produto.Descricao.Length > 60 ? produto.Descricao[..60] + "…" : produto.Descricao)
                    </span>
                }
            </MudTd>
            <MudTd>@produto.NomeCategoria</MudTd>
            <MudTd>@produto.NomeMarca</MudTd>
            <MudTd Style="text-align:center;">
                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@produto.SiglaUnidade</MudChip>
            </MudTd>
            <MudTd Style="text-align:center;">
                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                    @produto.TotalVariacoes @(produto.TotalVariacoes == 1 ? "variação" : "variações")
                </MudChip>
            </MudTd>
            <MudTd Style="text-align:center;">
                <MudChip T="string" Size="Size.Small"
                         Color="@(produto.TotalEstoque > 0 ? Color.Success : Color.Warning)">
                    @produto.TotalEstoque un.
                </MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Color="@(produto.Ativo? Color.Success: Color.Error)">
                    @(produto.Ativo ? "Ativo" : "Inativo")
                </MudChip>
            </MudTd>
            <MudTd Style="text-align:center;">
                <MudTooltip Text="Editar">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => Editar(produto.Id))" />
                </MudTooltip>
                <MudTooltip Text="@(produto.Ativo ? "Desativar" : "Ativar")">
                    <MudIconButton Icon="@(produto.Ativo? Icons.Material.Filled.ToggleOff : Icons.Material.Filled.ToggleOn)"
                                   Color="@(produto.Ativo ? Color.Error : Color.Success)" Size="Size.Small"
                                   OnClick="@(() => AlterarStatus(produto.Id, produto.Produto, produto.Ativo))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (_expandidos.Contains(context.Id))
            {
                <MudTd ColSpan="10" Style="padding:0;background:var(--mud-palette-background-grey);">
                    @if (_variacoesCache.TryGetValue(context.Id, out var vars) && vars != null)
                    {
                        <div style="padding:10px 20px 14px 48px;">
                            <MudText Typo="Typo.caption"
                                     Style="font-weight:600;text-transform:uppercase;letter-spacing:1px;color:#888;display:block;margin-bottom:6px;">
                                <MudIcon Icon="@Icons.Material.Filled.Palette" Size="Size.Small" Style="vertical-align:-3px;margin-right:4px;" />
                                Variações
                            </MudText>
                            <MudTable Items="@vars" Dense="true" Hover="true" Elevation="0"
                                      Style="border:0.5px solid #e0e0e0;border-radius:6px;background:white;">
                                <HeaderContent>
                                    <MudTh Style="font-weight:600;font-size:0.8rem;">Cor</MudTh>
                                    <MudTh Style="font-weight:600;font-size:0.8rem;text-align:center;">Tamanho</MudTh>
                                    <MudTh Style="font-weight:600;font-size:0.8rem;">Cód. Barras</MudTh>
                                    <MudTh Style="font-weight:600;font-size:0.8rem;text-align:right;">Preço</MudTh>
                                    <MudTh Style="font-weight:600;font-size:0.8rem;text-align:center;">Estoque</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="variacao">
                                    <MudTd Style="font-size:0.85rem;">@variacao.Cor</MudTd>
                                    <MudTd Style="text-align:center;">
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">@variacao.Tamanho</MudChip>
                                    </MudTd>
                                    <MudTd Style="font-size:0.82rem;color:#888;">
                                        @(string.IsNullOrWhiteSpace(variacao.CodigoBarras) ? "—" : variacao.CodigoBarras)
                                    </MudTd>
                                    <MudTd Style="text-align:right;font-weight:600;">
                                        R$ @variacao.Preco.ToString("N2")
                                    </MudTd>
                                    <MudTd Style="text-align:center;">
                                        <MudChip T="string" Size="Size.Small"
                                                 Color="@(variacao.QuantidadeEstoque > 0 ? Color.Success : Color.Warning)">
                                            @variacao.QuantidadeEstoque un.
                                        </MudChip>
                                    </MudTd>
                                </RowTemplate>
                                <NoRecordsContent>
                                    <MudTd ColSpan="5" Style="text-align:center;color:#bbb;padding:12px;">
                                        Nenhuma variação cadastrada.
                                    </MudTd>
                                </NoRecordsContent>
                            </MudTable>
                        </div>
                    }
                    else
                    {
                        <div style="padding:12px 48px;color:#bbb;font-size:0.85rem;">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            Carregando variações...
                        </div>
                    }
                </MudTd>
            }
        </ChildRowContent>
        <NoRecordsContent>
            <div class="d-flex flex-column align-center pa-6" style="color:#bbb;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:2.5rem;margin-bottom:8px;" />
                <MudText Typo="Typo.body1">Nenhum registro encontrado.</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>
    @if (_resultado != null)
    {
        <div class="pa-2" style="border-top:1px solid #f0f0f0;">
            <PaginacaoComponent PaginaAtual="@_filtro.Pagina" TotalPaginas="@_resultado.TotalPaginas"
                                TotalItens="@_resultado.TotalItens" OnPaginaMudou="MudarPagina" />
        </div>
    }
</MudPaper>

@code {
    private readonly Dictionary<ProdutoVariacaoDto, string> _precoTextos = new();
    private readonly HashSet<int> _expandidos = new();
    private readonly Dictionary<int, List<ProdutoVariacaoDto>?> _variacoesCache = new();

    private async Task ToggleExpansao(int produtoId)
    {
        if (_expandidos.Contains(produtoId))
        {
            _expandidos.Remove(produtoId);
            return;
        }
        _expandidos.Add(produtoId);
        if (!_variacoesCache.ContainsKey(produtoId))
        {
            _variacoesCache[produtoId] = null;
            StateHasChanged();
            var dto = await ProdutoService.ObterPorIdAsync(produtoId);
            _variacoesCache[produtoId] = dto?.Variacoes ?? new();
            StateHasChanged();
        }
    }

    private string GetPrecoTexto(ProdutoVariacaoDto v)
    {
        if (!_precoTextos.ContainsKey(v))
            _precoTextos[v] = v.Preco > 0 ? v.Preco.ToString("N2") : "";
        return _precoTextos[v];
    }

    private void OnPrecoAlterado(ProdutoVariacaoDto v, string? texto)
    {
        if (string.IsNullOrEmpty(texto)) { _precoTextos[v] = ""; v.Preco = 0; return; }
        var filtrado = new string(texto.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        _precoTextos[v] = filtrado;
        v.Preco = decimal.TryParse(filtrado.Replace(",", "."),
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out decimal d) ? d : 0;
    }

    private string? ValidarNome(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        if (v.Trim().Length < 2) return "Deve ter pelo menos 2 caracteres";
        return null;
    }

    private string FiltrarTamanho(string? v)
        => string.IsNullOrEmpty(v) ? "" : v.Trim().ToUpper();

    private static readonly HashSet<string> _minusculas = new(StringComparer.OrdinalIgnoreCase)
    {
        "da","de","do","das","dos","e","a","o","as","os","em","no","na","nos","nas",
        "com","por","para","ao","aos","à","às","the","of","and","del","los","las","la","le"
    };

    private string Cap(string? v)
    {
        if (string.IsNullOrEmpty(v)) return v ?? "";
        var palavras = v.Trim().ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        for (int i = 0; i < palavras.Length; i++)
            if (i == 0 || i == palavras.Length - 1 || !_minusculas.Contains(palavras[i]))
                palavras[i] = char.ToUpper(palavras[i][0]) + palavras[i][1..];
        return string.Join(" ", palavras);
    }
}

@page "/condicoes-pagamento"
@rendermode InteractiveServer

<PageTitle>Condições de Pagamento</PageTitle>
<LoadingSpinner Visivel="_carregando" />

<div class="d-flex align-center mb-4">
    <MudIcon Icon="@Icons.Material.Filled.RequestQuote" Color="Color.Primary" Class="mr-2" Style="font-size:1.8rem;" />
    <MudText Typo="Typo.h5" Style="font-weight:700;">Condições de Pagamento</MudText>
</div>

<MudPaper Elevation="1" Class="pa-4 mb-4" Style="border-radius:8px;">
    <div class="d-flex align-center justify-space-between mb-3">
        <MudText Typo="Typo.subtitle1" Style="font-weight:600;">
            @(_dto.IdOriginal == 0 ? "Nova Condição de Pagamento" : "Editar Condição de Pagamento")
        </MudText>
        @if (_dto.IdOriginal != 0 && _dto.AtualizadoEm.HasValue)
        {
            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Edit">
                Atualizado em @_dto.AtualizadoEm.Value.ToString("dd/MM/yyyy HH:mm")
            </MudChip>
        }
    </div>

    <MudForm @ref="_form" @bind-IsValid="_formValido">
        <MudGrid Spacing="2">
            @if (_dto.IdOriginal != 0)
            {
                <MudItem xs="4" sm="2" md="1">
                    <MudTextField @bind-Value="_dto.Id" Label="ID" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                </MudItem>
            }
            <MudItem xs="12" sm="6" md="@(_dto.IdOriginal != 0 ? 5 : 6)">
                <MudTextField Value="@_dto.CondicaoPagamento"
                              ValueChanged="@((string v) => _dto.CondicaoPagamento = Cap(v))"
                              Label="Condição de Pagamento"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório"
                              MaxLength="50" FullWidth="true" Immediate="true"
                              Validation="@((string v) => ValidarNome(v))" />
            </MudItem>
            
            <MudItem xs="10" sm="5" md="3">
                <MudSelect T="int" @bind-Value="_dto.MetodoPagamentoId"
                           Label="@(_metodonNaoSelecionado ? "Método * — Obrigatório!" : "Método de Pagamento *")"
                           Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"
                           Class="@(_metodonNaoSelecionado ? "mud-input-error" : "")">
                    <MudSelectItem T="int" Value="0" Disabled="true">— Selecione —</MudSelectItem>
                    @foreach (var metodo in _metodos)
                    {
                        <MudSelectItem T="int" Value="@metodo.Id">[@metodo.Codigo] @metodo.MetodoPagamento</MudSelectItem>
                    }
                </MudSelect>
                @if (_metodonNaoSelecionado)
                {
                    <MudText Typo="Typo.caption" Style="color:red;margin-left:14px;">⚠ Selecione um método antes de salvar</MudText>
                }
            </MudItem>
            <MudItem xs="2" sm="1" Class="d-flex align-end pb-1">
                <MudTooltip Text="Novo Método de Pagamento">
                    <MudIconButton Icon="@Icons.Material.Filled.AddCircle" Color="Color.Primary"
                                   Size="Size.Medium" OnClick="AbrirModalMetodoPagamento" />
                </MudTooltip>
            </MudItem>


            <MudItem xs="6" sm="3" md="2">
                <MudTextField Value="@_parcelasTexto"
                              ValueChanged="@((string v) => OnParcelasAlterado(v))"
                              Label="Nº Parcelas"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              Required="true" RequiredError="Obrigatório"
                              MaxLength="3" FullWidth="true" Immediate="true"
                              Validation="@((string v) => ValidarParcelas(v))" />
            </MudItem>
        </MudGrid>

        <MudDivider Class="my-3" />
        <MudText Typo="Typo.caption" Class="mb-2"
                 Style="color:#888;font-weight:600;text-transform:uppercase;letter-spacing:1px;">
            Taxas e Percentuais
        </MudText>
        <MudGrid Spacing="2">
            <MudItem xs="6" sm="4" md="2">
                <MudTextField Value="@_entradaTexto"
                              ValueChanged="@((string v) => OnPercentualAlterado(v, "entrada"))"
                              Label="Entrada Mín. (%)"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="10" FullWidth="true" Immediate="true"
                              Adornment="Adornment.End" AdornmentText="%"
                              Validation="@((string v) => ValidarPercentual(v, "Entrada mínima"))" />
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudTextField Value="@_descontoTexto"
                              ValueChanged="@((string v) => OnPercentualAlterado(v, "desconto"))"
                              Label="Desconto (%)"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="10" FullWidth="true" Immediate="true"
                              Adornment="Adornment.End" AdornmentText="%"
                              Validation="@((string v) => ValidarPercentual(v, "Desconto"))" />
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudTextField Value="@_acrescimoTexto"
                              ValueChanged="@((string v) => OnPercentualAlterado(v, "acrescimo"))"
                              Label="Acréscimo (%)"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="10" FullWidth="true" Immediate="true"
                              Adornment="Adornment.End" AdornmentText="%"
                              Validation="@((string v) => ValidarPercentual(v, "Acréscimo"))" />
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudTextField Value="@_multaTexto"
                              ValueChanged="@((string v) => OnPercentualAlterado(v, "multa"))"
                              Label="Multa (%)"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="10" FullWidth="true" Immediate="true"
                              Adornment="Adornment.End" AdornmentText="%"
                              Validation="@((string v) => ValidarPercentual(v, "Multa"))" />
            </MudItem>
            <MudItem xs="6" sm="4" md="2">
                <MudTextField Value="@_jurosTexto"
                              ValueChanged="@((string v) => OnPercentualAlterado(v, "juros"))"
                              Label="Taxa de Juros (%)"
                              Variant="Variant.Outlined" Margin="Margin.Dense"
                              MaxLength="10" FullWidth="true" Immediate="true"
                              Adornment="Adornment.End" AdornmentText="%"
                              Validation="@((string v) => ValidarPercentual(v, "Taxa de juros"))" />
            </MudItem>
        </MudGrid>

        <MudGrid Spacing="2" Class="mt-2">
            <MudItem xs="12" Class="d-flex justify-end align-end gap-2">
                @if (_dto.IdOriginal != 0)
                {
                    <MudButton Variant="Variant.Outlined" OnClick="LimparFormulario"
                               Style="height:40px;min-width:40px;" title="Cancelar edição">
                        <MudIcon Icon="@Icons.Material.Filled.Clear" Size="Size.Small" />
                    </MudButton>
                }
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Salvar"
                           Disabled="_salvando" Style="height:40px;font-weight:700;min-width:130px;">
                    @(_salvando ? "Salvando..." : "SALVAR")
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudForm>
</MudPaper>

<MudPaper Elevation="1" Class="pa-3 mb-3" Style="border-radius:8px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="5" md="5">
            <MudTextField @bind-Value="_filtro.Busca" Label="Pesquisar..." Variant="Variant.Outlined" Margin="Margin.Dense"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true"
                          OnKeyUp="@(async e => { if (e.Key == "Enter") await Pesquisar(); })" FullWidth="true" />
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.StatusFiltro" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("ativos")">Ativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("inativos")">Inativos</MudSelectItem>
                <MudSelectItem T="string" Value="@("todos")">Todos</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="6" sm="3" md="2">
            <MudSelect T="string" @bind-Value="_filtro.OrdenarPor" Label="Ordenar por" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true">
                <MudSelectItem T="string" Value="@("nome")">Nome</MudSelectItem>
                <MudSelectItem T="string" Value="@("metodo")">Método</MudSelectItem>
                <MudSelectItem T="string" Value="@("id")">ID</MudSelectItem>
                <MudSelectItem T="string" Value="@("data")">Data</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="12" md="3" Class="d-flex align-end gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Pesquisar" FullWidth="true" Style="height:40px;">Pesquisar</MudButton>
            <MudButton Variant="Variant.Outlined" OnClick="LimparFiltros" Style="height:40px;min-width:40px;">
                <MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" />
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;">
    <MudTable Items="@(_resultado?.Itens ?? new())" Dense="true" Hover="true" Loading="_carregando" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh Style="font-weight:600;">ID</MudTh>
            <MudTh Style="font-weight:600;">Condição de Pagamento</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Método</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Parcelas</MudTh>
            <MudTh Style="font-weight:600;text-align:right;">Entrada</MudTh>
            <MudTh Style="font-weight:600;text-align:right;">Desconto</MudTh>
            <MudTh Style="font-weight:600;text-align:right;">Acréscimo</MudTh>
            <MudTh Style="font-weight:600;text-align:right;">Juros</MudTh>
            <MudTh Style="font-weight:600;">Status</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Style="color:#888;font-size:0.85rem;">@context.Id</MudTd>
            <MudTd><strong>@context.CondicaoPagamento</strong></MudTd>
            <MudTd Style="text-align:center;">
                <MudTooltip Text="@context.NomeMetodoPagamento">
                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled"
                             Style="font-family:monospace;font-weight:700;">
                        @context.CodigoMetodo
                    </MudChip>
                </MudTooltip>
            </MudTd>
            <MudTd Style="text-align:center;">
                <MudChip T="string" Size="Size.Small" Color="Color.Info">
                    @context.NumeroParcelas @(context.NumeroParcelas == 1 ? "parcela" : "parcelas")
                </MudChip>
            </MudTd>
            <MudTd Style="text-align:right;">
                @if (context.EntradaMinimaPercentual > 0)
                {
                    <MudText Style="font-size:0.85rem;">@context.EntradaMinimaPercentual.ToString("N2")%</MudText>
                }
                else
                {

                    <span style="color:#bbb;">—</span>
                }
            </MudTd>
            <MudTd Style="text-align:right;">
                @if (context.DescontoPercentual > 0)
                {
                    <MudText Style="font-size:0.85rem;color:#2e7d32;">@context.DescontoPercentual.ToString("N2")%</MudText>
                }
                else
                {

                    <span style="color:#bbb;">—</span>
                }
            </MudTd>
            <MudTd Style="text-align:right;">
                @if (context.AcrescimoPercentual > 0)
                {
                    <MudText Style="font-size:0.85rem;color:#c62828;">@context.AcrescimoPercentual.ToString("N2")%</MudText>
                }
                else
                {

                    <span style="color:#bbb;">—</span>
                }
            </MudTd>
            <MudTd Style="text-align:right;">
                @if (context.TaxaJurosPercentual > 0)
                {
                    <MudText Style="font-size:0.85rem;color:#e65100;">@context.TaxaJurosPercentual.ToString("N2")%</MudText>
                }
                else
                {

                    <span style="color:#bbb;">—</span>
                }
            </MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.Ativo? Color.Success: Color.Error)">@(context.Ativo ? "Ativa" : "Inativa")</MudChip></MudTd>
            <MudTd Style="text-align:center;">
                <MudTooltip Text="Editar">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" OnClick="@(() => Editar(context.Id))" />
                </MudTooltip>
                <MudTooltip Text="@(context.Ativo ? "Desativar" : "Ativar")">
                    <MudIconButton Icon="@(context.Ativo? Icons.Material.Filled.ToggleOff : Icons.Material.Filled.ToggleOn)"
                                   Color="@(context.Ativo ? Color.Error : Color.Success)" Size="Size.Small"
                                   OnClick="@(() => AlterarStatus(context.Id, context.CondicaoPagamento, context.Ativo))" />
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="d-flex flex-column align-center pa-6" style="color:#bbb;">
                <MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:2.5rem;margin-bottom:8px;" />
                <MudText Typo="Typo.body1">Nenhum registro encontrado.</MudText>
            </div>
        </NoRecordsContent>
    </MudTable>
    @if (_resultado != null)
    {
        <div class="pa-2" style="border-top:1px solid #f0f0f0;">
            <PaginacaoComponent PaginaAtual="@_filtro.Pagina" TotalPaginas="@_resultado.TotalPaginas" TotalItens="@_resultado.TotalItens" OnPaginaMudou="MudarPagina" />
        </div>
    }
</MudPaper>

@code {
    private string _parcelasTexto = "1";
    private string _entradaTexto = "";
    private string _descontoTexto = "";
    private string _acrescimoTexto = "";
    private string _multaTexto = "";
    private string _jurosTexto = "";

    private void OnParcelasAlterado(string? v)
    {
        if (string.IsNullOrEmpty(v)) { _parcelasTexto = ""; _dto.NumeroParcelas = 1; return; }
        var d = new string(v.Where(char.IsDigit).ToArray());
        _parcelasTexto = d;
        _dto.NumeroParcelas = int.TryParse(d, out int n) && n >= 1 ? n : 1;
    }

    private void OnPercentualAlterado(string? v, string campo)
    {
        var filtrado = string.IsNullOrEmpty(v) ? "" : new string(v.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        var valor = decimal.TryParse(filtrado.Replace(",", "."),
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out decimal d) ? d : 0m;

        switch (campo)
        {
            case "entrada": _entradaTexto = filtrado; _dto.EntradaMinimaPercentual = valor; break;
            case "desconto": _descontoTexto = filtrado; _dto.DescontoPercentual = valor; break;
            case "acrescimo": _acrescimoTexto = filtrado; _dto.AcrescimoPercentual = valor; break;
            case "multa": _multaTexto = filtrado; _dto.MultaPercentual = valor; break;
            case "juros": _jurosTexto = filtrado; _dto.TaxaJurosPercentual = valor; break;
        }
    }

    private string? ValidarNome(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        if (v.Trim().Length < 2) return "Deve ter pelo menos 2 caracteres";
        return null;
    }

    private string? ValidarParcelas(string? v)
    {
        if (string.IsNullOrWhiteSpace(v)) return "Obrigatório";
        if (!int.TryParse(v, out int n) || n < 1 || n > 999) return "Deve ser entre 1 e 999";
        return null;
    }

    private string? ValidarPercentual(string? v, string campo)
    {
        if (string.IsNullOrWhiteSpace(v)) return null;
        var filtrado = new string(v.Where(c => char.IsDigit(c) || c == ',' || c == '.').ToArray());
        if (!decimal.TryParse(filtrado.Replace(",", "."),
            System.Globalization.NumberStyles.Any,
            System.Globalization.CultureInfo.InvariantCulture, out decimal d))
            return $"{campo}: valor inválido";
        if (d < 0 || d > 100) return $"{campo} deve ser entre 0 e 100";
        return null;
    }

    private static readonly HashSet<string> _minusculas = new(StringComparer.OrdinalIgnoreCase)
    {
        "da", "de", "do", "das", "dos", "e", "a", "o", "as", "os",
        "em", "no", "na", "nos", "nas", "com", "por", "para", "ao", "aos",
        "à", "às", "the", "of", "and", "del", "los", "las", "la", "le"
    };

    private string Cap(string? v)
    {
        if (string.IsNullOrEmpty(v)) return v ?? "";
        var palavras = v.Trim().ToLower().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        for (int i = 0; i < palavras.Length; i++)
        {
            if (i == 0 || i == palavras.Length - 1 || !_minusculas.Contains(palavras[i]))
                palavras[i] = char.ToUpper(palavras[i][0]) + palavras[i][1..];
        }
        return string.Join(" ", palavras);
    }
}

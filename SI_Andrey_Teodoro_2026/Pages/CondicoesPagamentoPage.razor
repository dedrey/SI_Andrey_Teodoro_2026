@page "/condicoes-pagamento"
@rendermode InteractiveServer
@inherits BasePage<CondicaoPagamentoListDto, CondicaoPagamentoDto>
<PageTitle>Condições de Pagamento</PageTitle>
<LoadingSpinner Visivel="_carregando" />
<div class="d-flex align-center justify-space-between mb-4">
    <div class="d-flex align-center"><MudIcon Icon="@Icons.Material.Filled.RequestQuote" Color="Color.Primary" Class="mr-2" Style="font-size:1.8rem;"/><MudText Typo="Typo.h5" Style="font-weight:700;">Condições de Pagamento</MudText></div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AbrirModalCadastro" Style="font-weight:700;">Cadastrar</MudButton>
</div>
<MudPaper Elevation="1" Class="pa-3 mb-3" Style="border-radius:8px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="5" md="5"><MudTextField @bind-Value="_filtro.Busca" Label="Pesquisar..." Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" OnKeyUp="@(async e => { if (e.Key=="Enter") await Pesquisar(); })" FullWidth="true"/></MudItem>
        <MudItem xs="6" sm="3" md="2"><MudSelect T="string" @bind-Value="_filtro.StatusFiltro" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"><MudSelectItem T="string" Value="@("ativos")">Ativos</MudSelectItem><MudSelectItem T="string" Value="@("inativos")">Inativos</MudSelectItem><MudSelectItem T="string" Value="@("todos")">Todos</MudSelectItem></MudSelect></MudItem>
        <MudItem xs="6" sm="3" md="2"><MudSelect T="string" @bind-Value="_filtro.OrdenarPor" Label="Ordenar por" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"><MudSelectItem T="string" Value="@("nome")">Nome</MudSelectItem><MudSelectItem T="string" Value="@("metodo")">Método</MudSelectItem><MudSelectItem T="string" Value="@("id")">ID</MudSelectItem></MudSelect></MudItem>
        <MudItem xs="12" sm="12" md="3" Class="d-flex align-end gap-2"><MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Pesquisar" FullWidth="true" Style="height:40px;">Pesquisar</MudButton><MudButton Variant="Variant.Outlined" OnClick="LimparFiltros" Style="height:40px;min-width:40px;"><MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small"/></MudButton></MudItem>
    </MudGrid>
</MudPaper>
<MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;">
    <MudTable Items="@(_resultado?.Itens ?? new())" Dense="true" Hover="true" Loading="_carregando" LoadingProgressColor="Color.Primary">
        <HeaderContent><MudTh Style="font-weight:600;">ID</MudTh><MudTh Style="font-weight:600;">Condição de Pagamento</MudTh><MudTh Style="font-weight:600;text-align:center;">Método</MudTh><MudTh Style="font-weight:600;text-align:center;">Parcelas</MudTh><MudTh Style="font-weight:600;text-align:right;">Desconto</MudTh><MudTh Style="font-weight:600;text-align:right;">Acréscimo</MudTh><MudTh Style="font-weight:600;text-align:right;">Juros</MudTh><MudTh Style="font-weight:600;">Status</MudTh><MudTh Style="font-weight:600;text-align:center;">Ações</MudTh></HeaderContent>
        <RowTemplate>
            <MudTd Style="color:#888;font-size:0.85rem;">@context.Id</MudTd>
            <MudTd><strong>@context.CondicaoPagamento</strong></MudTd>
            <MudTd Style="text-align:center;"><MudTooltip Text="@context.NomeMetodoPagamento"><MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Filled" Style="font-family:monospace;font-weight:700;">@context.CodigoMetodo</MudChip></MudTooltip></MudTd>
            <MudTd Style="text-align:center;"><MudChip T="string" Size="Size.Small" Color="Color.Info">@context.NumeroParcelas @(context.NumeroParcelas==1?"parcela":"parcelas")</MudChip></MudTd>
            <MudTd Style="text-align:right;">@if(context.DescontoPercentual>0){<MudText Style="font-size:0.85rem;color:#2e7d32;">@context.DescontoPercentual.ToString("N2")%</MudText>}else{<span style="color:#bbb;">—</span>}</MudTd>
            <MudTd Style="text-align:right;">@if(context.AcrescimoPercentual>0){<MudText Style="font-size:0.85rem;color:#c62828;">@context.AcrescimoPercentual.ToString("N2")%</MudText>}else{<span style="color:#bbb;">—</span>}</MudTd>
            <MudTd Style="text-align:right;">@if(context.TaxaJurosPercentual>0){<MudText Style="font-size:0.85rem;color:#e65100;">@context.TaxaJurosPercentual.ToString("N2")%</MudText>}else{<span style="color:#bbb;">—</span>}</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="@(context.Ativo?Color.Success:Color.Error)">@(context.Ativo?"Ativa":"Inativa")</MudChip></MudTd>
            <MudTd Style="text-align:center;"><MudTooltip Text="Visualizar"><MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(()=>Visualizar(context.Id))"/></MudTooltip><MudTooltip Text="@(context.Ativo?"Desativar":"Ativar")"><MudIconButton Icon="@(context.Ativo?Icons.Material.Filled.ToggleOff:Icons.Material.Filled.ToggleOn)" Color="@(context.Ativo?Color.Error:Color.Success)" Size="Size.Small" OnClick="@(()=>AlterarStatus(context.Id,context.CondicaoPagamento,context.Ativo))"/></MudTooltip></MudTd>
        </RowTemplate>
        <NoRecordsContent><div class="d-flex flex-column align-center pa-6" style="color:#bbb;"><MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:2.5rem;margin-bottom:8px;"/><MudText Typo="Typo.body1">Nenhum registro encontrado.</MudText></div></NoRecordsContent>
    </MudTable>
    @if (_resultado != null) { <div class="pa-2" style="border-top:1px solid #f0f0f0;"><PaginacaoComponent PaginaAtual="@_filtro.Pagina" TotalPaginas="@_resultado.TotalPaginas" TotalItens="@_resultado.TotalItens" OnPaginaMudou="MudarPagina"/></div> }
</MudPaper>
@code { }

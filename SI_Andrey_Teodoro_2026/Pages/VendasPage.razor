@page "/vendas"
@rendermode InteractiveServer
@inherits BasePage<VendaListDto, VendaDto>

<PageTitle>Vendas</PageTitle>
<LoadingSpinner Visivel="_carregando" />

<div class="d-flex align-center justify-space-between mb-4">
    <div class="d-flex align-center">
        <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Color="Color.Primary" Class="mr-2" Style="font-size:1.8rem;" />
        <MudText Typo="Typo.h5" Style="font-weight:700;">Vendas</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
               OnClick="AbrirModalCadastro" Style="font-weight:700;">
        Nova Venda
    </MudButton>
</div>

<MudPaper Elevation="1" Class="pa-3 mb-3" Style="border-radius:8px;">
    <MudGrid Spacing="2">
        <MudItem xs="12" sm="5" md="5"><MudTextField @bind-Value="_filtro.Busca" Label="Pesquisar..." Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" OnKeyUp="@(async e => { if (e.Key == "Enter") await Pesquisar(); })" FullWidth="true" /></MudItem>
        <MudItem xs="6" sm="3" md="2"><MudSelect T="string" @bind-Value="_filtro.StatusFiltro" Label="Status" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"><MudSelectItem T="string" Value="@("todos")">Todos</MudSelectItem><MudSelectItem T="string" Value="@("ABERTA")">Abertas</MudSelectItem><MudSelectItem T="string" Value="@("FINALIZADA")">Finalizadas</MudSelectItem><MudSelectItem T="string" Value="@("CANCELADA")">Canceladas</MudSelectItem></MudSelect></MudItem>
        <MudItem xs="6" sm="3" md="2"><MudSelect T="string" @bind-Value="_filtro.OrdenarPor" Label="Ordenar por" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true"><MudSelectItem T="string" Value="@("data")">Data (recente)</MudSelectItem><MudSelectItem T="string" Value="@("id")">ID</MudSelectItem></MudSelect></MudItem>
        <MudItem xs="12" sm="12" md="3" Class="d-flex align-end gap-2"><MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Pesquisar" FullWidth="true" Style="height:40px;">Pesquisar</MudButton><MudButton Variant="Variant.Outlined" OnClick="LimparFiltros" Style="height:40px;min-width:40px;"><MudIcon Icon="@Icons.Material.Filled.FilterAltOff" Size="Size.Small" /></MudButton></MudItem>
    </MudGrid>
</MudPaper>

<MudPaper Elevation="1" Style="border-radius:8px;overflow:hidden;">
    <MudTable T="VendaListDto" Items="@(_resultado?.Itens ?? new())" Dense="true" Hover="true" Loading="_carregando" LoadingProgressColor="Color.Primary">
        <HeaderContent>
            <MudTh Style="width:36px;"></MudTh>
            <MudTh Style="font-weight:600;">ID</MudTh>
            <MudTh Style="font-weight:600;">Cliente</MudTh>
            <MudTh Style="font-weight:600;text-align:right;">Subtotal</MudTh>
            <MudTh Style="font-weight:600;text-align:right;">Desc/Acrés</MudTh>
            <MudTh Style="font-weight:600;text-align:right;">Total</MudTh>
            <MudTh Style="font-weight:600;">Status</MudTh>
            <MudTh Style="font-weight:600;">Data</MudTh>
            <MudTh Style="font-weight:600;text-align:center;">Ações</MudTh>
        </HeaderContent>
        <RowTemplate Context="venda">
            <MudTd Style="padding:4px 8px;"><MudIconButton Icon="@(_expandidos.Contains(venda.Id)?Icons.Material.Filled.KeyboardArrowDown:Icons.Material.Filled.KeyboardArrowRight)" Size="Size.Small" OnClick="@(async () => await ToggleItens(venda.Id))"/></MudTd>
            <MudTd Style="color:#888;font-size:0.85rem;">@venda.Id</MudTd>
            <MudTd><strong>@(venda.NomeCliente ?? "—")</strong></MudTd>
            <MudTd Style="text-align:right;">R$ @venda.ValorSubtotal.ToString("N2")</MudTd>
            <MudTd Style="text-align:right;">
                @if (venda.ValorDesconto > 0)
                {
                    <MudText Style="font-size:0.85rem;color:#2e7d32;">-R$ @venda.ValorDesconto.ToString("N2")</MudText>
                }
                else if (venda.ValorDesconto < 0)
                {
                    <MudText Style="font-size:0.85rem;color:#c62828;">+R$ @Math.Abs(venda.ValorDesconto).ToString("N2")</MudText>
                }
                else
                {
                    <span style="color:#bbb;">—</span>
                }
            </MudTd>
            <MudTd Style="text-align:right;font-weight:700;color:#1a237e;">R$ @venda.ValorTotal.ToString("N2")</MudTd>
            <MudTd>
                <MudChip T="string" Size="Size.Small"
                         Color="@(venda.StatusVenda == "ABERTA" ? Color.Info : venda.StatusVenda == "FINALIZADA" ? Color.Success : Color.Error)">
                    @venda.StatusVenda
                </MudChip>
            </MudTd>
            <MudTd Style="font-size:0.85rem;color:#888;">@venda.CriadoEm.ToString("dd/MM/yyyy HH:mm")</MudTd>
            <MudTd Style="text-align:center;">
                @if (venda.StatusVenda == "ABERTA")
                {
                    <MudTooltip Text="Cancelar Venda">
                        <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small"
                                       OnClick="@(async () => await AbrirCancelamento(venda.Id))"/>
                    </MudTooltip>
                }
            </MudTd>
        </RowTemplate>
        <ChildRowContent>
            @if (_expandidos.Contains(context.Id))
            {
                <MudTd ColSpan="9" Style="padding:0;background:var(--mud-palette-background-grey);">
                    @if (_itensCache.TryGetValue(context.Id, out var itens) && itens != null)
                    {
                        <div style="padding:10px 20px 14px 48px;">
                            <MudTable Items="@itens" Dense="true" Hover="true" Elevation="0" Style="border:0.5px solid #e0e0e0;border-radius:6px;background:white;">
                                <HeaderContent><MudTh Style="font-weight:600;font-size:0.8rem;">Produto</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;">Cor / Tamanho</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:center;">Qtd</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:right;">Valor Unit.</MudTh><MudTh Style="font-weight:600;font-size:0.8rem;text-align:right;">Total</MudTh></HeaderContent>
                                <RowTemplate Context="item"><MudTd Style="font-weight:600;font-size:0.85rem;">@item.NomeProduto</MudTd><MudTd>@item.Cor / @item.Tamanho</MudTd><MudTd Style="text-align:center;font-weight:600;">@item.Quantidade un.</MudTd><MudTd Style="text-align:right;">R$ @item.ValorUnitario.ToString("N2")</MudTd><MudTd Style="text-align:right;font-weight:600;">R$ @item.ValorTotal.ToString("N2")</MudTd></RowTemplate>
                                <NoRecordsContent><MudTd ColSpan="5" Style="text-align:center;color:#bbb;padding:12px;">Nenhum item.</MudTd></NoRecordsContent>
                            </MudTable>
                        </div>
                    }
                    else
                    {
                        <div style="padding:12px 48px;color:#bbb;font-size:0.85rem;">
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>Carregando itens...
                        </div>
                    }
                </MudTd>
            }
        </ChildRowContent>
        <NoRecordsContent><div class="d-flex flex-column align-center pa-6" style="color:#bbb;"><MudIcon Icon="@Icons.Material.Filled.SearchOff" Style="font-size:2.5rem;margin-bottom:8px;"/><MudText Typo="Typo.body1">Nenhuma venda encontrada.</MudText></div></NoRecordsContent>
    </MudTable>
    @if (_resultado != null) { <div class="pa-2" style="border-top:1px solid #f0f0f0;"><PaginacaoComponent PaginaAtual="@_filtro.Pagina" TotalPaginas="@_resultado.TotalPaginas" TotalItens="@_resultado.TotalItens" OnPaginaMudou="MudarPagina"/></div> }
</MudPaper>

@code { }
